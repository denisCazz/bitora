---
export interface LinkItem {
  href: string;
  label: string;
  desc?: string;
}

export interface Props {
  title?: string;
  links: LinkItem[];
}

const { title = 'Approfondimenti correlati', links } = Astro.props;
---

<section class="py-12 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-xl md:text-2xl font-bold text-slate-950 dark:text-white mb-6">{title}</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        links.map(link => (
          <a
            href={link.href}
            class="group block rounded-2xl border border-gray-200 dark:border-white/10 bg-white dark:bg-white/[0.03] p-5 hover:border-gray-400 dark:hover:border-white/30 transition-colors"
          >
            <span class="font-semibold text-slate-950 dark:text-white group-hover:text-[color:var(--brand-cta)] transition-colors">
              {link.label}
            </span>
            {link.desc ? (
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{link.desc}</p>
            ) : null}
          </a>
        ))
      }
    </div>
  </div>
</section>

---
export interface Props {
  eyebrow?: string;
  title: string;
  highlight?: string;
  description?: string;
  variant?: 'split' | 'background';
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  posterSrc?: string;
  videoSrc?: string;
  videoLabel?: string;
  images?: { src: string; alt: string }[];
}

const {
  eyebrow,
  title,
  highlight,
  description,
  variant = 'split',
  primaryCta,
  secondaryCta,
  posterSrc,
  videoSrc,
  videoLabel = 'Video di presentazione',
  images = [],
} = Astro.props;
---

<section class="relative overflow-hidden">
  {
    variant === 'background' && videoSrc ? (
      <div class="absolute inset-0" data-hero-bg>
        <video
          class="absolute inset-0 w-full h-full object-cover"
          src={videoSrc}
          autoplay
          muted
          playsinline
          loop
          preload="metadata"
          poster={posterSrc}
          aria-label={videoLabel}
        />
        <div class="absolute inset-0 bg-black/60 dark:bg-black/70" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/35 to-[color:var(--bg-primary)]" />
      </div>
    ) : null
  }

  <div
    class={`absolute inset-0 bg-gradient-to-b from-[color:var(--bg-primary)] via-white to-white dark:from-black dark:via-black dark:to-black ${
      variant === 'background' ? 'opacity-0' : ''
    }`}
  >
  </div>

  <div
    class={`absolute inset-0 pointer-events-none ${
      variant === 'background' ? 'opacity-25' : 'opacity-40'
    }`}
  >
    <div
      class="absolute -top-20 -left-24 w-[520px] h-[520px] rounded-full blur-[120px]"
      style="background: radial-gradient(circle at 30% 30%, rgba(3,105,161,.25), transparent 65%)"
    >
    </div>
    <div
      class="absolute top-1/2 -right-28 w-[520px] h-[520px] rounded-full blur-[130px]"
      style="background: radial-gradient(circle at 70% 30%, rgba(15,23,42,.2), transparent 70%)"
    >
    </div>
  </div>

  <div class="relative z-10 px-6 md:px-12 lg:px-20 py-20 md:py-28">
    <div
      class={`max-w-6xl mx-auto ${
        variant === 'background'
          ? 'max-w-4xl text-center'
          : 'grid lg:grid-cols-12 gap-14 items-center'
      }`}
    >
      <div class={variant === 'background' ? '' : 'lg:col-span-6'}>
        <div
          class={variant === 'background'
            ? 'hero-panel rounded-[32px] px-7 py-9 md:px-10 md:py-12'
            : ''}
        >
          {
            eyebrow ? (
              <p
                class={`text-sm font-semibold tracking-widest uppercase mb-5 ${
                  variant === 'background' ? 'text-white/80' : 'text-slate-500 dark:text-slate-400'
                }`}
              >
                {eyebrow}
              </p>
            ) : null
          }

          <h1
            class={`text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.06] ${
              variant === 'background'
                ? 'text-white hero-title-shadow'
                : 'text-slate-950 dark:text-white'
            }`}
          >
            {title}
            {
              highlight ? (
                <>
                  <br />
                  <span
                    class={
                      variant === 'background' ? 'text-sky-300' : 'text-[color:var(--brand-cta)]'
                    }
                  >
                    {highlight}
                  </span>
                </>
              ) : null
            }
          </h1>

          {
            description ? (
              <p
                class={`mt-6 text-lg md:text-xl leading-relaxed max-w-xl ${
                  variant === 'background'
                    ? 'text-white/85 mx-auto'
                    : 'text-slate-600 dark:text-slate-300'
                }`}
              >
                <span class={variant === 'background' ? 'hero-body-shadow' : ''}>
                  {description}
                </span>
              </p>
            ) : null
          }

          <div
            class={`mt-10 flex flex-col sm:flex-row gap-4 ${variant === 'background' ? 'justify-center' : ''}`}
          >
            <a
              href={primaryCta.href}
              class="btn-primary shine-on-hover group min-w-[220px] flex items-center justify-center gap-2"
            >
              {primaryCta.label}
              <svg
                class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            {
              secondaryCta ? (
                <a
                  href={secondaryCta.href}
                  class="btn-secondary min-w-[220px] flex items-center justify-center gap-2"
                >
                  {secondaryCta.label}
                </a>
              ) : null
            }
          </div>

          <div
            class={`mt-10 flex flex-wrap gap-x-8 gap-y-4 text-sm ${
              variant === 'background'
                ? 'justify-center text-white/80'
                : 'text-slate-600 dark:text-slate-400'
            }`}
          >
            <span class="inline-flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              Risposta in 24h
            </span>
            <span class="inline-flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-sky-500"></span>
              +50 progetti
            </span>
            <span class="inline-flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-slate-800 dark:bg-white"></span>
              Piemonte · Italia
            </span>
          </div>
        </div>
      </div>

      {
        variant === 'split' ? (
          <div class="lg:col-span-6">
            <div class="media-frame relative aspect-[4/3] md:aspect-video">
              {videoSrc ? (
                <video
                  class="absolute inset-0 w-full h-full object-cover"
                  src={videoSrc}
                  autoplay
                  muted
                  playsinline
                  loop
                  preload="metadata"
                  poster={posterSrc}
                  aria-label={videoLabel}
                />
              ) : (
                <img
                  src={posterSrc}
                  alt={videoLabel}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="eager"
                  fetchpriority="high"
                />
              )}

              <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent" />

              <button
                type="button"
                class="absolute top-5 right-5 px-4 py-2 rounded-full bg-white/90 text-slate-900 text-sm font-bold shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-transform"
                data-video-play
              >
                Play video
              </button>

              {images?.length ? (
                <div class="absolute -bottom-8 left-4 right-4 md:left-6 md:right-6">
                  <div class="rounded-2xl px-5 py-4 border border-gray-300 dark:border-white/15 bg-white dark:bg-gray-950 shadow-xl">
                    <div class="flex items-center gap-4">
                      <div class="flex -space-x-2 flex-shrink-0">
                        {images.slice(0, 4).map(img => (
                          <img
                            src={img.src}
                            alt={img.alt}
                            class="w-10 h-10 rounded-full border-2 border-white dark:border-gray-900 object-cover"
                            loading="lazy"
                          />
                        ))}
                      </div>
                      <div class="min-w-0">
                        <div class="flex gap-0.5 text-amber-400">
                          {[1, 2, 3, 4, 5].map(() => (
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                          ))}
                        </div>
                        <p class="text-sm font-semibold text-gray-900 dark:text-white mt-1">
                          +50 clienti soddisfatti
                        </p>
                        <p class="text-xs text-gray-600 dark:text-gray-400">
                          Risultati misurabili · Piemonte e tutta Italia
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              ) : null}
            </div>
          </div>
        ) : null
      }
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
    const videos = document.querySelectorAll<HTMLVideoElement>('video[aria-label]');
    const playBtns = document.querySelectorAll<HTMLButtonElement>('[data-video-play]');
    const heroBgs = document.querySelectorAll<HTMLElement>('[data-hero-bg]');

    videos.forEach(v => {
      const tryPlay = () => {
        v.play()
          .then(() => {
            const btn = v
              .closest('section')
              ?.querySelector('[data-video-play]') as HTMLElement | null;
            btn?.classList.add('hidden');
          })
          .catch(() => {});
      };

      if (!prefersReduced) {
        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(entries => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                tryPlay();
                io.disconnect();
              }
            });
          });
          io.observe(v);
        } else {
          tryPlay();
        }
      }
    });

    playBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const section = btn.closest('section') || btn.closest('.media-frame');
        const vid =
          (section?.querySelector('video[aria-label]') as HTMLVideoElement | null) ||
          (section?.querySelector('video') as HTMLVideoElement | null);
        vid?.play().catch(() => {});
        btn.classList.add('hidden');
      });
    });

    // Parallax on background hero
    if (!prefersReduced) {
      const onScroll = () => {
        const y = window.scrollY || 0;
        heroBgs.forEach(bg => {
          const rect = bg.getBoundingClientRect();
          // only when near viewport
          if (rect.bottom < 0 || rect.top > window.innerHeight) return;
          const strength = 0.12;
          (bg.querySelector('video') as HTMLElement | null)?.classList.add('parallax-layer');
          const t = (y * strength).toFixed(2);
          bg.style.transform = `translateY(${t}px)`;
        });
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  });
</script>

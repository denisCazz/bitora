---
export interface Crumb {
  name: string;
  item: string;
}

export interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: c.name,
    item: c.item,
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

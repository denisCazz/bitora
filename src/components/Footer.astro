---
const currentYear = new Date().getFullYear();
const pathname = (Astro.url.pathname || '/').replace(/\/$/, '') || '/';
// Hide banner on pages that already end with their own demo CTA
const hideFooterCta = [
  '/',
  '/rapportini',
  '/ticketing',
  '/gestione-interventi',
  '/richiedi-demo',
  '/contattaci',
].includes(pathname);
---

{!hideFooterCta && (
  <section class="relative py-14 px-6 md:px-12 bg-black border-t border-white/10">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3 tracking-tight">
        Pronto a vedere il flusso sulla tua azienda?
      </h2>
      <p class="text-white/55 mb-7 max-w-lg mx-auto text-sm md:text-base leading-relaxed">
        Raccontaci come gestisci oggi richieste, tecnici e rapportini. Ti mostreremo una configurazione dimostrativa costruita intorno al tuo processo.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/richiedi-demo"
          data-track="cta_click"
          data-track-location="footer_cta"
          class="inline-flex items-center justify-center gap-2 bg-white text-black font-semibold rounded-full px-7 py-3.5 hover:bg-gray-100 transition-colors"
        >
          Prenota la demo gratuita
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="https://wa.me/393514979670?text=Ciao%2C%20vorrei%20una%20demo%20della%20piattaforma%20gestione%20interventi."
          data-track="whatsapp_click"
          data-track-location="footer_cta"
          class="inline-flex items-center justify-center gap-2 bg-[#1f8f4e] text-white font-semibold rounded-full px-7 py-3.5 hover:bg-[#22a358] transition-colors"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </section>
)}

<footer class="bg-black border-t border-white/10 text-white">
  <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-[1.5fr,1fr,1fr,1fr]">
      <!-- Brand -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-3">
          <img src="/bitora.png" alt="Bitora" class="h-10 w-10 rounded-full object-cover" />
          <span class="text-lg font-semibold tracking-tight"
            >bitora<span class="text-white/35">.it</span></span
          >
        </a>
        <p class="text-sm leading-relaxed text-white/50 max-w-xs">
          Bitora di Denis Cazzulo. Piattaforme operative per assistenza tecnica, manutenzione e interventi sul territorio. Sede a Carmagnola (TO).
        </p>
        <p class="text-xs leading-relaxed text-white/35">
          P.IVA 13359170019
        </p>
        <div class="space-y-3 text-sm">
          <a
            href="mailto:info@bitora.it"
            class="flex items-center gap-2.5 text-white/50 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 2v.01L12 13 4 6.01V6h16ZM4 18V8.2l7.4 6.17a2 2 0 0 0 2.6 0L20 8.2V18H4Z"
              ></path></svg
            >
            info@bitora.it
          </a>
          <a
            href="tel:+393514979670"
            data-track="phone_click"
            data-track-location="footer"
            class="flex items-center gap-2.5 text-white/50 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M6.6 10.8c1.6 3.2 3.4 5 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.3c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1l-2 1.9Z"
              ></path></svg
            >
            +39 351 497 9670
          </a>
          <a
            href="https://wa.me/393514979670"
            target="_blank"
            rel="noopener"
            data-track="whatsapp_click"
            data-track-location="footer"
            class="flex items-center gap-2.5 text-white/50 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
        </div>
        <div class="flex items-center gap-2.5 pt-1">
          <a
            href="https://www.instagram.com/bitorait/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-white/50 hover:text-white hover:border-white/30 transition-all"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a3.999 3.999 0 110-7.998 3.999 3.999 0 010 7.998zm6.406-11.845a1.44 1.44 0 11-2.881-.002 1.44 1.44 0 012.881.002z"
              ></path></svg
            >
          </a>
          <a
            href="https://www.facebook.com/people/Bitora-Italia/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-white/50 hover:text-white hover:border-white/30 transition-all"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.079v-3.47h3.046V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.515c-1.492 0-1.957.925-1.957 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.613 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Piattaforma -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-white/30 mb-6">Piattaforma</h4>
        <ul class="space-y-3.5 text-sm">
          <li>
            <a href="/gestione-interventi" class="text-white/55 hover:text-white transition-colors"
              >Ecosistema</a
            >
          </li>
          <li>
            <a href="/rapportini" class="text-white/55 hover:text-white transition-colors">Rapportini</a>
          </li>
          <li>
            <a href="/ticketing" class="text-white/55 hover:text-white transition-colors">Ticketing</a>
          </li>
          <li>
            <a href="/richiedi-demo" class="text-white/55 hover:text-white transition-colors"
              >Richiedi demo</a
            >
          </li>
          <li>
            <a href="/sistemi-aziendali" class="text-white/55 hover:text-white transition-colors"
              >Sistemi aziendali</a
            >
          </li>
          <li>
            <a
              href="/tools/calcolatore-roi-gestionale"
              class="text-white/55 hover:text-white transition-colors">Calcolatore ROI</a
            >
          </li>
        </ul>
      </div>

      <!-- Servizi -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-white/30 mb-6">Servizi</h4>
        <ul class="space-y-3.5 text-sm">
          <li>
            <a href="/servizi" class="text-white/55 hover:text-white transition-colors">Panoramica</a>
          </li>
          <li>
            <a href="/siti-web-professionali" class="text-white/55 hover:text-white transition-colors"

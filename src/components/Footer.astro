        WhatsApp
      </a>
    </div>
  </div>
</section>

<footer
  class="relative border-t border-gray-200/70 dark:border-white/10 bg-white/70 dark:bg-black/40 backdrop-blur-xl text-gray-700 dark:text-gray-200"
>

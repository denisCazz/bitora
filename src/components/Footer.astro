    <!-- Main footer grid -->
    <div class="mt-12 grid gap-10 lg:grid-cols-[1.2fr,1fr,1fr,1fr]">
      <div class="space-y-6">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400"
          >
            Bitora
          </p>
          <h3 class="mt-2 text-3xl font-semibold text-gray-900 dark:text-white tracking-tight">
            <span class="tracking-tight">bitora</span><span class="text-gray-400">.it</span>
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-300 max-w-sm">
            Sistemi digitali su misura per aziende e PMI. Sede in Piemonte, serviamo clienti in
            tutta Italia.
          </p>
        </div>

        <div class="space-y-3 text-sm">
          <a
            href="mailto:info@bitora.it"
            class="group flex items-center gap-3 hover:text-gray-900 dark:hover:text-white transition-colors"
          >
            <span
              class="inline-flex h-9 w-9 items-center justify-center rounded-2xl bg-gray-100 dark:bg-white/10 text-gray-700 dark:text-gray-300 group-hover:bg-gray-200 dark:group-hover:bg-white/15"
              aria-hidden="true"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 2v.01L12 13 4 6.01V6h16ZM4 18V8.2l7.4 6.17a2 2 0 0 0 2.6 0L20 8.2V18H4Z"
                ></path>
              </svg>
            </span>
            <span class="text-gray-700 dark:text-gray-200">info@bitora.it</span>
          </a>

          <a
            href="tel:+393514979670"
            class="group flex items-center gap-3 hover:text-gray-900 dark:hover:text-white transition-colors"
          >
            <span
              class="inline-flex h-9 w-9 items-center justify-center rounded-2xl bg-gray-100 dark:bg-white/10 text-gray-700 dark:text-gray-300 group-hover:bg-gray-200 dark:group-hover:bg-white/15"
              aria-hidden="true"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M6.6 10.8c1.6 3.2 3.4 5 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.3c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1l-2.0 1.9Z"
                ></path>
              </svg>
            </span>
            <span class="text-gray-700 dark:text-gray-200">+39 3514979670</span>
          </a>

          <div class="flex items-center gap-3 text-gray-500 dark:text-gray-400">
            <span
              class="inline-flex h-9 w-9 items-center justify-center rounded-2xl bg-black/5 dark:bg-white/10"
              aria-hidden="true"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 2a7 7 0 0 0-7 7c0 5.3 7 13 7 13s7-7.7 7-13a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5Z"
                ></path>
              </svg>
            </span>
            <span>Sede: Carmagnola (TO) • Serviamo tutta Italia</span>

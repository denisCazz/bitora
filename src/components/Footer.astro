          </li>
        </ul>
      </div>

      <div>
        <h4
          class="text-sm font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400"
        >
          Azienda
        </h4>
        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a href="/chi-siamo" class="hover:text-gray-900 dark:hover:text-white transition-colors"
              >Chi siamo</a
            >
          </li>
          <li>
            <a href="/lavori" class="hover:text-gray-900 dark:hover:text-white transition-colors"
              >Progetti</a
            >
          </li>
          <li>
            <a
              href="/contattaci"
              class="hover:text-gray-900 dark:hover:text-white transition-colors">Contatti</a
            >
          </li>
          <li>
            <a
              href="/siti-web-piemonte"
              class="hover:text-gray-900 dark:hover:text-white transition-colors">Territorio</a

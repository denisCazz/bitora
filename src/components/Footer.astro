        <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-white/30 mb-6">Legale</h4>
        <ul class="space-y-3.5 text-sm">
          <li>
            <a href="/privacy-policy" class="text-white/55 hover:text-white transition-colors"
              >Privacy policy</a
            >
          </li>
          <li>
            <a href="/cookie-policy" class="text-white/55 hover:text-white transition-colors"
              >Cookie policy</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 pt-6 border-t border-white/[0.07] flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-white/28"

          </li>
          <li>
            <a
              href="/e-commerce-piemonte"
              class="hover:text-gray-900 dark:hover:text-white transition-colors">E-commerce</a
            >
          </li>
          <li>
            <a
              href="/grafica-digitale-social-media"
              class="hover:text-gray-900 dark:hover:text-white transition-colors"
              >Grafica & Social</a
            >
          </li>
          <li>
            <a
              href="/nfc-ecosystem"
              class="hover:text-gray-900 dark:hover:text-white transition-colors">Tessere NFC</a
            >
          </li>
          <li>

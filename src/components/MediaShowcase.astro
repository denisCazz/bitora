---
export interface MediaItem {
  src: string;
  alt: string;
  href?: string;
  caption?: string;
}

export interface Props {
  items: MediaItem[];
}

const { items } = Astro.props;
---

<div class="grid md:grid-cols-12 gap-4">
  {
    items.map((it, idx) => (
      <figure
        class={`group overflow-hidden rounded-3xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel hover-lift ${
          idx === 0 ? 'md:col-span-7' : idx === 1 ? 'md:col-span-5' : 'md:col-span-4'
        }`}
      >
        {it.href ? (
          <a href={it.href} class="block">
            <img
              src={it.src}
              alt={it.alt}
              class="w-full h-full object-cover aspect-[16/10] group-hover:scale-[1.03] transition-transform duration-300"
              loading="lazy"
            />
          </a>
        ) : (
          <img
            src={it.src}
            alt={it.alt}
            class="w-full h-full object-cover aspect-[16/10] group-hover:scale-[1.03] transition-transform duration-300"
            loading="lazy"
          />
        )}
        {it.caption ? (
          <figcaption class="px-5 py-4 text-sm text-slate-700 dark:text-slate-300">
            {it.caption}
          </figcaption>
        ) : null}
      </figure>
    ))
  }
</div>

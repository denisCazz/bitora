---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="space-y-3">
  {
    items.map((it, idx) => (
      <details class="group rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel">
        <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4">
          <span class="font-semibold text-slate-950 dark:text-white">{it.question}</span>
          <span class="w-10 h-10 rounded-xl bg-black/5 dark:bg-white/10 flex items-center justify-center flex-shrink-0">
            <svg
              class="w-5 h-5 text-slate-900 dark:text-white transition-transform duration-200 group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="m19.5 8.25-7.5 7.5-7.5-7.5"
              />
            </svg>
          </span>
        </summary>
        <div class="px-5 pb-5 -mt-1 text-slate-600 dark:text-slate-300 leading-relaxed">
          {it.answer}
        </div>
      </details>
    ))
  }
</div>

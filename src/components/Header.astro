---
const navItems = [
  { name: 'Home', url: '/' },
  { name: 'Servizi', url: '/servizi' },
  { name: 'I nostri lavori', url: '/lavori' },
  { name: 'Free Tools', url: '/tools' },
  { name: 'Contatti', url: '/contattaci' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50">

  <div class="flex items-center justify-between px-8 md:px-16 lg:px-24 py-4">
    <a href="/" class="flex-shrink-0 z-10 flex items-center gap-3" aria-label="Bitora home">
      <img src="/bitora.png" alt="Bitora" class="h-10 w-10 rounded-full object-cover" />
      <span class="text-sm font-semibold text-white/75 hidden md:block tracking-tight">bitora<span class="text-white/30">.it</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-0.5" aria-label="Navigazione principale">
      {navItems.filter(i => i.name !== 'Contatti').map(item => (
        <a
          href={item.url}
          class={(currentPath === item.url || currentPath.startsWith(item.url + '/'))
            ? 'px-3.5 py-2 rounded-lg text-sm font-medium transition-all duration-200 text-white bg-white/[0.09]'
            : 'px-3.5 py-2 rounded-lg text-sm font-medium transition-all duration-200 text-white/60 hover:text-white hover:bg-white/[0.06]'}
        >
          {item.name}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="/contattaci" class="sl-cta-btn hidden md:inline-flex">Contattaci</a>
      <button id="mob-toggle" class="md:hidden text-white p-2 rounded-lg transition-colors hover:bg-white/10" aria-label="Menu" aria-expanded="false">
        <svg id="mob-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="mob-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mob-menu" class="hidden md:hidden bg-black/95 backdrop-blur-xl border-t border-white/10 px-8 py-5">
    <nav class="flex flex-col gap-0.5">
      {navItems.map(item => (
        <a
          href={item.url}
          class={currentPath === item.url
            ? 'py-3 px-3 text-sm font-medium rounded-lg transition-colors text-white bg-white/[0.08]'
            : 'py-3 px-3 text-sm font-medium rounded-lg transition-colors text-white/65 hover:text-white hover:bg-white/[0.05]'}
        >
          {item.name}
        </a>
      ))}
    </nav>
  </div>

</header>

<script>
  const header = document.getElementById('site-header');
  const mobToggle = document.getElementById('mob-toggle');
  const mobMenu = document.getElementById('mob-menu');
  const mobIconOpen = document.getElementById('mob-icon-open');
  const mobIconClose = document.getElementById('mob-icon-close');

  let ticking = false;
  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(() => {
        if (window.scrollY > 60) {
          header?.classList.add('scrolled');
        } else {
          header?.classList.remove('scrolled');
        }
        ticking = false;
      });
      ticking = true;
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  mobToggle?.addEventListener('click', () => {
    const isOpen = !mobMenu?.classList.contains('hidden');
    if (isOpen) {
      mobMenu?.classList.add('hidden');
      mobIconOpen?.classList.remove('hidden');
      mobIconClose?.classList.add('hidden');
      mobToggle.setAttribute('aria-expanded', 'false');
    } else {
      mobMenu?.classList.remove('hidden');
      mobIconOpen?.classList.add('hidden');
      mobIconClose?.classList.remove('hidden');
      mobToggle.setAttribute('aria-expanded', 'true');
    }
  });
</script>

<style>
  #site-header { transition: background .35s ease, border-color .35s ease, box-shadow .35s ease; }
  #site-header.scrolled {
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    box-shadow: 0 4px 32px rgba(0,0,0,0.35);
  }
  .sl-cta-btn {
    display:inline-flex;align-items:center;gap:.5rem;
    background:rgba(255,255,255,0.11);color:#fff;font-weight:600;font-size:.875rem;
    padding:.5rem 1.25rem;border-radius:8px;
    border:1px solid rgba(255,255,255,0.18);
    backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
    transition:background .2s,border-color .2s;white-space:nowrap;
  }
  .sl-cta-btn:hover{background:rgba(255,255,255,0.20);border-color:rgba(255,255,255,0.32);}
</style>
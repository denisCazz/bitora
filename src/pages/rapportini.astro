---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import ProductUi from '../components/product/ProductUi.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';

const campi = [
  'dati del cliente',
  'luogo e data dell’intervento',
  'prodotto o impianto interessato',
  'marca, modello e numero di serie',
  'descrizione del problema',
  'attività eseguite',
  'ore lavorate',
  'ricambi e materiali utilizzati',
  'fotografie',
  'note tecniche',
  'esito dell’intervento',
  'firma del tecnico',
  'firma del cliente',
];

const steps = [
  {
    n: '01',
    t: 'Il tecnico accede all’app',
    d: 'Entra con il proprio account e visualizza i lavori o i rapportini di sua competenza.',
  },
  {
    n: '02',
    t: 'Compila il rapportino',
    d: 'Inserisce i dati del cliente, il problema riscontrato, le operazioni eseguite e il tempo impiegato.',
  },
  {
    n: '03',
    t: 'Aggiunge prove e materiali',
    d: 'Può caricare fotografie, indicare i ricambi utilizzati, inserire note e allegare documentazione.',
  },
  {
    n: '04',
    t: 'Raccoglie le firme',
    d: 'Il cliente e il tecnico possono firmare direttamente sul dispositivo.',
  },
  {
    n: '05',
    t: 'Il documento viene archiviato',
    d: 'Il sistema salva il rapportino, genera il PDF e rende i dati disponibili all’amministrazione.',
  },
];

const features = [
  {
    t: 'Rapportini digitali',
    d: 'Creazione e compilazione dei rapporti di intervento da smartphone, tablet e computer.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    t: 'Firma del cliente',
    d: 'Raccolta della firma direttamente sul dispositivo al termine del lavoro.',
    icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z',
  },
  {
    t: 'Fotografie e allegati',
    d: 'Caricamento di immagini, documenti e prove relative all’intervento.',
    icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    t: 'Generazione PDF',
    d: 'Creazione automatica del documento finale con tutti i dati raccolti.',
    icon: 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  },
  {
    t: 'Archivio centralizzato',
    d: 'Ricerca e consultazione dello storico degli interventi per cliente, tecnico o periodo.',
    icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4',
  },
  {
    t: 'Gestione utenti e ruoli',
    d: 'Accessi differenziati per amministratori, operatori e tecnici.',
    icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  },
  {
    t: 'Statistiche operative',
    d: 'Dashboard con numero di rapportini, tipologie di intervento, attività dei tecnici e andamento nel tempo.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
  {
    t: 'Utilizzo da mobile',
    d: 'Interfaccia responsive e possibilità di installare la piattaforma come applicazione PWA.',
    icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
  },
];

const moduli = [
  { t: 'Pianificazione interventi', d: 'Calendario per organizzare appuntamenti e attività future.' },
  { t: 'Assegnazione lavori', d: 'Distribuzione degli interventi ai tecnici o operatori disponibili.' },
  { t: 'Notifiche e scadenze', d: 'Promemoria per manutenzioni, appuntamenti, documenti e attività da completare.' },
  { t: 'Magazzino ricambi', d: 'Gestione dei ricambi disponibili e registrazione dei materiali usati in intervento.' },
  { t: 'Invio documentazione', d: 'Invio di rapportini, PDF e documenti a clienti o uffici amministrativi.' },
  { t: 'Preventivi', d: 'Creazione e gestione di preventivi collegati a clienti e interventi.' },
];

const vantaggi = [
  'Meno documenti cartacei',
  'Meno errori di compilazione',
  'Informazioni sempre leggibili',
  'Riduzione del lavoro amministrativo',
  'Storico degli interventi centralizzato',
  'Maggiore controllo sul lavoro dei tecnici',
  'Documenti disponibili in pochi secondi',
  'Migliore organizzazione di clienti, interventi e ricambi',
  'Immagine più professionale davanti al cliente',
  'Possibilità di analizzare dati e prestazioni',
];

const destinatari = [
  'Tecnici sul territorio',
  'Manutentori',
  'Installatori',
  'Centri assistenza',
  'Impiantisti',
  'Aziende di climatizzazione',
  'Assistenza su caldaie e stufe',
  'Elettricisti e idraulici',
  'Serramentisti',
  'Facility management',
  'Assistenza su macchinari e attrezzature',
  'Reti di assistenza post-vendita',
];

const integrazioni = [
  'ticketing',
  'CRM',
  'magazzino',
  'calendari',
  'sistemi amministrativi',
  'portali per clienti e centri assistenza',
  'sistemi documentali',
  'intelligenza artificiale',
];

const flowChips = ['Intervento', 'Compilazione', 'Foto e ricambi', 'Firma', 'PDF e archivio'];
---

<Layout
  title="App rapportini digitali per tecnici e manutentori | Bitora"
  description="Digitalizza rapportini, interventi, firme, fotografie e ricambi. Una piattaforma personalizzabile per tecnici, manutentori e centri assistenza."
  image="/field-tablet.jpg"
>
  <div class="product-page">
    <!-- HERO -->
    <section class="prod-hero">
      <div class="prod-hero-media" aria-hidden="true">
        <img
          src="/field-tablet.jpg"
          alt=""
          class="prod-hero-img"
          fetchpriority="high"
          decoding="async"
        />
        <div class="prod-hero-scrim"></div>
      </div>
      <div class="shell prod-hero-copy">
        <p class="eyebrow">Gestione rapportini digitali</p>
        <h1 class="display">
          Rapportini digitali,<br />interventi sotto controllo
        </h1>
        <p class="lede">
          Una piattaforma completa per compilare, firmare, archiviare e gestire i rapporti di intervento,
          direttamente da smartphone, tablet o computer.
        </p>
        <div class="cta-row">
          <a href="/richiedi-demo" class="sl-btn-primary" data-track="cta_click" data-track-location="rapportini_hero"
            >Richiedi una demo</a
          >
          <a href="#funzionalita" class="sl-btn-secondary">Scopri le funzionalità</a>
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="band">
      <div class="shell band-inner">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16" data-reveal>
          <div class="lg:col-span-5">
            <p class="eyebrow">Il valore</p>
            <h2 class="headline">Dal foglio sparso<br />al processo aziendale</h2>
            <p class="body mb-5">
              L’applicazione permette ai tecnici di registrare ogni intervento in formato digitale.
              Elimina carta, file Excel, PDF compilati a mano e informazioni disperse tra email e WhatsApp.
            </p>
            <p class="body-sm">
              Al termine, il sistema archivia il rapporto e può generare automaticamente un documento PDF
              pronto per essere consultato, inviato o conservato.
            </p>
          </div>
          <div class="lg:col-span-6 lg:col-start-7">
            <p class="eyebrow" style="margin-bottom:1rem">Cosa registra il tecnico</p>
            <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-3">
              {campi.map((c) => (
                <li class="flex gap-3 text-sm text-[var(--prod-secondary)] leading-snug">
                  <span class="text-[var(--prod-faint)] mt-0.5 shrink-0">—</span>
                  <span>{c}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- DASHBOARD -->
    <section id="dashboard" class="band band-alt">
      <div class="shell band-inner">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-14 items-start" data-reveal>
          <div class="lg:col-span-5">
            <p class="eyebrow">Dashboard</p>
            <h2 class="headline">Il centro operativo<br />dell’applicazione</h2>
            <p class="body mb-7">
              Un’interfaccia semplice e immediata: da qui si crea un rapportino, si cerca lo storico, si
              leggono le statistiche e si accede ai moduli. Ogni ruolo vede solo ciò che gli serve.
            </p>
            <ul class="space-y-3 text-sm text-[var(--prod-secondary)]">
              {[
                'Nuovo rapportino in pochi tap',
                'Ricerca sullo storico già registrato',
                'Totale rapportini e distribuzione per tipologia',
                'Export PDF, installazione PWA e tema grafico',
                'Accessi differenziati per ruolo',
              ].map((line) => (
                <li class="flex gap-3">
                  <span class="text-[var(--prod-faint)]">→</span>
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="lg:col-span-7">
            <div class="ui-frame" aria-hidden="true">
              <div class="ui-chrome">
                <span class="ui-dot"></span><span class="ui-dot"></span><span class="ui-dot"></span>
                <span class="ml-3 text-xs text-[var(--prod-faint)] tracking-wide">Rapportini · Dashboard</span>
              </div>
              <div class="p-5 md:p-7">
                <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
                  <div>
                    <p class="text-xs text-[var(--prod-faint)] mb-1">Centro operativo</p>
                    <p class="text-lg font-semibold tracking-tight">Panoramica interventi</p>
                  </div>
                  <div class="flex gap-2">
                    <span class="px-3.5 py-1.5 text-xs font-semibold rounded-full bg-[#f5f5f7] text-black"
                      >+ Nuovo rapportino</span
                    >
                    <span
                      class="px-3.5 py-1.5 text-xs font-semibold rounded-full border border-white/20 text-[var(--prod-secondary)]"
                      >Cerca</span
                    >
                  </div>
                </div>
                <div class="grid grid-cols-3 gap-3 mb-6">
                  {[
                    { l: 'Rapportini', v: '248' },
                    { l: 'Questo mese', v: '37' },
                    { l: 'Con firma', v: '96%' },
                  ].map((s) => (
                    <div class="rounded-xl border border-white/[0.08] bg-white/[0.03] p-4">
                      <p class="text-[10px] uppercase tracking-wider text-[var(--prod-faint)] mb-2">{s.l}</p>
                      <p class="text-2xl font-bold tabular-nums tracking-tight">{s.v}</p>
                    </div>
                  ))}
                </div>
                <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6">
                  {['Manutenzione', 'Installazione', 'Assistenza', 'Garanzia', 'Altro'].map((t, i) => (
                    <div class="rounded-xl border border-white/[0.06] p-3">
                      <div class="h-14 flex items-end gap-1 mb-2">
                        <div class="flex-1 bg-white/10 rounded-sm" style={`height:${35 + i * 12}%`}></div>
                        <div class="flex-1 bg-white/25 rounded-sm" style={`height:${50 + ((i * 17) % 40)}%`}
                        ></div>
                      </div>
                      <p class="text-[10px] text-[var(--prod-faint)] truncate">{t}</p>
                    </div>
                  ))}
                </div>
                <div class="rounded-xl border border-white/[0.08] divide-y divide-white/[0.06] overflow-hidden">
                  {[
                    { id: 'R-1042', c: 'Rossi Impianti', t: 'Manutenzione', s: 'Firmato' },
                    { id: 'R-1041', c: 'Bianchi Srl', t: 'Assistenza', s: 'In bozza' },
                    { id: 'R-1040', c: 'Verde Clima', t: 'Installazione', s: 'PDF pronto' },
                  ].map((r) => (
                    <div class="grid grid-cols-4 gap-2 px-4 py-3 text-xs">
                      <span class="text-[var(--prod-faint)] font-mono">{r.id}</span>
                      <span class="text-[var(--prod-text)] truncate">{r.c}</span>
                      <span class="text-[var(--prod-muted)]">{r.t}</span>
                      <span class="text-right text-[var(--prod-secondary)]">{r.s}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
            <p class="text-xs text-[var(--prod-faint)] mt-4">
              Anteprima dell’interfaccia operativa. I dati sono illustrativi.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- COME FUNZIONA -->
    <section id="come-funziona" class="band">
      <div class="shell band-inner">
        <div class="mb-12" data-reveal>
          <p class="eyebrow">Come funziona</p>
          <h2 class="headline max-w-3xl">Cinque passaggi, dal campo all’archivio</h2>
          <div class="flow-rail mt-2">
            {
              flowChips.flatMap((chip, i) =>
                i < flowChips.length - 1
                  ? [
                      <span class="flow-chip">{chip}</span>,
                      <span class="flow-arrow" aria-hidden="true">→</span>,
                    ]
                  : [<span class="flow-chip">{chip}</span>]
              )
            }
          </div>
        </div>
        <div class="grid md:grid-cols-2 xl:grid-cols-5 gap-px bg-[var(--prod-line-soft)] rounded-2xl overflow-hidden" data-reveal>
          {steps.map((s) => (
            <div class="step-cell flex flex-col">
              <span class="text-3xl font-bold text-white/10 tabular-nums mb-4 tracking-tight">{s.n}</span>
              <h3 class="text-base font-bold mb-2.5 leading-snug tracking-tight">{s.t}</h3>
              <p class="text-sm text-[var(--prod-muted)] leading-relaxed">{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="band band-alt">
      <div class="shell band-inner">
        <div class="mb-12 max-w-2xl" data-reveal>
          <p class="eyebrow">Funzionalità</p>
          <h2 class="headline">Cosa fa la piattaforma</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3.5" data-reveal>
          {features.map((f) => (
            <div class="feat-card">
              <svg
                class="w-5 h-5 text-[var(--prod-muted)] mb-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon}></path>
              </svg>
              <h3 class="text-[0.95rem] font-bold mb-2 tracking-tight">{f.t}</h3>
              <p class="text-sm text-[var(--prod-muted)] leading-relaxed">{f.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MODULI -->
    <section class="band">
      <div class="shell band-inner">
        <div class="grid lg:grid-cols-12 gap-10 mb-12" data-reveal>
          <div class="lg:col-span-5">
            <p class="eyebrow">Moduli aggiuntivi</p>
            <h2 class="headline">Modulare, non monolitica</h2>
            <p class="body">
              L’applicazione è modulare e può essere ampliata in base alle esigenze. I moduli sotto sono
              opzionali o personalizzabili: non ogni installazione li include tutti.
            </p>
          </div>
        </div>
        <ul class="border-t border-[var(--prod-line-soft)]" data-reveal>
          {moduli.map((m, i) => (
            <li class="border-b border-[var(--prod-line-soft)] py-6 md:py-7 grid md:grid-cols-12 gap-2 md:gap-8 items-baseline">
              <span class="md:col-span-1 text-[var(--prod-faint)] text-sm font-bold tabular-nums">0{i + 1}</span>
              <h3 class="md:col-span-4 text-lg font-bold tracking-tight">{m.t}</h3>
              <p class="md:col-span-7 text-[var(--prod-muted)] text-sm md:text-base leading-relaxed">{m.d}</p>
            </li>
          ))}
        </ul>
        <p class="mt-10 text-sm text-[var(--prod-faint)]" data-reveal>
          Si collega naturalmente al
          <a href="/ticketing" class="text-[var(--prod-secondary)] underline underline-offset-4 hover:text-white"
            >ticketing</a
          >
          e all’
          <a
            href="/gestione-interventi"
            class="text-[var(--prod-secondary)] underline underline-offset-4 hover:text-white"
            >ecosistema completo</a
          >.
        </p>
      </div>
    </section>

    <!-- VANTAGGI -->
    <section class="band band-alt">
      <div class="shell band-inner">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16" data-reveal>
          <div class="lg:col-span-5">
            <p class="eyebrow">Vantaggi</p>
            <h2 class="headline">Non solo meno carta:<br />più controllo sul lavoro</h2>
            <p class="body">
              Ogni intervento diventa un dato consultabile. L’azienda può sapere chi ha eseguito il lavoro,
              quando, presso quale cliente, quali ricambi sono stati utilizzati e quale è stato l’esito,
              senza cercare informazioni tra moduli cartacei, chat ed email.
            </p>
          </div>
          <div class="lg:col-span-6 lg:col-start-7">
            <ul class="grid sm:grid-cols-2 gap-2.5">
              {vantaggi.map((v) => (
                <li class="rounded-xl border border-[var(--prod-line-soft)] bg-black/40 px-4 py-3.5 text-sm text-[var(--prod-secondary)]">
                  {v}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- DESTINATARI -->
    <section class="band">
      <div class="shell band-inner">
        <div class="mb-10 max-w-2xl" data-reveal>
          <p class="eyebrow">Destinatari</p>
          <h2 class="headline">Pensata per chi lavora sul campo</h2>
        </div>
        <div class="flex flex-wrap gap-2.5" data-reveal>
          {destinatari.map((d) => (
            <span class="status-pill">{d}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- PERSONALIZZAZIONE -->
    <section class="band band-alt">
      <div class="shell band-inner">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16" data-reveal>
          <div class="lg:col-span-6">
            <p class="eyebrow">Personalizzazione</p>
            <h2 class="headline">Adattata ai vostri processi</h2>
            <p class="body mb-5">
              Ogni azienda gestisce gli interventi in modo diverso. Per questo la piattaforma può essere
              configurata con campi, modelli di rapportino, ruoli, stati, moduli e flussi operativi
              personalizzati.
            </p>
            <p class="body-sm">
              Bitora trasforma il rapporto di intervento da documento isolato a parte integrante di un
              processo aziendale organizzato e controllabile.
            </p>
          </div>
          <div class="lg:col-span-5 lg:col-start-8">
            <p class="eyebrow" style="margin-bottom:1rem">Possibilità progettuali</p>
            <ul class="space-y-0">
              {integrazioni.map((i) => (
                <li class="flex gap-3 text-[var(--prod-secondary)] text-sm border-b border-[var(--prod-line-soft)] py-3">
                  <span class="text-[var(--prod-faint)]">+</span>
                  <span>Integrazione con {i}</span>
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--prod-faint)] mt-5 leading-relaxed">
              Presentate come possibilità progettuali, non come integrazioni già attive in ogni installazione.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="band-cta">
      <div class="shell band-cta-inner" data-reveal>
        <p class="eyebrow">Demo</p>
        <h2 class="display" style="font-size:clamp(2rem,5vw,3.5rem);margin-bottom:1.25rem">
          Vuoi digitalizzare i rapportini della tua azienda?
        </h2>
        <p class="lede" style="margin-inline:auto;margin-bottom:2.5rem;text-align:center">
          Mostraci come gestisci oggi tecnici e interventi. Ti faremo vedere come trasformare il tuo
          processo in una piattaforma semplice, centralizzata e costruita intorno al tuo lavoro.
        </p>
        <div class="cta-row" style="justify-content:center">
          <a
            href="/richiedi-demo"
            class="sl-btn-primary"
            data-track="cta_click"
            data-track-location="rapportini_final">Richiedi una demo</a
          >
          <a href="/contattaci" class="sl-btn-secondary">Parla con Bitora</a>
        </div>
      </div>
    </section>
  </div>

  <ProductUi />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Bitora Gestione Rapportini',
      applicationCategory: 'BusinessApplication',
      applicationSubCategory: 'Field Service Management',
      operatingSystem: 'Web, PWA',
      url: 'https://www.bitora.it/rapportini/',
      description:
        'Applicazione web per la gestione digitale dei rapportini tecnici. Permette di registrare interventi, fotografie, materiali, ricambi e firme, generando automaticamente il documento PDF e centralizzando lo storico aziendale.',
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        description: 'Attivazione iniziale + canone. Demo su richiesta.',
      },
    })}
  />

  <BreadcrumbListSchema
    crumbs={[
      { name: 'Home', item: 'https://www.bitora.it/' },
      { name: 'Ecosistema', item: 'https://www.bitora.it/gestione-interventi/' },
      { name: 'Rapportini', item: 'https://www.bitora.it/rapportini/' },
    ]}
  />
</Layout>

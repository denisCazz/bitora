---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    title: 'Come scegliere un gestionale per PMI nel 2026',
    slug: 'gestionale-pmi-2026',
    date: '2026-03-15',
    dateFormatted: '15 Marzo 2026',
    excerpt:
      'Guida completa alla scelta del gestionale aziendale giusto per la tua PMI. Criteri di valutazione, errori da evitare e consigli pratici per il 2026.',
    category: 'Gestionali',
    readTime: '8 min',
  },
  {
    title: 'Web design a Carmagnola: guida completa',
    slug: 'web-design-carmagnola-2025',
    date: '2025-11-20',
    dateFormatted: '20 Novembre 2025',
    excerpt:
      'Tutto quello che devi sapere per realizzare un sito web professionale a Carmagnola e dintorni. SEO locale, design moderno e strategie per farsi trovare.',
    category: 'Siti Web',
    readTime: '7 min',
  },
  {
    title: 'Tessere NFC per ristoranti: come funzionano',
    slug: 'tessere-nfc-ristoranti',
    date: '2025-10-05',
    dateFormatted: '5 Ottobre 2025',
    excerpt:
      'Come le tessere NFC stanno rivoluzionando la raccolta recensioni nei ristoranti. Funzionamento, vantaggi e casi reali di utilizzo.',
    category: 'NFC',
    readTime: '6 min',
  },
];
---

<Layout
  title="Blog Bitora | Articoli su Digitale, Web e Business per PMI"
  description="Articoli, guide e approfondimenti su gestionali, siti web, NFC e strategie digitali per PMI e professionisti. Il blog di Bitora."
>
  <main
    class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden selection:bg-gray-200 dark:selection:bg-white/20 selection:text-gray-900 dark:selection:text-white"
  >
    <!-- Hero -->
    <section class="relative py-24 md:py-32 px-6 md:px-12 lg:px-20 overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-white via-white to-gray-50 dark:from-black dark:via-black dark:to-black/95"
      >
      </div>
      <div
        class="absolute top-1/3 -right-20 w-72 h-72 rounded-full bg-gray-100 dark:bg-white/10 blur-[100px] opacity-50"
      >
      </div>

      <div class="relative z-10 max-w-4xl">
        <p
          class="text-sm font-medium tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-4"
        >
          Blog
        </p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
          Blog<br />
          <span class="text-gray-900 dark:text-white">Bitora.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
          Articoli, guide e approfondimenti su digitale, web e business. Scritti per imprenditori e
          professionisti che vogliono crescere.
        </p>
      </div>
    </section>

    <!-- Articles -->
    <section
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5"
    >
      <div class="max-w-4xl mx-auto">
        <div class="space-y-8">
          {
            articles.map((article, i) => (
              <a
                href={`/blog/${article.slug}`}
                class="group block p-8 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/30 transition-all duration-300 reveal-on-scroll"
                style={`transition-delay: ${i * 100}ms`}
              >
                <div class="flex flex-wrap items-center gap-3 mb-4">
                  <span class="px-3 py-1 text-xs font-medium bg-gray-100 dark:bg-white/10 text-gray-900 dark:text-white rounded-full">
                    {article.category}
                  </span>
                  <span class="text-sm text-gray-500">{article.dateFormatted}</span>
                  <span class="text-sm text-gray-500">&middot; {article.readTime} di lettura</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors">
                  {article.title}
                </h2>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
                  {article.excerpt}
                </p>
                <span class="inline-flex items-center gap-2 text-gray-900 dark:text-white font-medium group-hover:gap-3 transition-all text-sm">
                  Leggi l'articolo{' '}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          Hai un progetto in mente?
        </h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8">
          Parliamone. Consulenza gratuita e senza impegno.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contattaci"
            class="btn-primary inline-flex items-center justify-center gap-2 min-w-[200px]"
            >Richiedi consulenza gratuita</a
          >
          <a
            href="https://wa.me/393514979670?text=Ciao%2C%20ho%20letto%20il%20vostro%20blog%20e%20vorrei%20informazioni.%20Ho%20visitato%20il%20sito%20bitora.it"
            class="btn-secondary inline-flex items-center justify-center gap-2 min-w-[200px]"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  });
</script>

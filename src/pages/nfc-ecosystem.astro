---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';
import MediaShowcase from '../components/MediaShowcase.astro';
import FAQ from '../components/FAQ.astro';
import ServiceSchema from '../components/schema/Service.astro';
import FAQPageSchema from '../components/schema/FAQPage.astro';
import HowToSchema from '../components/schema/HowTo.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';
---

<Layout
  title="Tessere NFC | Biglietti da Visita Smart per Bar, Ristoranti, Professionisti | Bitora"
  description="Tessere NFC programmate su misura: recensioni Google, contatti, menu digitali. Per bar, ristoranti, professionisti. Pellicola intercambiabile. Molto richieste in Piemonte."
  image="/nfc.png"
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <VideoHero
      eyebrow="Tessere NFC"
      title="Biglietti da visita"
      highlight="smart (1 tap)."
      description="Recensioni Google, contatti, menu digitale e link utili. Programmazione inclusa, pellicola intercambiabile e aggiornamenti illimitati."
      primaryCta={{ label: 'Richiedi informazioni', href: '/contattaci?topic=nfc' }}
      secondaryCta={{ label: 'Come funziona', href: '#come-funziona' }}
      posterSrc="/nfc.png"
      videoSrc="https://videos.pexels.com/video-files/6963744/6963744-hd_1920_1080_25fps.mp4"
      videoLabel="Tessera NFC in uso"
      images={[
        { src: '/chanty.JPG', alt: 'Bar Chantilly Carmagnola' },
        { src: '/mistral.jpg', alt: 'Mistral Impianti' },
        { src: '/ilportico.png', alt: 'Il Portico' },
      ]}
    />

    <section
      id="come-funziona"
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Come funziona
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Cos’è una tessera NFC?
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            È una tessera con chip NFC programmato. Con un tap lo smartphone apre una pagina:
            recensioni Google, WhatsApp, menu digitale, sito o contatti.
          </p>

          <dl class="mt-8 space-y-4">
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Programmazione inclusa</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Impostiamo link, contatti e destinazione. Tu devi solo usarla.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Nessun abbonamento</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Aggiornamenti gratuiti: cambi link quando vuoi, senza canone.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Pellicola intercambiabile</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Cambi grafica senza cambiare tessera.
              </dd>
            </div>
          </dl>
        </div>

        <div class="lg:col-span-7">
          <MediaShowcase
            items={[
              {
                src: 'https://images.unsplash.com/photo-1592664474505-43b716088775?auto=format&fit=crop&w=1600&q=80',
                alt: 'Cliente usa smartphone',
                caption: 'Un tap: niente app, niente frizioni.',
              },
              {
                src: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&w=1600&q=80',
                alt: 'Tecnologia e accessori',
                caption: 'Compatibile con smartphone moderni.',
              },
              {
                src: '/nfc.png',
                alt: 'Tessera NFC Bitora',
                caption: 'Design pulito + QR di backup.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Prima/Dopo rimosso: evitiamo blocchi ridondanti -->

    <section class="py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            FAQ tessere NFC
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
            Risposte rapide su costi, tempi e compatibilità.
          </p>
        </div>
        <div class="lg:col-span-7">
          <FAQ
            items={[
              {
                question: 'Le tessere NFC richiedono abbonamento?',
                answer:
                  'No. Programmazione inclusa e aggiornamenti illimitati, senza canone mensile.',
              },
              {
                question: 'Posso collegarla alle recensioni Google?',
                answer:
                  'Sì. Configuriamo link diretto alla pagina recensioni Google della tua attività.',
              },
              {
                question: 'Funziona su iPhone e Android?',
                answer: 'Sì, su dispositivi moderni. Aggiungiamo anche QR di backup.',
              },
              {
                question: 'Posso cambiare il link in futuro?',
                answer: 'Sì. Ti aggiorniamo la destinazione quando vuoi (gratis).',
              },
              {
                question: 'Cosa posso inserire nel tap?',
                answer:
                  'Recensioni, contatti, WhatsApp, menu digitale, sito, social, PDF, link multipli.',
              },
              {
                question: 'Quanto tempo serve?',
                answer: 'Tipicamente pochi giorni: grafica, approvazione e consegna.',
              },
            ]}
          />
        </div>
      </div>
    </section>
  </main>
</Layout>

<ServiceSchema
  name="Tessere NFC programmate"
  url="https://www.bitora.it/nfc-ecosystem/"
  serviceType={['Tessere NFC', 'Recensioni Google', 'Menu digitale', 'Biglietti da visita smart']}
  areaServed={['Carmagnola', 'Torino', 'Piemonte', 'Italia']}
/>

<HowToSchema
  name="Come usare una tessera NFC per recensioni Google"
  description="Setup semplice: scegli destinazione, programmiamo chip, poi tap del cliente."
  steps={[
    {
      name: 'Scegli obiettivo',
      text: 'Recensioni Google, contatti, menu digitale o link multipli.',
    },
    { name: 'Programmazione', text: 'Bitora programma chip NFC e configura QR di backup.' },
    {
      name: 'Consegna e uso',
      text: 'Espone in locale o consegni al cliente: un tap e si apre pagina.',
    },
    { name: 'Aggiornamenti', text: 'Quando vuoi, cambiamo destinazione senza canone.' },
  ]}
/>

<FAQPageSchema
  items={[
    {
      question: 'Le tessere NFC richiedono abbonamento?',
      answer: 'No. Programmazione inclusa e aggiornamenti illimitati, senza canone mensile.',
    },
    {
      question: 'Posso collegarla alle recensioni Google?',
      answer: 'Sì. Configuriamo link diretto alla pagina recensioni Google della tua attività.',
    },
    {
      question: 'Funziona su iPhone e Android?',
      answer: 'Sì, su dispositivi moderni. Aggiungiamo anche QR di backup.',
    },
    {
      question: 'Posso cambiare il link in futuro?',
      answer: 'Sì. Ti aggiorniamo la destinazione quando vuoi (gratis).',
    },
    {
      question: 'Cosa posso inserire nel tap?',
      answer: 'Recensioni, contatti, WhatsApp, menu digitale, sito, social, PDF, link multipli.',
    },
    {
      question: 'Quanto tempo serve?',
      answer: 'Tipicamente pochi giorni: grafica, approvazione e consegna.',
    },
  ]}
/>

<BreadcrumbListSchema
  crumbs={[
    { name: 'Home', item: 'https://www.bitora.it/' },
    { name: 'Tessere NFC', item: 'https://www.bitora.it/nfc-ecosystem/' },
  ]}
/>

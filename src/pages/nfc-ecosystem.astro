---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Tessere NFC | Biglietti da Visita Smart per Bar, Ristoranti, Professionisti | Bitora"
  description="Tessere NFC programmate su misura: recensioni Google, contatti, menu digitali. Per bar, ristoranti, professionisti. Pellicola intercambiabile. Molto richieste in Piemonte."
>
  <main class="bg-black text-white overflow-x-hidden selection:bg-primary/20 selection:text-white">
    
    <!-- Hero -->
    <section class="relative py-24 md:py-32 px-6 md:px-12 lg:px-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-black via-black to-black/95"></div>
      <div class="absolute top-1/3 -right-20 w-72 h-72 rounded-full bg-primary/10 blur-[100px] opacity-50"></div>
      
      <div class="relative z-10 max-w-4xl">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Tessere NFC</p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
          Biglietti da visita<br />
          <span class="text-primary">intelligenti.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl leading-relaxed mb-8">
          Un tap per condividere tutto: recensioni Google, contatti, menu digitali, sito web. <strong class="text-white">Pellicola intercambiabile</strong>, programmazione inclusa, aggiornamenti gratuiti.
        </p>
        <div class="flex flex-wrap gap-6 text-sm text-gray-400 mb-8">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            1 Tap
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Aggiornamenti illimitati
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Nessun abbonamento
          </span>
        </div>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contattaci?topic=nfc" class="btn-primary group min-w-[200px] flex items-center justify-center gap-2">
            Richiedi informazioni
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#come-funziona" class="btn-secondary min-w-[200px] flex items-center justify-center gap-2">
            Come funziona
          </a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-16 md:py-20 px-6 md:px-12 lg:px-20 border-y border-white/5 bg-white/[0.02]">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-3 gap-8 text-center">
          {[
            { value: '1 Tap', label: 'Per condividere tutto' },
            { value: '∞', label: 'Aggiornamenti gratuiti' },
            { value: 'Pellicola', label: 'Grafica intercambiabile' }
          ].map((stat, i) => (
            <div class="reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <p class="text-3xl md:text-4xl font-bold text-white mb-2">{stat.value}</p>
              <p class="text-sm text-gray-500 uppercase tracking-wider">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Come funziona -->
    <section id="come-funziona" class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Come funziona</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">Tessere NFC programmate da noi, pronte all'uso</h2>

        <div class="grid md:grid-cols-3 gap-8">
          {[
            { icon: '💳', title: '1. Tessera Personalizzata', desc: 'Grafica professionale in pellicola adesiva intercambiabile. Cambi look senza cambiare tessera.', features: ['PVC resistente', 'Pellicola intercambiabile', 'QR di backup'] },
            { icon: '📱', title: '2. Programmazione Bitora', desc: 'Ci occupiamo di tutto: programmiamo il chip NFC con i tuoi link, contatti o pagina recensioni.', features: ['Link Google Recensioni', 'Sito web o landing', 'Contatti e social'] },
            { icon: '⭐', title: '3. Usa e Aggiorna', desc: 'Consegna ai clienti, esponi in locale. Aggiornamenti gratuiti quando vuoi cambiare destinazione.', features: ['Aggiornamenti illimitati', 'Supporto incluso', 'Nessun abbonamento'] }
          ].map((item, i) => (
            <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/10 hover:border-primary/40 transition-all reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 text-3xl">{item.icon}</div>
              <h3 class="text-xl font-bold text-white mb-4">{item.title}</h3>
              <p class="text-gray-400 mb-6">{item.desc}</p>
              <ul class="space-y-2">
                {item.features.map(f => (
                  <li class="flex items-center gap-2 text-sm text-gray-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Per chi -->
    <section class="py-20 md:py-24 px-6 md:px-12 lg:px-20 bg-white/[0.02] border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Per chi sono perfette</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">Settori in cui abbiamo più successo</h2>

        <div class="grid md:grid-cols-3 gap-8">
          {[
            { icon: '🍕', title: 'Ristoranti & Pizzerie', desc: 'Raccogli recensioni Google. Consegnale con lo scontrino o esponile sui tavoli: un tap e il cliente lascia la recensione.', badge: 'Ristorazione' },
            { icon: '🍸', title: 'Bar & Locali', desc: 'Menu digitali, eventi e promozioni. I clienti scansionano e vedono subito le novità del locale.', badge: 'Bar & Locali' },
            { icon: '💼', title: 'Professionisti', desc: 'Biglietto da visita del futuro. Un tap e il cliente salva contatti, visita il sito e prenota un appuntamento.', badge: 'Professionisti' }
          ].map((item, i) => (
            <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/10 hover:border-primary/40 transition-all reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <span class="text-xs font-medium text-primary uppercase tracking-wider">{item.badge}</span>
              <div class="text-3xl my-4">{item.icon}</div>
              <h3 class="text-xl font-bold text-white mb-4">{item.title}</h3>
              <p class="text-gray-400 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-16 p-8 rounded-2xl bg-white/[0.03] border border-white/10 text-center reveal-on-scroll">
          <p class="text-xl text-gray-300 italic mb-4">"Le tessere NFC per le recensioni hanno aumentato del 300% i feedback su Google. I clienti le adorano, è questione di un secondo."</p>
          <p class="text-primary font-medium">— Titolare pizzeria, Carmagnola</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-white/5">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Pronto per la tua tessera NFC?</h2>
        <p class="text-gray-400 mb-8">Contattaci per informazioni e un preventivo personalizzato. Ogni progetto è chiavi in mano.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contattaci?topic=nfc" class="btn-primary inline-flex items-center justify-center gap-2 min-w-[200px]">Richiedi informazioni</a>
          <a href="https://wa.me/393514979670?text=Ciao,%20vorrei%20informazioni%20sulle%20tessere%20NFC." class="btn-secondary inline-flex items-center justify-center gap-2 min-w-[200px]">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .reveal-on-scroll { opacity: 0; transform: translateY(30px); transition: all 1s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal-on-scroll.is-visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); } });
  }, { threshold: 0.1 });
  document.addEventListener('DOMContentLoaded', () => document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el)));
</script>

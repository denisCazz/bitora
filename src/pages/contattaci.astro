---
import Layout from '../layouts/Layout.astro';

const inviato = Astro.url.searchParams.get('inviato') === '1';
const topic = Astro.url.searchParams.get('topic') || '';
const argomentoPreselezionato = topic === 'ecommerce' ? 'e-commerce' : topic === 'nfc' ? 'nfc' : topic === 'sistemi' ? 'sistemi-aziendali' : topic === 'crm' ? 'gestionali-crm' : '';
---

<Layout title="Contattaci | Consulenza Gratuita | Bitora" 
       description="Richiedi una consulenza gratuita per sistemi aziendali, gestionali, siti web ed e-commerce. Sede in Piemonte, serviamo tutta Italia. Risposta in 24 ore.">
  <main class="bg-black text-white overflow-x-hidden selection:bg-primary/20 selection:text-white">
    
    <!-- Hero - stesso stile della home -->
    <section class="relative py-24 md:py-32 px-6 md:px-12 lg:px-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-black via-black to-black/95"></div>
      <div class="absolute top-1/3 -right-20 w-72 h-72 rounded-full bg-primary/10 blur-[100px] opacity-50"></div>
      
      <div class="relative z-10 max-w-4xl">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Contatti</p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
          Parliamone.
        </h1>
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl leading-relaxed">
          Hai un progetto in mente? Siamo qui per ascoltarti. Contattaci su WhatsApp o chiamaci.
        </p>
      </div>
    </section>

    <!-- Contact Options -->
    <section class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        
        <div class="grid md:grid-cols-2 gap-8 reveal-on-scroll">
          
          <!-- WhatsApp -->
          <a href="https://wa.me/393514979670" class="group relative overflow-hidden rounded-2xl bg-white/[0.03] border border-white/10 p-10 transition-all hover:scale-[1.02] hover:border-primary/40">
            <div class="absolute inset-0 bg-gradient-to-br from-green-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative z-10 flex flex-col items-center text-center space-y-6">
              <div class="w-20 h-20 bg-white/5 rounded-2xl flex items-center justify-center group-hover:bg-green-500/20 transition-colors duration-300">
                <svg class="w-10 h-10 text-white group-hover:text-green-400 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-white mb-2">WhatsApp</h3>
                <p class="text-gray-400 mb-4">Risposta immediata</p>
                <span class="inline-flex items-center gap-2 text-green-400 font-medium">
                  Chatta ora
                  <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </span>
              </div>
            </div>
          </a>

          <!-- Phone -->
          <a href="tel:+393514979670" class="group relative overflow-hidden rounded-2xl bg-white/[0.03] border border-white/10 p-10 transition-all hover:scale-[1.02] hover:border-primary/40">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative z-10 flex flex-col items-center text-center space-y-6">
              <div class="w-20 h-20 bg-white/5 rounded-2xl flex items-center justify-center group-hover:bg-primary/20 transition-colors duration-300">
                <svg class="w-10 h-10 text-white group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-white mb-2">Telefono</h3>
                <p class="text-gray-400 mb-4">Parla con noi</p>
                <span class="inline-flex items-center gap-2 text-primary font-medium">
                  +39 351 497 9670
                  <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </span>
              </div>
            </div>
          </a>

        </div>

        <!-- Form di contatto -->
        <div class="mt-24 reveal-on-scroll">
          {inviato && (
            <div class="mb-8 p-6 rounded-2xl bg-green-500/10 border border-green-500/30 text-green-400">
              <p class="font-medium">Messaggio inviato con successo. Ti risponderemo entro 24 ore.</p>
            </div>
          )}
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Scrivici</h2>
          <p class="text-gray-400 mb-8 max-w-xl">Compila il form e ti risponderemo entro 24 ore.</p>
          <form 
            id="contact-form"
            action="/api/contact"
            method="POST"
            class="space-y-6 max-w-2xl"
          >
            <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="nome" class="block text-sm font-medium text-gray-300 mb-2">Nome *</label>
                <input type="text" id="nome" name="nome" required
                  class="w-full px-4 py-3 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-gray-500 focus:border-white/30 focus:outline-none focus:ring-1 focus:ring-white/20 transition-colors"
                  placeholder="Il tuo nome"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-gray-500 focus:border-white/30 focus:outline-none focus:ring-1 focus:ring-white/20 transition-colors"
                  placeholder="tua@email.it"
                />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="telefono" class="block text-sm font-medium text-gray-300 mb-2">Telefono</label>
                <input type="tel" id="telefono" name="telefono"
                  class="w-full px-4 py-3 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-gray-500 focus:border-white/30 focus:outline-none focus:ring-1 focus:ring-white/20 transition-colors"
                  placeholder="+39 351 123 4567"
                />
              </div>
              <div>
                <label for="argomento" class="block text-sm font-medium text-gray-300 mb-2">Argomento</label>
                <select id="argomento" name="argomento"
                  class="w-full px-4 py-3 rounded-xl bg-white/[0.05] border border-white/10 text-white focus:border-white/30 focus:outline-none focus:ring-1 focus:ring-white/20 transition-colors"
                >
                  <option value="" class="bg-zinc-900 text-gray-400">Seleziona...</option>
                  <option value="sistemi-aziendali" class="bg-zinc-900" selected={argomentoPreselezionato === 'sistemi-aziendali'}>Sistemi aziendali</option>
                  <option value="gestionali-crm" class="bg-zinc-900" selected={argomentoPreselezionato === 'gestionali-crm'}>Gestionali & CRM</option>
                  <option value="siti-web" class="bg-zinc-900">Siti web</option>
                  <option value="e-commerce" class="bg-zinc-900" selected={argomentoPreselezionato === 'e-commerce'}>E-commerce</option>
                  <option value="grafica-social" class="bg-zinc-900">Grafica & Social</option>
                  <option value="nfc" class="bg-zinc-900" selected={argomentoPreselezionato === 'nfc'}>Tessere NFC</option>
                  <option value="altro" class="bg-zinc-900">Altro</option>
                </select>
              </div>
            </div>
            <div>
              <label for="messaggio" class="block text-sm font-medium text-gray-300 mb-2">Messaggio *</label>
              <textarea id="messaggio" name="messaggio" rows="5" required
                class="w-full px-4 py-3 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-gray-500 focus:border-white/30 focus:outline-none focus:ring-1 focus:ring-white/20 transition-colors resize-none"
                placeholder="Raccontaci il tuo progetto..."
              ></textarea>
            </div>
            <div id="form-error" class="hidden p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm"></div>
            <button type="submit" id="submit-btn" class="btn-primary px-8 py-4">
              Invia messaggio
            </button>
          </form>
        </div>

        <div class="mt-24 p-8 bg-white/[0.03] border border-white/10 rounded-2xl text-center reveal-on-scroll hover:border-primary/40 transition-all duration-300">
          <h3 class="text-xl font-bold text-white mb-4">Perché scegliere Bitora?</h3>
          <div class="grid md:grid-cols-3 gap-6 text-left md:text-center">
            <div class="flex flex-col items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <span class="text-gray-400">Risposta rapida</span>
            </div>
            <div class="flex flex-col items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <span class="text-gray-400">Consulenza gratuita</span>
            </div>
            <div class="flex flex-col items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
              <span class="text-gray-400">Soluzioni su misura</span>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.addEventListener('DOMContentLoaded', () => {
    const elements = document.querySelectorAll('.reveal-on-scroll');
    elements.forEach(el => observer.observe(el));

    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const errorEl = document.getElementById('form-error');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !errorEl) return;

      submitBtn.setAttribute('disabled', '');
      errorEl.classList.add('hidden');
      errorEl.textContent = '';

      const formData = new FormData(form as HTMLFormElement);

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();

        if (data.ok) {
          window.location.href = '/contattaci/?inviato=1';
          return;
        }
        errorEl.textContent = data.error || 'Errore durante l\'invio. Riprova.';
        errorEl.classList.remove('hidden');
      } catch {
        errorEl.textContent = 'Errore di connessione. Riprova.';
        errorEl.classList.remove('hidden');
      } finally {
        submitBtn.removeAttribute('disabled');
      }
    });
  });
</script>

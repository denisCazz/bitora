---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';
import StatCounter from '../components/StatCounter.astro';
import TrustBadges from '../components/TrustBadges.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';
import { caseStudies } from '../data/caseStudies';

const featured = caseStudies.filter(c => c.featured);
const others = caseStudies.filter(c => !c.featured);
---

<Layout
  title="Progetti & Portfolio | Casi studio Bitora in Piemonte e Italia"
  description="Progetti realizzati da Bitora: siti web, e-commerce, NFC, sistemi aziendali. Risultati misurabili, clienti reali, foto e dettagli di ogni caso studio."
  image="https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=1600&q=80"
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <VideoHero
      variant="background"
      eyebrow="Portfolio"
      title="Lavori che"
      highlight="parlano da soli."
      description="Non solo pixel: strumenti di business reali. Foto, metriche e storie dei clienti che ci hanno scelto."
      primaryCta={{ label: 'Inizia il tuo progetto', href: '/contattaci' }}
      secondaryCta={{ label: 'Chi siamo', href: '/chi-siamo' }}
      posterSrc="https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=1600&q=80"
      videoSrc="https://videos.pexels.com/video-files/3129671/3129671-uhd_2560_1440_30fps.mp4"
      videoLabel="Showcase progetti Bitora"
    />

    <!-- Stats -->
    <section
      class="py-16 md:py-20 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <StatCounter
          items={[
            { label: 'Progetti', value: '25+', number: 25, suffix: '+' },
            { label: 'Soddisfazione', value: '100%', number: 100, suffix: '%' },
            { label: 'Lead medi', value: '+30%', number: 30, suffix: '%' },
            { label: 'Setup iniziale', value: '48h', number: 48, suffix: 'h' },
          ]}
        />
      </div>
    </section>

    <!-- Featured -->
    {
      featured.length > 0 && (
        <section class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5">
          <div class="max-w-6xl mx-auto">
            <p class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3">
              In evidenza
            </p>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white mb-12">
              Casi studio principali.
            </h2>

            <div class="grid lg:grid-cols-2 gap-8">
              {featured.map((p, i) => (
                <a
                  href={`/progetti/${p.slug}`}
                  class="group block rounded-3xl overflow-hidden border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel hover-lift reveal-on-scroll"
                  style={`transition-delay:${i * 80}ms`}
                >
                  <div class="relative media-frame">
                    <img
                      src={p.imageUrl}
                      alt={p.title}
                      class="w-full h-full object-cover aspect-[16/10] group-hover:scale-[1.03] transition-transform duration-500"
                      loading="lazy"
                    />
                    {p.isWip && (
                      <div class="absolute top-4 right-4 hero-panel rounded-full px-3 py-1 text-xs font-semibold text-white">
                        In corso
                      </div>
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-transparent" />
                    <div class="absolute bottom-5 left-5 right-5">
                      <div class="hero-panel rounded-2xl px-5 py-4">
                        <p class="text-xs font-semibold tracking-widest uppercase text-white/80">
                          {p.category} · {p.location}
                        </p>
                        <p class="text-white font-bold text-xl mt-1">{p.title}</p>
                      </div>
                    </div>
                  </div>
                  <div class="p-6">
                    <p class="text-slate-600 dark:text-slate-300 line-clamp-2 mb-4">{p.problema}</p>
                    <div class="flex flex-wrap gap-2">
                      {p.metricsPreview.map(m => (
                        <span class="text-xs font-medium border border-gray-200 dark:border-white/10 px-3 py-1 rounded-full bg-gray-50 dark:bg-white/[0.04] text-slate-700 dark:text-slate-300">
                          {m}
                        </span>
                      ))}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- All projects -->
    {
      others.length > 0 && (
        <section class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]">
          <div class="max-w-6xl mx-auto">
            <p class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3">
              Tutti i progetti
            </p>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white mb-12">
              Altri lavori realizzati.
            </h2>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {others.map((p, i) => (
                <a
                  href={`/progetti/${p.slug}`}
                  class="group block rounded-3xl overflow-hidden border border-gray-200 dark:border-white/10 bg-white dark:bg-white/[0.03] hover-lift reveal-on-scroll"
                  style={`transition-delay:${i * 60}ms`}
                >
                  <div class="relative">
                    <img
                      src={p.imageUrl}
                      alt={p.title}
                      class="w-full h-full object-cover aspect-[4/3] group-hover:scale-[1.03] transition-transform duration-500"
                      loading="lazy"
                    />
                    {p.isWip && (
                      <div class="absolute top-3 right-3 hero-panel rounded-full px-3 py-1 text-[10px] font-semibold text-white tracking-widest uppercase">
                        In corso
                      </div>
                    )}
                  </div>
                  <div class="p-5">
                    <div class="flex items-center justify-between gap-2 text-xs text-slate-500 uppercase tracking-wider mb-2">
                      <span>{p.category}</span>
                      <span>{p.location}</span>
                    </div>
                    <h3 class="text-lg font-extrabold tracking-tight text-slate-950 dark:text-white group-hover:text-[color:var(--brand-cta)] transition-colors">
                      {p.title}
                    </h3>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-300 line-clamp-2">
                      {p.problema}
                    </p>
                    <div class="mt-3 flex flex-wrap gap-1.5">
                      {p.metricsPreview.slice(0, 2).map(m => (
                        <span class="text-[11px] text-slate-500 border border-gray-200 dark:border-white/10 px-2 py-0.5 rounded-full">
                          {m}
                        </span>
                      ))}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Trust -->
    <section class="py-20 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto">
        <TrustBadges />
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-3xl mx-auto text-center">
        <h2
          class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-950 dark:text-white"
        >
          Il prossimo caso studio<br />potrebbe essere il tuo.
        </h2>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
          Raccontaci la sfida. Costruiamo la soluzione su misura.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contattaci" class="btn-primary min-w-[220px] shine-on-hover"
            >Inizia il progetto</a
          >
          <a href="/chi-siamo" class="btn-secondary min-w-[220px]">Conosci Bitora</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<BreadcrumbListSchema
  crumbs={[
    { name: 'Home', item: 'https://www.bitora.it/' },
    { name: 'Progetti', item: 'https://www.bitora.it/lavori/' },
  ]}
/>

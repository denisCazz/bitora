---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { caseStudies } from '../data/caseStudies';

const projects = caseStudies.filter(c => !c.isWip);
---

<Layout
  title="Lavori e prototipi | Portfolio Bitora"
  description="Progetti realizzati e prototipi software Bitora: siti web, e-commerce e piattaforme dimostrative per assistenza tecnica. Sede in Piemonte."
>
  <main class="bg-black text-white overflow-x-hidden">

    <!-- HERO -->
    <section class="pt-40 pb-20 px-8 md:px-16 lg:px-24 border-b border-white/[0.06]">
      <div class="max-w-7xl mx-auto">
        <p class="text-xs font-semibold tracking-[0.25em] text-white/40 uppercase mb-7" data-reveal>Portfolio</p>
        <h1 class="text-[clamp(3.5rem,10vw,9rem)] font-bold leading-[0.95] tracking-tight mb-14" data-reveal>
          I nostri<br />lavori.
        </h1>
        <div class="flex flex-wrap gap-12 md:gap-20 border-t border-white/[0.08] pt-10" data-reveal>
          <div>
            <p class="text-4xl font-bold mb-1">{projects.length}</p>
            <p class="text-xs uppercase tracking-[0.2em] text-white/35">Progetti</p>
          </div>
          <div>
            <p class="text-4xl font-bold mb-1">100%</p>
            <p class="text-xs uppercase tracking-[0.2em] text-white/35">Su misura</p>
          </div>
          <div>
            <p class="text-4xl font-bold mb-1">0</p>
            <p class="text-xs uppercase tracking-[0.2em] text-white/35">Template usati</p>
          </div>
          <div>
            <p class="text-4xl font-bold mb-1">Demo</p>
            <p class="text-xs uppercase tracking-[0.2em] text-white/35">Disponibile</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROTOTIPI -->
    <section class="border-b border-white/[0.06] bg-white/[0.02]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 py-20 md:py-28" data-reveal>
        <p class="text-xs font-semibold tracking-[0.25em] text-white/40 uppercase mb-6">Prototipi e soluzioni dimostrative</p>
        <h2 class="text-3xl md:text-4xl lg:text-[2.85rem] font-bold tracking-tight leading-[1.07] mb-4 max-w-3xl">
          Piattaforma per la gestione dell’assistenza tecnica
        </h2>
        <p class="text-sm font-medium text-white/40 mb-6">Prototipo software Bitora · Demo disponibile</p>
        <p class="text-base md:text-[1.05rem] text-white/58 leading-relaxed mb-8 max-w-[56ch]">
          Prototipo modulare per la gestione di pratiche, assegnazioni, centri assistenza, tecnici e rapportini digitali. La piattaforma è pensata per essere configurata sui processi delle aziende che gestiscono interventi sul territorio.
        </p>
        <div class="flex flex-wrap gap-2 mb-9">
          {[
            'Gestione pratiche',
            'Stati di lavorazione',
            'Assegnazione CAT',
            'Assegnazione manutentori',
            'Rapportini digitali',
            'Firme e fotografie',
            'Ricambi e PDF',
            'Dashboard',
          ].map((m) => (
            <span class="text-xs font-semibold text-white/65 bg-white/[0.06] border border-white/10 rounded-full px-3.5 py-1.5 tracking-wide">
              {m}
            </span>
          ))}
        </div>
        <a
          href="/richiedi-demo"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-sm font-semibold rounded hover:bg-white/88 transition-colors"
        >
          Richiedi una demo
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- PROJECTS -->
    {projects.map((p, i) => (
      <article class="border-b border-white/[0.06]">
        <div
          class={
            'max-w-7xl mx-auto px-8 md:px-16 lg:px-24 py-20 md:py-28 flex flex-col gap-12 md:gap-20 items-center ' +
            (i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse')
          }
          data-reveal
        >
          <!-- image -->
          <div class="w-full md:w-[52%] flex-shrink-0 relative group rounded-2xl overflow-hidden bg-white/[0.03]">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={p.imageUrl}
                alt={p.title}
                class="w-full h-full object-cover object-center transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            <span class="absolute top-4 left-4 text-xs font-semibold tracking-wider bg-black/65 backdrop-blur-sm text-white/60 border border-white/10 rounded-full px-3 py-1.5">
              {p.category}
            </span>
          </div>

          <!-- text -->
          <div class="flex-1 min-w-0 relative">
            <span
              aria-hidden="true"
              class="absolute -top-6 right-0 text-[clamp(5rem,12vw,10rem)] font-bold leading-none text-white/[0.04] select-none pointer-events-none tabular-nums"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="relative">
              <p class="text-xs font-semibold tracking-[0.2em] text-white/35 uppercase mb-4">{p.location}</p>
              <h2 class="text-3xl md:text-4xl lg:text-[2.85rem] font-bold tracking-tight leading-[1.07] mb-3">
                {p.title}
              </h2>
              <p class="text-sm font-medium text-white/40 mb-7">{p.subtitle}</p>
              <p class="text-base md:text-[1.05rem] text-white/58 leading-relaxed mb-8 max-w-[38ch]">
                {p.problema.slice(0, 210)}{p.problema.length > 210 ? '\u2026' : ''}
              </p>
              <div class="flex flex-wrap gap-2 mb-9">
                {p.metricsPreview.map(m => (
                  <span class="text-xs font-semibold text-white/65 bg-white/[0.06] border border-white/10 rounded-full px-3.5 py-1.5 tracking-wide">
                    {m}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap items-center gap-4">
                {p.siteUrl && p.siteUrl !== '#' && (
                  <a
                    href={p.siteUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-sm font-semibold rounded hover:bg-white/88 transition-colors"
                  >
                    Visita il sito
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                  </a>
                )}
                <a href="/contattaci" class="text-sm font-medium text-white/38 hover:text-white transition-colors underline underline-offset-4 decoration-white/20 hover:decoration-white/60">
                  Progetto simile?
                </a>
              </div>
            </div>
          </div>

        </div>
      </article>
    ))}

    <!-- CTA -->
    <section class="py-36 px-8 md:px-16 lg:px-24 text-center">
      <p class="text-xs font-semibold tracking-[0.25em] text-white/30 uppercase mb-8" data-reveal>Prossimo progetto</p>
      <h2 class="text-[clamp(2.5rem,7vw,5.5rem)] font-bold leading-[1.03] tracking-tight mb-6 max-w-2xl mx-auto" data-reveal>
        Il tuo nome<br />potrebbe essere qui.
      </h2>
      <p class="text-base md:text-lg text-white/50 mb-12 max-w-sm mx-auto leading-relaxed" data-reveal>
        Consulenza gratuita, risposta entro 24 ore.<br />Nessun impegno.
      </p>
      <div class="flex flex-wrap gap-4 justify-center" data-reveal>
        <a href="/contattaci" class="px-7 py-3.5 bg-white text-black rounded font-semibold text-sm hover:bg-white/90 transition-colors">Inizia il tuo progetto</a>
        <a href="/servizi" class="px-7 py-3.5 border border-white/25 text-white rounded font-semibold text-sm hover:border-white/60 hover:bg-white/[0.06] transition-all">Scopri i servizi</a>
      </div>
    </section>

  </main>
</Layout>

<script>
  const _els = document.querySelectorAll('[data-reveal]');
  const _obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('rv'); _obs.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  _els.forEach(el => _obs.observe(el));
</script>

<style>
  [data-reveal] { opacity:0; transform:translateY(38px); transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1); }
  [data-reveal].rv { opacity:1; transform:translateY(0); }
  @media (prefers-reduced-motion:reduce) { [data-reveal] { opacity:1!important;transform:none!important;transition:none!important; } }
</style>
---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import QRCodeGenerator from '../components/tools/QRCodeGenerator';
import PasswordGenerator from '../components/tools/PasswordGenerator';
---

<Layout
  title="Free Tools Online | Generatore QR Code e Password | Bitora"
  description="Strumenti gratuiti online: generatore di QR code personalizzabili, generatore di password sicure, calcolatore ROI. Nessuna registrazione richiesta."
>
  <main class="bg-black text-white overflow-x-hidden">

    <!-- HERO -->
    <section class="relative min-h-[75vh] flex flex-col justify-center items-center text-center px-8 border-b border-white/[0.06]">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full bg-white/[0.025] blur-[100px]"></div>
      </div>
      <div class="relative z-10 max-w-3xl mx-auto" data-reveal>
        <p class="text-xs font-semibold tracking-[0.25em] text-white/40 uppercase mb-6">Strumenti gratuiti &middot; Nessuna registrazione</p>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tight mb-6 leading-[1.02]">Free Tools.</h1>
        <p class="text-base md:text-xl text-white/55 max-w-lg mx-auto leading-relaxed mb-12">
          Tutto funziona nel tuo browser.<br class="hidden md:block" />Nessun dato inviato ai server.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="#qr-generator" class="px-6 py-3 bg-white text-black rounded font-semibold text-sm hover:bg-white/90 transition-colors">QR Code</a>
          <a href="#password-generator" class="px-6 py-3 border border-white/25 text-white rounded font-semibold text-sm hover:border-white/60 hover:bg-white/[0.06] transition-all">Password</a>
          <a href="/tools/calcolatore-roi-gestionale" class="px-6 py-3 border border-white/25 text-white rounded font-semibold text-sm hover:border-white/60 hover:bg-white/[0.06] transition-all">Calcolatore ROI</a>
        </div>
      </div>
    </section>

    <!-- ROI CALLOUT -->
    <section class="py-24 px-8 md:px-16 lg:px-24 border-b border-white/[0.06]">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12 md:gap-20" data-reveal>
        <div class="flex-1">
          <p class="text-xs font-semibold tracking-[0.25em] text-white/40 uppercase mb-5">Calcolatore ROI</p>
          <h2 class="text-4xl md:text-5xl font-bold leading-[1.04] tracking-tight mb-5">
            Quanto vale<br />digitalizzare?
          </h2>
          <p class="text-base md:text-lg text-white/55 mb-8 leading-relaxed max-w-md">
            Inserisci i tuoi dati operativi e scopri il ritorno economico mensile e annuale della digitalizzazione.
          </p>
          <a href="/tools/calcolatore-roi-gestionale" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black rounded font-semibold text-sm hover:bg-white/90 transition-colors">
            Apri il calcolatore &rarr;
          </a>
        </div>
        <div class="flex-shrink-0 grid grid-cols-2 gap-3">
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-8 py-6 text-center">
            <p class="text-3xl font-bold mb-1">10&times;</p>
            <p class="text-xs text-white/40 uppercase tracking-wider">ritorno medio</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-8 py-6 text-center">
            <p class="text-3xl font-bold mb-1">&lt;6m</p>
            <p class="text-xs text-white/40 uppercase tracking-wider">payback period</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-8 py-6 text-center">
            <p class="text-3xl font-bold mb-1">40%</p>
            <p class="text-xs text-white/40 uppercase tracking-wider">ore risparmiate</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-8 py-6 text-center">
            <p class="text-3xl font-bold mb-1">0 &euro;</p>
            <p class="text-xs text-white/40 uppercase tracking-wider">costo del tool</p>
          </div>
        </div>
      </div>
    </section>

    <!-- QR CODE -->
    <section id="qr-generator" class="py-24 px-8 md:px-16 lg:px-24 border-b border-white/[0.06] scroll-mt-24">
      <div class="max-w-7xl mx-auto">
        <div class="mb-14" data-reveal>
          <p class="text-xs font-semibold tracking-[0.25em] text-white/40 uppercase mb-4">Strumento 01</p>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Generatore QR Code</h2>
          <p class="text-base md:text-lg text-white/55 max-w-2xl leading-relaxed">
            Colori personalizzati, logo al centro e stili diversi. Esporta in PNG trasparente o JPG.
          </p>
        </div>
        <div data-reveal>
          <QRCodeGenerator client:load />
        </div>
      </div>
    </section>

    <!-- PASSWORD -->
    <section id="password-generator" class="py-24 px-8 md:px-16 lg:px-24 border-b border-white/[0.06] scroll-mt-24">
      <div class="max-w-7xl mx-auto">
        <div class="mb-14" data-reveal>
          <p class="text-xs font-semibold tracking-[0.25em] text-white/40 uppercase mb-4">Strumento 02</p>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Generatore Password</h2>
          <p class="text-base md:text-lg text-white/55 max-w-2xl leading-relaxed">
            Sicure e personalizzate. Scegli lunghezza e tipi di caratteri. Tutto localmente nel tuo browser.
          </p>
        </div>
        <div data-reveal>
          <PasswordGenerator client:load />
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-28 px-8 md:px-16 lg:px-24 text-center">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-5 max-w-xl mx-auto" data-reveal>
        Ti servono soluzioni<br />piu avanzate?
      </h2>
      <p class="text-base md:text-lg text-white/55 mb-10 max-w-md mx-auto" data-reveal>
        Siti web, e-commerce, tessere NFC e sistemi aziendali su misura.
      </p>
      <div class="flex flex-wrap gap-4 justify-center" data-reveal>
        <a href="/contattaci" class="px-7 py-3.5 bg-white text-black rounded font-semibold text-sm hover:bg-white/90 transition-colors">Contattaci</a>
        <a href="/servizi" class="px-7 py-3.5 border border-white/25 text-white rounded font-semibold text-sm hover:border-white/60 hover:bg-white/[0.06] transition-all">Scopri i servizi</a>
      </div>
    </section>

  </main>
</Layout>

<script>
  const _els = document.querySelectorAll('[data-reveal]');
  const _obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); _obs.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  _els.forEach(el => _obs.observe(el));
</script>

<style>
  [data-reveal] {
    opacity:0; transform:translateY(40px);
    transition: opacity .8s cubic-bezier(0.16,1,0.3,1), transform .8s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].is-visible { opacity:1; transform:translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { opacity:1!important; transform:none!important; transition:none!important; }
  }
</style>
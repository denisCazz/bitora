---
import Layout from '../layouts/Layout.astro';
import QRCodeGenerator from '../components/tools/QRCodeGenerator';
import PasswordGenerator from '../components/tools/PasswordGenerator';
---

<Layout
  title="Free Tools Online | Generatore QR Code e Password | Bitora"
  description="Strumenti gratuiti online: generatore di QR code personalizzabili con logo e colori, generatore di password sicure. Nessuna registrazione richiesta."
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <!-- Hero Section -->
    <section
      class="relative min-h-[60vh] flex flex-col justify-center items-center text-center px-4 overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-gray-200/40 dark:from-gray-800/20 via-white dark:via-black to-white dark:to-black opacity-50"
      >
      </div>

      <div
        class="relative z-10 max-w-5xl mx-auto space-y-8 opacity-0 animate-fade-in-up"
        style="animation-delay: 0.2s; animation-fill-mode: forwards;"
      >
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-sm text-gray-600 dark:text-gray-300 mb-4"
        >
          <span>🛠️</span> Strumenti gratuiti — nessuna registrazione
        </div>
        <h1
          class="text-5xl md:text-8xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-b from-gray-900 dark:from-white to-gray-400 dark:to-white/60"
        >
          Free Tools.
        </h1>
        <p
          class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 font-light max-w-3xl mx-auto leading-relaxed"
        >
          Strumenti utili per il tuo business, <strong class="text-gray-900 dark:text-white"
            >gratuiti e senza limiti</strong
          >. Tutto funziona nel tuo browser — nessun dato viene inviato ai nostri server.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
          <a
            href="#qr-generator"
            class="px-8 py-4 bg-gray-900 dark:bg-white text-white dark:text-black rounded-full font-bold text-lg hover:scale-105 transition-transform"
          >
            Generatore QR Code
          </a>
          <a
            href="#password-generator"
            class="px-8 py-4 border border-gray-200 dark:border-white/20 text-gray-900 dark:text-white rounded-full font-bold text-lg hover:bg-gray-100 dark:hover:bg-white/10 transition-all"
          >
            Generatore Password
          </a>
          <a
            href="/tools/calcolatore-roi-gestionale"
            class="px-8 py-4 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-full font-bold text-lg hover:bg-gray-100 dark:hover:bg-white/10 transition-all"
          >
            Calcolatore ROI Gestionale
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 px-6 md:px-12 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-4xl mx-auto text-center reveal-on-scroll">
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 dark:bg-white/10 border border-gray-200 dark:border-white/20 text-sm text-gray-600 dark:text-gray-300 mb-6"
        >
          <span>📊</span> Nuovo strumento
        </div>
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          Calcolatore ROI per Gestionale Professionale
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-3xl mx-auto">
          Inserisci numero di rapportini, operatori, tempi medi e costi per stimare il ritorno
          economico mensile e annuale della digitalizzazione operativa.
        </p>
        <a
          href="/tools/calcolatore-roi-gestionale"
          class="inline-flex items-center justify-center px-8 py-4 bg-gray-900 dark:bg-white text-white dark:text-black rounded-full font-bold text-lg hover:scale-105 transition-transform"
        >
          Apri il calcolatore ROI
        </a>
      </div>
    </section>

    <!-- QR Code Generator -->
    <section
      id="qr-generator"
      class="py-24 px-6 md:px-12 border-t border-gray-200 dark:border-white/5 scroll-mt-24"
    >
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16 reveal-on-scroll">
          <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 dark:bg-white/10 border border-gray-200 dark:border-white/20 text-sm text-gray-600 dark:text-gray-300 mb-6"
          >
            <span>📱</span> QR Code personalizzato
          </div>
          <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
            Generatore QR Code
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
            Crea QR code unici con <strong class="text-gray-900 dark:text-white"
              >colori personalizzati, logo al centro e stili diversi</strong
            >. Esporta in PNG trasparente o JPG con sfondo.
          </p>
        </div>

        <div class="reveal-on-scroll">
          <QRCodeGenerator client:load />
        </div>
      </div>
    </section>

    <!-- Password Generator -->
    <section
      id="password-generator"
      class="py-24 px-6 md:px-12 border-t border-gray-200 dark:border-white/5 scroll-mt-24"
    >
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16 reveal-on-scroll">
          <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-sm text-green-700 dark:text-green-300 mb-6"
          >
            <span>🔐</span> Sicurezza
          </div>
          <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
            Generatore Password
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
            Genera password <strong class="text-gray-900 dark:text-white"
              >sicure e personalizzate</strong
            >. Scegli lunghezza, tipi di caratteri ed escludi quelli che non vuoi. Tutto avviene
            localmente nel tuo browser.
          </p>
        </div>

        <div class="reveal-on-scroll">
          <PasswordGenerator client:load />
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-24 px-6 md:px-12 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-4xl mx-auto text-center reveal-on-scroll">
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          Ti servono soluzioni più avanzate?
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto">
          Bitora crea siti web, e-commerce e soluzioni NFC su misura per aziende in Piemonte.
          Raccontaci il tuo progetto.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contattaci"
            class="px-8 py-4 bg-gray-900 dark:bg-white text-white dark:text-black rounded-full font-bold text-lg hover:scale-105 transition-transform"
          >
            Contattaci
          </a>
          <a
            href="/soluzioni"
            class="px-8 py-4 border border-gray-200 dark:border-white/20 text-gray-900 dark:text-white rounded-full font-bold text-lg hover:bg-gray-100 dark:hover:bg-white/10 transition-all"
          >
            Scopri le soluzioni
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

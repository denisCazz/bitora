---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Soluzioni Digitali per Turismo e Ospitalità | Bitora"
  description="Siti web multilingua, integrazione booking, SEO locale e Google Maps per strutture turistiche in Piemonte. Aumenta le prenotazioni dirette e riduci le commissioni OTA."
>
  <main
    class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden selection:bg-gray-200 dark:selection:bg-white/20 selection:text-gray-900 dark:selection:text-white"
  >
    <!-- Hero -->
    <section class="relative py-24 md:py-32 px-6 md:px-12 lg:px-20 overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-white via-white to-gray-50 dark:from-black dark:via-black dark:to-black/95"
      >
      </div>
      <div
        class="absolute top-1/3 -right-20 w-72 h-72 rounded-full bg-gray-100 dark:bg-white/10 blur-[100px] opacity-50"
      >
      </div>

      <div class="relative z-10 max-w-4xl">
        <a
          href="/settori"
          class="inline-flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-6"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path></svg
          >
          Tutti i settori
        </a>
        <p
          class="text-sm font-medium tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-4"
        >
          Settore Turismo
        </p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
          Soluzioni digitali per<br />
          <span class="text-gray-900 dark:text-white">turismo e ospitalità.</span>
        </h1>
        <p
          class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed mb-8"
        >
          Siti multilingua, booking diretto, SEO locale e Google Maps. Riduci la dipendenza dalle
          OTA e aumenta le prenotazioni dirette della tua struttura.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contattaci?topic=turismo"
            class="btn-primary group min-w-[200px] flex items-center justify-center gap-2"
          >
            Parla con noi
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
          <a
            href="https://wa.me/393514979670?text=Ciao%2C%20vorrei%20informazioni%20su%20soluzioni%20per%20il%20turismo.%20Ho%20visitato%20il%20sito%20bitora.it"
            class="btn-secondary min-w-[200px] flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- Pain Points -->
    <section
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal-on-scroll">
          <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
            Le sfide del settore turistico
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
            Problemi concreti che affrontano hotel, B&B, agriturismi e strutture ricettive ogni
            giorno.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            [
              {
                icon: '🔍',
                title: 'Visibilità online',
                desc: 'I turisti cercano su Google. Se non compari nei primi risultati, scelgono un concorrente.',
              },
              {
                icon: '📅',
                title: 'Prenotazioni dirette',
                desc: 'Dipendere da Booking.com costa il 15-20% a prenotazione. Servono canali diretti.',
              },
              {
                icon: '⭐',
                title: 'Recensioni',
                desc: 'Le recensioni guidano le scelte. Servono strategie per raccoglierle in modo costante.',
              },
              {
                icon: '📊',
                title: 'Stagionalità',
                desc: "Bassa stagione vuota? Servono strategie digitali per destagionalizzare l'offerta.",
              },
            ].map((item, i) => (
              <div
                class="p-6 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/30 transition-all reveal-on-scroll"
                style={`transition-delay: ${i * 80}ms`}
              >
                <span class="text-3xl mb-4 block">{item.icon}</span>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">{item.title}</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm">{item.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Soluzioni -->
    <section
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 bg-gray-50 dark:bg-white/[0.02] border-t border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal-on-scroll">
          <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
            Le nostre soluzioni per il turismo
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
            Strumenti digitali pensati per strutture ricettive che vogliono crescere.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div
            class="p-8 rounded-2xl bg-white dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 reveal-on-scroll hover:border-gray-400 dark:hover:border-white/30 transition-all"
          >
            <div
              class="w-14 h-14 bg-gray-100 dark:bg-white/10 rounded-2xl flex items-center justify-center mb-6"
            >
              <span class="text-2xl">🌍</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
              Siti web multilingua
            </h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              Un sito professionale in italiano, inglese, francese, tedesco — quante lingue servono.
              Contenuti ottimizzati per ogni mercato, non semplici traduzioni automatiche.
            </p>
            <ul class="space-y-3 text-gray-500 text-sm">
              <li class="flex items-center gap-2">✓ Traduzione professionale per ogni lingua</li>
              <li class="flex items-center gap-2">✓ SEO multilingua con hreflang</li>
              <li class="flex items-center gap-2">✓ Galleria fotografica immersiva</li>
            </ul>
          </div>

          <div
            class="p-8 rounded-2xl bg-white dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 reveal-on-scroll hover:border-gray-400 dark:hover:border-white/30 transition-all"
            style="transition-delay: 100ms"
          >
            <div
              class="w-14 h-14 bg-green-500/20 rounded-2xl flex items-center justify-center mb-6"
            >
              <span class="text-2xl">📅</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
              Integrazione booking
            </h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              Sistema di prenotazione diretta integrato nel tuo sito. I clienti prenotano senza
              passare dalle OTA, tu risparmi sulle commissioni e hai il contatto diretto.
            </p>
            <ul class="space-y-3 text-gray-500 text-sm">
              <li class="flex items-center gap-2">✓ Calendario disponibilità in tempo reale</li>
              <li class="flex items-center gap-2">✓ Pagamento online sicuro</li>
              <li class="flex items-center gap-2">✓ Sincronizzazione con Booking/Airbnb</li>
            </ul>
          </div>

          <div
            class="p-8 rounded-2xl bg-white dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 reveal-on-scroll hover:border-gray-400 dark:hover:border-white/30 transition-all"
            style="transition-delay: 200ms"
          >
            <div
              class="w-14 h-14 bg-gray-100 dark:bg-white/10 rounded-2xl flex items-center justify-center mb-6"
            >
              <span class="text-2xl">📍</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
              SEO locale e Google Maps
            </h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              Ottimizziamo la tua presenza su Google Maps e nelle ricerche locali. "Hotel Langhe",
              "B&B Monferrato", "agriturismo Piemonte" — ti facciamo trovare dai turisti.
            </p>
            <ul class="space-y-3 text-gray-500 text-sm">
              <li class="flex items-center gap-2">✓ Google Business ottimizzato</li>
              <li class="flex items-center gap-2">✓ Schema markup per strutture ricettive</li>
              <li class="flex items-center gap-2">✓ Keyword turistiche territoriali</li>
            </ul>
          </div>

          <div
            class="p-8 rounded-2xl bg-white dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 reveal-on-scroll hover:border-gray-400 dark:hover:border-white/30 transition-all"
            style="transition-delay: 300ms"
          >
            <div
              class="w-14 h-14 bg-yellow-500/20 rounded-2xl flex items-center justify-center mb-6"
            >
              <span class="text-2xl">💳</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
              Tessere NFC per recensioni
            </h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              Una tessera NFC nella camera o alla reception. L'ospite avvicina il telefono e lascia
              una recensione Google in 10 secondi. Più recensioni positive, più prenotazioni.
            </p>
            <ul class="space-y-3 text-gray-500 text-sm">
              <li class="flex items-center gap-2">✓ Un tap = recensione Google</li>
              <li class="flex items-center gap-2">✓ Personalizzabile con il tuo brand</li>
              <li class="flex items-center gap-2">✓ Ideale per check-out</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Numeri -->
    <section
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal-on-scroll">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Perché investire nel digitale turistico
          </h2>
          <p class="text-gray-600 dark:text-gray-400 text-lg">Dati che parlano chiaro.</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {
            [
              { value: '87%', label: 'dei turisti cerca online prima di prenotare' },
              { value: '15-20%', label: 'commissione media delle OTA per prenotazione' },
              { value: '4.0+', label: 'stelle minime per essere considerati dai turisti' },
              { value: '3x', label: 'più prenotazioni con un sito multilingua ottimizzato' },
            ].map((stat, i) => (
              <div class="text-center reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
                <p class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">
                  {stat.value}
                </p>
                <p class="text-sm text-gray-600 dark:text-gray-400">{stat.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 bg-gray-50 dark:bg-white/[0.02] border-t border-gray-200 dark:border-white/5"
    >
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16 reveal-on-scroll">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Domande frequenti
          </h2>
          <p class="text-gray-600 dark:text-gray-400">
            Le risposte ai dubbi più comuni nel settore turistico.
          </p>
        </div>

        <div class="space-y-6">
          {
            [
              {
                q: 'Posso sincronizzare il booking del sito con Booking.com e Airbnb?',
                a: 'Sì, integriamo il tuo sistema di prenotazione diretta con i principali channel manager. Le disponibilità si aggiornano automaticamente su tutti i canali, evitando overbooking.',
              },
              {
                q: 'Il sito sarà tradotto in più lingue?',
                a: 'Assolutamente. Realizziamo siti multilingua con traduzioni professionali (non automatiche) e SEO ottimizzato per ogni lingua. Italiano, inglese, francese, tedesco — quante ne servono.',
              },
              {
                q: 'Come mi aiutate a ridurre la dipendenza dalle OTA?',
                a: "Con un sito ottimizzato per le ricerche dirette, un sistema di booking integrato e campagne SEO mirate. L'obiettivo è portare i turisti a prenotare direttamente dal tuo sito, risparmiando sulle commissioni.",
              },
              {
                q: 'Quanto tempo serve per realizzare il sito?',
                a: 'Un sito turistico multilingua con booking integrato richiede generalmente 3-5 settimane. Ti coinvolgiamo in ogni fase con anteprime e revisioni.',
              },
            ].map((item, i) => (
              <details
                class="group p-6 rounded-2xl bg-white dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 reveal-on-scroll"
                style={`transition-delay: ${i * 80}ms`}
              >
                <summary class="flex items-center justify-between cursor-pointer list-none">
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white pr-4">{item.q}</h3>
                  <svg
                    class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                </summary>
                <p class="text-gray-600 dark:text-gray-400 mt-4 leading-relaxed">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          Fai crescere la tua struttura turistica.
        </h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8">
          Consulenza gratuita. Raccontaci della tua struttura e ti proponiamo la strategia digitale
          giusta.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contattaci?topic=turismo"
            class="btn-primary inline-flex items-center justify-center gap-2 min-w-[200px]"
            >Richiedi consulenza gratuita</a
          >
          <a
            href="https://wa.me/393514979670?text=Ciao%2C%20vorrei%20informazioni%20su%20soluzioni%20per%20il%20turismo.%20Ho%20visitato%20il%20sito%20bitora.it"
            class="btn-secondary inline-flex items-center justify-center gap-2 min-w-[200px]"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Soluzioni Digitali per Turismo e Ospitalità",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Bitora",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Carmagnola",
        "addressRegion": "Piemonte",
        "addressCountry": "IT"
      }
    },
    "areaServed": ["Carmagnola", "Torino", "Langhe", "Monferrato", "Piemonte", "Italia"],
    "serviceType": "Digital Solutions for Tourism",
    "description": "Siti web multilingua, integrazione booking, SEO locale e Google Maps per strutture turistiche"
  }
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  });
</script>

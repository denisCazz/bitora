---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import ProductUi from '../components/product/ProductUi.astro';
import FAQ from '../components/FAQ.astro';
import FAQPageSchema from '../components/schema/FAQPage.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';

const faqItems = [
  {
    question: 'Cosa include l’ecosistema Bitora?',
    answer:
      'Due applicazioni collegate: Gestione Pratiche e Ticketing (richieste, CAT, stati) e Gestione Rapportini (intervento sul campo, firme, PDF). Possono lavorare insieme o essere attivate separatamente.',
  },
  {
    question: 'Qual è la differenza tra pratica e rapportino?',
    answer:
      'La pratica è l’intera richiesta di assistenza, dall’apertura alla chiusura. Il rapportino è il documento dell’intervento eseguito dal tecnico: attività, ricambi, foto e firme.',
  },
  {
    question: 'Per quali aziende è pensata?',
    answer:
      'Per aziende di assistenza tecnica e manutenzione con tecnici sul territorio: manutentori, impiantisti, reti di installatori, centri assistenza e produttori con post-vendita.',
  },
  {
    question: 'Come funziona il modello commerciale?',
    answer:
      'Attivazione iniziale (configurazione, personalizzazioni, formazione) più canone mensile o annuale in base a utenti, tecnici o centri assistenza. I moduli aggiuntivi si attivano quando servono.',
  },
  {
    question: 'Posso vedere una demo?',
    answer:
      'Sì. Compila il questionario su /richiedi-demo: ti mostriamo il flusso sulla tua operatività.',
  },
];

const flusso = [
  { n: '01', t: 'Richiesta', d: 'Il cliente segnala un problema. L’operatore apre la pratica.' },
  { n: '02', t: 'Assegnazione', d: 'La pratica va al CAT e poi al manutentore o tecnico.' },
  { n: '03', t: 'Intervento', d: 'Il tecnico lavora sul campo con il rapportino digitale.' },
  { n: '04', t: 'Chiusura', d: 'Firma, PDF, aggiornamento pratica e storico centralizzato.' },
];
---

<Layout
  title="Gestione completa di assistenza e interventi | Bitora"
  description="La piattaforma può collegare la gestione delle pratiche con i rapportini digitali: dalla richiesta iniziale al documento firmato, con moduli configurabili sul processo aziendale."
  image="/hero-ecosistema.jpg"
>
  <div class="product-page">
    <!-- HERO -->
    <section class="prod-hero">
      <div class="prod-hero-media" aria-hidden="true">
        <img
          src="/hero-ecosistema.jpg"
          alt=""
          class="prod-hero-img"
          fetchpriority="high"
          decoding="async"
        />
        <div class="prod-hero-scrim"></div>
      </div>
      <div class="shell prod-hero-copy">
        <p class="eyebrow">Ecosistema field service</p>
        <h1 class="display">
          Dalla richiesta<br />iniziale al<br />rapportino firmato
        </h1>
        <p class="lede">
          La piattaforma può collegare la gestione delle pratiche con la compilazione dei rapportini digitali. Ogni richiesta viene registrata, assegnata e monitorata. Al termine dell’intervento, il tecnico documenta il lavoro svolto con note, fotografie, ricambi, firme e PDF.
        </p>
        <div class="cta-row">
          <a
            href="/richiedi-demo"
            class="sl-btn-primary"
            data-track="cta_click"
            data-track-location="ecosystem_hero">Richiedi una demo</a
          >
          <a href="#due-applicazioni" class="sl-btn-secondary">Scopri i due moduli</a>
        </div>
      </div>
    </section>

    <!-- MESSAGGIO -->
    <section class="band">
      <div class="shell band-inner">
        <div class="max-w-3xl" data-reveal>
          <p class="eyebrow">Perché insieme</p>
          <h2 class="headline">Un processo solo, due moduli collegabili</h2>
          <p class="body mb-5">
            Il ticket rappresenta l’intera richiesta. Il rapportino rappresenta uno specifico intervento.
            Una pratica può avere più rapportini; la chiusura di un rapportino non chiude necessariamente la pratica, che può restare aperta in attesa di ricambi o di un secondo intervento.
          </p>
          <p class="body-sm">
            Le funzionalità mostrate rappresentano una configurazione dimostrativa. Moduli e flussi vengono definiti in base alle esigenze del progetto.
          </p>
        </div>
      </div>
    </section>

    <!-- DUE APPLICAZIONI -->
    <section id="due-applicazioni" class="border-t border-white/[0.06] bg-white/[0.015]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 py-24 md:py-32">
        <div class="mb-14" data-reveal>
          <p class="text-xs font-semibold tracking-[0.3em] text-white/35 uppercase mb-6">Applicazioni</p>
          <h2 class="text-[clamp(1.85rem,4vw,3.25rem)] font-bold tracking-tight leading-[1.08] max-w-3xl">
            Due pagine dedicate, un ecosistema unico
          </h2>
        </div>
        <div class="grid lg:grid-cols-2 gap-6" data-reveal>
          <a
            href="/ticketing"
            class="group border border-white/[0.1] bg-black/50 p-8 md:p-10 hover:border-white/25 hover:bg-white/[0.03] transition-all duration-300 block"
          >
            <div class="flex items-center gap-3 mb-8">
              <span class="w-10 h-10 border border-white/15 flex items-center justify-center text-white/50">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
              </span>
              <p class="text-xs font-semibold tracking-[0.2em] text-white/40 uppercase">Ticketing</p>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold mb-4 group-hover:translate-x-1 transition-transform">
              Gestione pratiche
            </h3>
            <p class="text-white/50 leading-relaxed mb-8">
              Registra, assegna e monitora le richieste di assistenza. Stati chiari, CAT e manutentori
              distinti, cronologia completa fino alla chiusura.
            </p>
            <span class="text-sm font-semibold text-white inline-flex items-center gap-2">
              Apri la pagina ticketing
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </span>
          </a>

          <a
            href="/rapportini"
            class="group border border-white/[0.1] bg-black/50 p-8 md:p-10 hover:border-white/25 hover:bg-white/[0.03] transition-all duration-300 block"
          >
            <div class="flex items-center gap-3 mb-8">
              <span class="w-10 h-10 border border-white/15 flex items-center justify-center text-white/50">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </span>
              <p class="text-xs font-semibold tracking-[0.2em] text-white/40 uppercase">Rapportini</p>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold mb-4 group-hover:translate-x-1 transition-transform">
              Gestione rapportini
            </h3>
            <p class="text-white/50 leading-relaxed mb-8">
              Compila, firma e archivia i rapporti di intervento da mobile. Foto, ricambi, PDF automatico
              e storico centralizzato per l’amministrazione.
            </p>
            <span class="text-sm font-semibold text-white inline-flex items-center gap-2">
              Apri la pagina rapportini
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- FLUSSO UNIFICATO -->
    <section id="flusso" class="border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 py-24 md:py-32">
        <div class="mb-12" data-reveal>
          <p class="text-xs font-semibold tracking-[0.3em] text-white/35 uppercase mb-6">Flusso</p>
          <h2 class="text-[clamp(1.85rem,4vw,3.25rem)] font-bold tracking-tight leading-[1.08] mb-6 max-w-3xl">
            Il ciclo completo
          </h2>
          <div class="flow-rail mb-4">
            {[
              'Pratica',
              'CAT',
              'Manutentore',
              'Intervento',
              'Rapportino',
              'Firma',
              'PDF',
              'Chiusura',
            ].flatMap((chip, i, arr) =>
              i < arr.length - 1
                ? [
                    <span class="flow-chip">{chip}</span>,
                    <span class="flow-arrow" aria-hidden="true">→</span>,
                  ]
                : [<span class="flow-chip">{chip}</span>]
            )}
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-px bg-white/[0.06]" data-reveal>
          {flusso.map((s) => (
            <div class="bg-black p-10 md:p-14 flex gap-8 md:gap-12 items-start min-h-[200px]">
              <span class="text-[clamp(2.5rem,4vw,4rem)] font-bold leading-none text-white/[0.08] tabular-nums shrink-0"
                >{s.n}</span
              >
              <div class="pt-2">
                <h3 class="text-2xl font-bold mb-3">{s.t}</h3>
                <p class="text-white/45 text-sm md:text-base leading-relaxed max-w-sm">{s.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- VISUAL SPLIT -->
    <section class="band band-alt">
      <div class="shell band-inner">
        <div class="grid lg:grid-cols-2 gap-6 lg:gap-8 items-stretch" data-reveal>
          <div class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-[var(--prod-line-soft)]">
            <img
              src="/hero-field-service.jpg"
              alt="Tecnico in intervento sul campo"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-transparent to-transparent"></div>
            <p class="absolute bottom-5 left-5 right-5 text-sm text-white/85 font-medium tracking-tight">
              Sul campo: rapportino, foto e firme sul dispositivo
            </p>
          </div>
          <div class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-[var(--prod-line-soft)]">
            <img
              src="/communication.jpg"
              alt="Gestione pratiche e comunicazioni dall’ufficio"
              class="w-full h-full object-cover object-center"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-transparent to-transparent"></div>
            <p class="absolute bottom-5 left-5 right-5 text-sm text-white/85 font-medium tracking-tight">
              In ufficio: pratiche, stati e assegnazioni sotto controllo
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMERCIALE -->
    <section class="border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 py-24 md:py-32">
        <div class="grid lg:grid-cols-12 gap-14" data-reveal>
          <div class="lg:col-span-5">
            <p class="text-xs font-semibold tracking-[0.3em] text-white/35 uppercase mb-6">Commerciale</p>
            <h2 class="text-[clamp(2rem,4vw,3.25rem)] font-bold tracking-tight leading-[1.05] mb-6">
              Attivazione<br />+ canone.
            </h2>
            <p class="text-white/50 leading-relaxed mb-10 max-w-md">
              Setup e formazione all’inizio. Poi canone in base a utenti, tecnici, centri e moduli.
              Ticketing e rapportini si attivano insieme o in fasi successive.
            </p>
            <a href="/richiedi-demo" class="sl-btn-primary">Richiedi una demo</a>
          </div>
          <div class="lg:col-span-6 lg:col-start-7">
            <div class="border-t border-white/[0.08]">
              {[
                { t: 'Setup / onboarding', d: 'Incluso a progetto' },
                { t: 'Canone', d: 'Mensile o annuale' },
                { t: 'Moduli', d: 'Attivabili nel tempo' },
                { t: 'Demo', d: 'Su richiesta' },
              ].map((row) => (
                <div class="flex justify-between gap-6 py-6 border-b border-white/[0.08]">
                  <span class="text-white/55">{row.t}</span>
                  <span class="font-semibold text-right">{row.d}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 py-24 md:py-32">
        <div class="grid lg:grid-cols-12 gap-12" data-reveal>
          <div class="lg:col-span-4">
            <p class="text-xs font-semibold tracking-[0.3em] text-white/35 uppercase mb-6">FAQ</p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Domande frequenti</h2>
            <p class="text-white/45 leading-relaxed">Ecosistema, applicazioni e modello.</p>
          </div>
          <div class="lg:col-span-7 lg:col-start-6">
            <FAQ items={faqItems} />
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-white/10 py-32 md:py-40 px-8 md:px-16 lg:px-24 text-center">
      <div data-reveal>
        <p class="text-xs font-semibold tracking-[0.3em] text-white/30 uppercase mb-8">Demo</p>
        <h2 class="text-[clamp(2.5rem,7vw,5rem)] font-bold leading-[1.02] tracking-tight mb-6 max-w-4xl mx-auto">
          Pronto a vedere<br />l’ecosistema?
        </h2>
        <p class="text-white/45 text-lg mb-12 max-w-md mx-auto leading-relaxed">
          Bitora sviluppa piattaforme per aziende che gestiscono assistenza tecnica, interventi e manutenzioni. Dalla richiesta iniziale al rapportino firmato, ogni attività può essere organizzata, assegnata e documentata in un unico sistema.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/richiedi-demo"
            class="sl-btn-primary"
            data-track="cta_click"
            data-track-location="ecosystem_final">Richiedi una demo</a
          >
          <a
            href="https://wa.me/393514979670?text=Ciao%2C%20vorrei%20una%20demo%20della%20piattaforma%20gestione%20interventi."
            class="sl-btn-secondary"
            data-track="whatsapp_click"
            data-track-location="ecosystem_final">WhatsApp</a
          >
        </div>
      </div>
    </section>
  </div>

  <ProductUi />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Bitora Ecosistema Gestione Interventi',
      applicationCategory: 'BusinessApplication',
      applicationSubCategory: 'Field Service Management',
      operatingSystem: 'Web',
      url: 'https://www.bitora.it/gestione-interventi/',
      description:
        'Ecosistema che unisce ticketing, pratiche di assistenza e rapportini digitali per aziende con tecnici sul territorio.',
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        description: 'Attivazione iniziale + canone ricorrente. Demo su richiesta.',
      },
      featureList: [
        'Ticketing e gestione pratiche',
        'Assegnazione a CAT e manutentori',
        'Rapportini digitali con firma',
        'PDF automatico e archivio',
        'Statistiche operative',
      ],
    })}
  />

  <FAQPageSchema items={faqItems} />

  <BreadcrumbListSchema
    crumbs={[
      { name: 'Home', item: 'https://www.bitora.it/' },
      { name: 'Ecosistema', item: 'https://www.bitora.it/gestione-interventi/' },
    ]}
  />
</Layout>

---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';
import MediaShowcase from '../components/MediaShowcase.astro';
import FAQ from '../components/FAQ.astro';
import TrustBadges from '../components/TrustBadges.astro';
import ServiceSchema from '../components/schema/Service.astro';
import FAQPageSchema from '../components/schema/FAQPage.astro';
import HowToSchema from '../components/schema/HowTo.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';
import AnswerFirst from '../components/AnswerFirst.astro';
import ServiceRelatedLinks from '../components/ServiceRelatedLinks.astro';
---

<Layout
  title="Siti Web Professionali | Veloci, SEO, Mobile-First | Bitora"
  description="Siti web professionali per aziende e PMI. Design su misura, performance, SEO tecnico, contenuti. Sede in Piemonte, copertura Italia."
  image="https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?auto=format&fit=crop&w=1600&q=80"
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <VideoHero
      variant="background"
      eyebrow="Siti Web Professionali"
      title="Siti web"
      highlight="che fanno la differenza."
      description="Design su misura, performance reali, SEO tecnico e contenuti. Mobile-first, accessibili, indicizzati al meglio."
      primaryCta={{ label: 'Richiedi preventivo', href: '/contattaci?topic=sito' }}
      secondaryCta={{ label: 'Cosa includiamo', href: '#cosa' }}
      posterSrc="https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?auto=format&fit=crop&w=1600&q=80"
      videoSrc="https://videos.pexels.com/video-files/3192293/3192293-uhd_2560_1440_25fps.mp4"
      videoLabel="Sviluppo siti web professionali"
    />

    <AnswerFirst
      question="Quanto costa un sito web professionale per una PMI?"
      answer="Un sito web professionale per PMI parte da circa €20/mese per soluzioni essenziali (fino a 5 pagine con hosting) fino a progetti business da €49/mese o preventivi su misura. Bitora offre audit gratuito e consegna in 7–14 giorni per landing, 2–6 settimane per siti completi."
    />

    <section
      id="cosa"
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Cos'è un sito professionale
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Più di una vetrina. Un asset di business.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            Sito veloce, indicizzato, mobile-first, con contenuti chiari e CTA misurabili.
          </p>

          <dl class="mt-8 space-y-4">
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Performance reali</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                LCP &lt; 2.5s, CLS controllato. Niente librerie pesanti inutili.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">SEO tecnico</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Schema, sitemap, OG, contenuti orientati a intent locali e nazionali.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Accessibilità</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                WCAG AA: contrasti, focus, semantica, screen reader.
              </dd>
            </div>
          </dl>
        </div>

        <div class="lg:col-span-7">
          <MediaShowcase
            items={[
              {
                src: 'https://images.unsplash.com/photo-1559028012-481c04fa702d?auto=format&fit=crop&w=1600&q=80',
                alt: 'Mockup sito su laptop e mobile',
                caption: 'Design responsive testato 375 → 1440px.',
              },
              {
                src: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1600&q=80',
                alt: 'Sviluppo codice e SEO',
                caption: 'Codice pulito + Lighthouse target 90+.',
              },
              {
                src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1600&q=80',
                alt: 'Analytics e metriche',
                caption: 'Dashboard analytics e Search Console.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Prima/Dopo rimosso: evitiamo blocchi ridondanti -->

    <section class="py-20 md:py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto">
        <p
          class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
        >
          Metodo
        </p>
        <h2
          class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white mb-12"
        >
          Dal brief al lancio in 4 step.
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            [
              { n: '01', t: 'Discovery', d: 'Brief, obiettivi, target, struttura.' },
              { n: '02', t: 'Design', d: 'Wireframe, UI, prototipo, copy.' },
              { n: '03', t: 'Sviluppo', d: 'Codice pulito, performance, SEO, test.' },
              { n: '04', t: 'Lancio', d: 'Deploy, Analytics, Search Console, supporto.' },
            ].map((s, i) => (
              <div
                class="rounded-3xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-7 hover-lift"
                style={`transition-delay:${i * 80}ms`}
              >
                <p class="text-xs font-bold tracking-widest text-[color:var(--brand-cta)]">{s.n}</p>
                <h3 class="mt-2 text-lg font-extrabold tracking-tight text-slate-950 dark:text-white">
                  {s.t}
                </h3>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{s.d}</p>
              </div>
            ))
          }
        </div>

        <div class="mt-16">
          <TrustBadges />
        </div>
      </div>
    </section>

    <section
      class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            FAQ siti web
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
            Risposte chiare su costi, tempi, SEO e supporto.
          </p>
        </div>
        <div class="lg:col-span-7">
          <FAQ
            items={[
              {
                question: 'Quanto costa un sito professionale?',
                answer:
                  'Dipende da pagine, contenuti e integrazioni. Audit gratuito e preventivo chiaro.',
              },
              {
                question: 'Quanto tempo serve?',
                answer:
                  'Landing 7–14 giorni. Sito completo 2–6 settimane in base a contenuti e revisioni.',
              },
              {
                question: 'Fate SEO tecnico?',
                answer:
                  'Sì: struttura H1/H2, schema, performance, sitemap, contenuti per intent locali e nazionali.',
              },
              {
                question: 'Mi insegnate ad aggiornarlo?',
                answer: 'Sì: formazione e documentazione. CMS semplice o servizio gestito.',
              },
              {
                question: 'Lo rendete accessibile?',
                answer:
                  'Sì: WCAG AA. Contrasti, focus, semantica, alt text, prefers-reduced-motion.',
              },
              {
                question: 'Hosting incluso?',
                answer: 'Possibile: ti consigliamo soluzione adatta a budget e traffico.',
              },
              {
                question: 'Fate manutenzione?',
                answer: 'Sì: aggiornamenti, monitoraggio, backup, ottimizzazioni continue.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <ServiceRelatedLinks
      links={[
        {
          href: '/siti-web-piemonte',
          label: 'Siti web Piemonte',
          desc: 'Web agency per Torino e provincia',
        },
        {
          href: '/siti-web-torino',
          label: 'Siti web Torino',
          desc: 'Progetti per aziende torinesi',
        },
        {
          href: '/blog/quanto-costa-sito-web-pmi',
          label: 'Quanto costa un sito web PMI',
          desc: 'Guida prezzi e tempi 2026',
        },
        {
          href: '/carmagnola',
          label: 'Web design Carmagnola',
          desc: 'Sede Bitora e clienti locali',
        },
        {
          href: '/e-commerce-piemonte',
          label: 'E-commerce Piemonte',
          desc: 'Negozi online chiavi in mano',
        },
        {
          href: '/lavori',
          label: 'Case study',
          desc: 'Progetti reali con metriche',
        },
      ]}
    />

    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto text-center">
        <h2
          class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-950 dark:text-white"
        >
          Vuoi un sito che converte?
        </h2>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
          Audit gratuito + preventivo modulare in 24h.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contattaci?topic=sito" class="btn-primary min-w-[220px] shine-on-hover"
            >Richiedi preventivo</a
          >
          <a
            href="https://wa.me/393514979670?text=Ciao,%20vorrei%20un%20preventivo%20per%20un%20sito%20web."
            data-track="whatsapp_click"
            data-track-location="siti_web_cta"
            class="btn-secondary min-w-[220px]"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<ServiceSchema
  name="Realizzazione Siti Web Professionali"
  url="https://www.bitora.it/siti-web-professionali/"
  serviceType={['Siti Web', 'Web Design', 'SEO Tecnico', 'Sviluppo Web']}
  areaServed={['Carmagnola', 'Torino', 'Piemonte', 'Italia']}
/>

<HowToSchema
  name="Come progettiamo un sito web professionale"
  description="Metodo Bitora in 4 step: discovery, design, sviluppo, lancio."
  steps={[
    { name: 'Discovery', text: 'Brief, obiettivi, target, struttura informativa.' },
    { name: 'Design', text: 'Wireframe, UI, prototipo navigabile, copy SEO.' },
    {
      name: 'Sviluppo',
      text: 'Codice pulito, performance LCP < 2.5s, SEO tecnico, test cross-browser.',
    },
    { name: 'Lancio', text: 'Deploy, Analytics, Search Console, supporto post-lancio.' },
  ]}
/>

<FAQPageSchema
  items={[
    {
      question: 'Quanto costa un sito professionale?',
      answer: 'Dipende da pagine, contenuti e integrazioni. Audit gratuito e preventivo chiaro.',
    },
    {
      question: 'Quanto tempo serve?',
      answer: 'Landing 7–14 giorni. Sito completo 2–6 settimane in base a contenuti e revisioni.',
    },
    {
      question: 'Fate SEO tecnico?',
      answer:
        'Sì: struttura H1/H2, schema, performance, sitemap, contenuti per intent locali e nazionali.',
    },
    {
      question: 'Mi insegnate ad aggiornarlo?',
      answer: 'Sì: formazione e documentazione. CMS semplice o servizio gestito.',
    },
    {
      question: 'Lo rendete accessibile?',
      answer: 'Sì: WCAG AA. Contrasti, focus, semantica, alt text, prefers-reduced-motion.',
    },
    {
      question: 'Hosting incluso?',
      answer: 'Possibile: ti consigliamo soluzione adatta a budget e traffico.',
    },
    {
      question: 'Fate manutenzione?',
      answer: 'Sì: aggiornamenti, monitoraggio, backup, ottimizzazioni continue.',
    },
  ]}
/>

<BreadcrumbListSchema
  crumbs={[
    { name: 'Home', item: 'https://www.bitora.it/' },
    { name: 'Siti Web Professionali', item: 'https://www.bitora.it/siti-web-professionali/' },
  ]}
/>

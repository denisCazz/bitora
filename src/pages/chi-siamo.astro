---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';
import MediaShowcase from '../components/MediaShowcase.astro';
import TrustBadges from '../components/TrustBadges.astro';
import StatCounter from '../components/StatCounter.astro';
import ClientLogos from '../components/ClientLogos.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';
---

<Layout
  title="Chi Siamo | Bitora - Sistemi Digitali su Misura"
  description="Bitora: sistemi digitali su misura per aziende e PMI. Sede a Carmagnola, Piemonte. Serviamo tutta Italia. Metodo Trust & Authority, risultati misurabili."
  image="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1600&q=80"
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <VideoHero
      variant="background"
      eyebrow="Chi siamo"
      title="Il partner digitale"
      highlight="della tua azienda."
      description="Sviluppiamo sistemi digitali su misura per PMI italiane. Sede a Carmagnola, copertura nazionale. Trasparenza, metodo, risultati."
      primaryCta={{ label: 'Richiedi consulenza', href: '/contattaci' }}
      secondaryCta={{ label: 'Vedi i progetti', href: '/lavori' }}
      posterSrc="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1600&q=80"
      videoSrc="https://videos.pexels.com/video-files/3209828/3209828-uhd_2560_1440_25fps.mp4"
      videoLabel="Team Bitora al lavoro"
    />

    <!-- Stats -->
    <section
      class="py-16 md:py-20 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <StatCounter
          items={[
            { label: 'Progetti realizzati', value: '50+', number: 50, suffix: '+' },
            { label: 'Clienti soddisfatti', value: '100%', number: 100, suffix: '%' },
            { label: 'Risposta media', value: '24h', number: 24, suffix: 'h' },
            { label: 'Copertura', value: 'Italia' },
          ]}
        />
      </div>
    </section>

    <!-- Storia + Galleria -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            La storia
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Nati per costruire valore digitale.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            Bitora nasce dall'idea di creare sistemi digitali su misura per le PMI italiane. Sede a
            Carmagnola, nel cuore del Piemonte. Crediamo che ogni azienda meriti strumenti costruiti
            sulle proprie esigenze.
          </p>
          <p class="mt-4 text-base text-slate-600 dark:text-slate-300 leading-relaxed">
            Affianchiamo le imprese nel percorso di digitalizzazione con competenza, trasparenza e
            risultati concreti. Niente pacchetti preconfezionati: solo soluzioni che funzionano.
          </p>
        </div>

        <div class="lg:col-span-7">
          <MediaShowcase
            items={[
              {
                src: 'https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=1600&q=80',
                alt: 'Workshop e brainstorming',
                caption: 'Workshop iniziale: ascoltiamo prima di proporre.',
              },
              {
                src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1600&q=80',
                alt: 'Team al lavoro',
                caption: 'Sviluppo iterativo, sempre in contatto col cliente.',
              },
              {
                src: 'https://images.unsplash.com/photo-1556761175-4b46a572b786?auto=format&fit=crop&w=1600&q=80',
                alt: 'Pianificazione e roadmap',
                caption: 'Roadmap chiare, KPI definiti, output misurabili.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Metodo -->
    <section
      class="py-24 px-6 md:px-12 lg:px-20 bg-gray-50 dark:bg-white/[0.02] border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <p
          class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
        >
          Metodo
        </p>
        <h2
          class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white mb-12"
        >
          Come lavoriamo, in 4 step.
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            [
              {
                n: '01',
                t: 'Analisi',
                d: 'Processi, pain point, obiettivi. Definiamo scope e priorità.',
              },
              {
                n: '02',
                t: 'Progettazione',
                d: 'Architettura, UX e flussi. Niente sorprese in sviluppo.',
              },
              {
                n: '03',
                t: 'Sviluppo',
                d: 'Iterativo con checkpoint. Vedi i progressi in tempo reale.',
              },
              { n: '04', t: 'Deploy', d: 'Go-live assistito, formazione e supporto post-lancio.' },
            ].map((s, i) => (
              <div
                class="rounded-3xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-7 hover-lift reveal-on-scroll"
                style={`transition-delay:${i * 80}ms`}
              >
                <p class="text-xs font-bold tracking-widest text-[color:var(--brand-cta)]">{s.n}</p>
                <h3 class="mt-2 text-lg font-extrabold tracking-tight text-slate-950 dark:text-white">
                  {s.t}
                </h3>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{s.d}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Valori -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Valori
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Cosa ci guida ogni giorno.
          </h2>
        </div>

        <div class="lg:col-span-8 grid sm:grid-cols-2 gap-6">
          {
            [
              {
                t: 'Risultati',
                d: 'Non "bello", efficace. Ogni soluzione genera valore misurabile.',
              },
              {
                t: 'Innovazione',
                d: 'Tecnologie moderne: Astro, React, integrazioni API, automazioni.',
              },
              {
                t: 'Partnership',
                d: 'Non fornitori, partner. Supporto diretto, niente call center.',
              },
              {
                t: 'Trasparenza',
                d: 'Preventivi chiari, milestone visibili, comunicazione continua.',
              },
            ].map((v, i) => (
              <div
                class="rounded-3xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-7 hover-lift reveal-on-scroll"
                style={`transition-delay:${i * 80}ms`}
              >
                <h3 class="text-xl font-extrabold tracking-tight text-slate-950 dark:text-white">
                  {v.t}
                </h3>
                <p class="mt-2 text-slate-600 dark:text-slate-300 leading-relaxed">{v.d}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Trust + clienti -->
    <section
      class="py-24 px-6 md:px-12 lg:px-20 bg-gray-50 dark:bg-white/[0.02] border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <p
          class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
        >
          Garanzie
        </p>
        <h2
          class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white mb-10"
        >
          Trust & metodo, sempre.
        </h2>
        <TrustBadges />

        <div class="mt-16">
          <ClientLogos />
        </div>
      </div>
    </section>

    <!-- Territorio -->
    <section class="py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-6">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Territorio
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Sede in Piemonte.<br />Serviamo tutta Italia.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            Carmagnola (TO) come base operativa. Lavoriamo con clienti in tutta Italia tramite call,
            demo, supporto remoto e visite quando serve.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            {
              [
                'Carmagnola',
                'Torino',
                'Cuneo',
                'Asti',
                'Alessandria',
                'Milano',
                'Roma',
                'Tutta Italia',
              ].map(c => (
                <span class="px-4 py-2 rounded-full bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-sm font-medium">
                  {c}
                </span>
              ))
            }
          </div>
        </div>
        <div class="lg:col-span-6">
          <div class="media-frame relative overflow-hidden">
            <img
              src="/monviso.jpg"
              alt="Carmagnola, Piemonte"
              class="w-full h-full object-cover aspect-[16/10]"
              loading="lazy"
              data-parallax
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent"
            >
            </div>
            <div class="absolute bottom-5 left-5 right-5">
              <div class="hero-panel rounded-2xl px-5 py-4">
                <p class="text-white font-semibold">Carmagnola (TO)</p>
                <p class="text-white/85 text-sm mt-1">Sede operativa · Piemonte · Italia</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-3xl mx-auto text-center">
        <h2
          class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-950 dark:text-white"
        >
          Costruiamo il futuro insieme.
        </h2>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
          Consulenza gratuita. Risposta in 24h.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contattaci" class="btn-primary min-w-[220px] shine-on-hover">Contattaci ora</a>
          <a href="/lavori" class="btn-secondary min-w-[220px]">Vedi i progetti</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<BreadcrumbListSchema
  crumbs={[
    { name: 'Home', item: 'https://www.bitora.it/' },
    { name: 'Chi siamo', item: 'https://www.bitora.it/chi-siamo/' },
  ]}
/>

<script>
  const prefersReduced = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
  if (!prefersReduced) {
    const els = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
    const onScroll = () => {
      const y = window.scrollY || 0;
      els.forEach(el => {
        const r = el.getBoundingClientRect();
        if (r.bottom < 0 || r.top > window.innerHeight) return;
        el.style.transform = `translateY(${(y * 0.06).toFixed(1)}px) scale(1.04)`;
      });
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

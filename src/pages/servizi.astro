---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Servizi | Gestione interventi, siti web ed e-commerce | Bitora"
  description="Piattaforma per ticket, tecnici e rapportini digitali. Siti web ed e-commerce come servizi complementari. Sede in Piemonte, copertura nazionale."
>
  <div class="bg-black text-white overflow-x-hidden">

    <section class="relative h-[70vh] min-h-[560px] flex flex-col justify-end">
      <div class="absolute inset-0">
        <img
          src="/field-tablet.jpg"
          alt="Digitalizzazione operativa e assistenza tecnica"
          class="w-full h-full object-cover"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/55 to-black/20"></div>
      </div>
      <div class="relative z-10 px-8 md:px-16 lg:px-24 pb-16 md:pb-24">
        <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-4">Cosa facciamo</p>
        <h1 class="text-5xl md:text-6xl lg:text-[5rem] font-bold leading-[1.04] tracking-tight mb-5 max-w-3xl">
          Digitalizziamo<br />l’assistenza tecnica.
        </h1>
        <p class="text-base md:text-lg text-white/70 max-w-lg leading-relaxed">
          Il nucleo è la piattaforma di gestione interventi. Siti web ed e-commerce restano servizi di ingresso e supporto.
        </p>
      </div>
    </section>

    <!-- PIATTAFORMA -->
    <section id="gestione-interventi" class="bg-black py-24 md:py-36 border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24">
        <div class="grid md:grid-cols-2 gap-12 lg:gap-24 items-center">
          <div>
            <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-6">01 — Priorità</p>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight mb-6">
              Ticket, tecnici<br />e rapportini.
            </h2>
            <p class="text-base md:text-lg text-white/70 mb-8 leading-relaxed">
              Una piattaforma unica per richieste, assegnazioni, calendario, interventi sul campo, firme, PDF, ricambi e statistiche.
            </p>
            <div class="flex flex-wrap gap-2 mb-10">
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Ticketing</span>
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Rapportini</span>
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Centri assistenza</span>
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Statistiche</span>
            </div>
            <div class="flex flex-wrap gap-4">
              <a href="/gestione-interventi" class="sl-btn-primary">Scopri la piattaforma</a>
              <a href="/richiedi-demo" class="sl-btn-secondary">Richiedi demo</a>
            </div>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-8 space-y-4">
            {[
              'Apertura pratiche e priorità',
              'Assegnazione a centri e tecnici',
              'Rapportino digitale con firma',
              'Documenti, foto e storico',
              'Controllo tempi e performance',
            ].map(item => (
              <div class="flex items-start gap-3 text-white/75 text-sm">
                <span class="text-white mt-0.5">✓</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- AI MODULO -->
    <section id="ai" class="relative bg-black py-24 md:py-32 overflow-hidden border-t border-white/[0.06]">
      <div class="relative z-10 px-8 md:px-16 lg:px-24 max-w-4xl mx-auto text-center">
        <p class="text-xs font-semibold tracking-[0.25em] text-indigo-400/70 uppercase mb-6">02 — Modulo AI documentale</p>
        <h2 class="text-4xl md:text-5xl font-bold leading-[1.04] tracking-tight mb-6">
          AI al servizio dei processi,<br />non come fine.
        </h2>
        <p class="text-base md:text-lg text-white/65 mb-8 max-w-2xl mx-auto leading-relaxed">
          Ricerca nei manuali, estrazione dati da documenti, compilazione assistita e supporto ai tecnici. Utile quando è collegata a ticket e rapportini.
        </p>
        <a href="/gestione-interventi#ai-documentale" class="sl-btn-secondary">Come si integra</a>
      </div>
    </section>

    <!-- SITI WEB -->
    <section id="siti-web" class="relative min-h-[70vh] flex flex-col justify-center py-24 border-t border-white/[0.06]">
      <div class="absolute inset-0">
        <img
          src="/programming.jpg"
          alt="Siti web professionali"
          class="w-full h-full object-cover opacity-25"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-black/40"></div>
      </div>
      <div class="relative z-10 px-8 md:px-16 lg:px-24 max-w-2xl">
        <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-4">03 — Siti Web</p>
        <h2 class="text-4xl md:text-5xl font-bold leading-[1.05] tracking-tight mb-4">
          Presenza online<br />che converte.
        </h2>
        <p class="text-base md:text-lg text-white/70 mb-8 leading-relaxed">
          Siti professionali, SEO tecnico e performance. Servizio complementare e di ingresso verso software operativi.
        </p>
        <a href="/siti-web-professionali" class="sl-btn-secondary">Scopri i siti web</a>
      </div>
    </section>

    <!-- E-COMMERCE -->
    <section id="ecommerce" class="bg-black py-24 md:py-36 border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24 grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-6">04 — E-commerce</p>
          <h2 class="text-4xl md:text-5xl font-bold leading-[1.05] tracking-tight mb-6">
            Negozi online<br />su misura.
          </h2>
          <p class="text-base md:text-lg text-white/70 mb-8 leading-relaxed">
            Cataloghi, carrello, pagamenti e gestione ordini. Ideale come canale digitale aggiuntivo, non come messaggio principale di Bitora.
          </p>
          <a href="/e-commerce-piemonte" class="sl-btn-secondary">Scopri e-commerce</a>
        </div>
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3] border border-white/10">
          <img
            src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=900&q=85"
            alt="E-commerce su misura"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <!-- ALTRI -->
    <section id="altri" class="bg-black py-24 border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24">
        <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-6">Altri strumenti</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-8">Moduli e servizi complementari</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <a href="/sistemi-aziendali" class="rounded-2xl border border-white/10 p-6 hover:border-white/30 transition-colors">
            <h3 class="font-bold text-lg mb-2">Sistemi aziendali</h3>
            <p class="text-white/60 text-sm">CRM e gestionali verticali integrati ai processi.</p>
          </a>
          <a href="/nfc-ecosystem" class="rounded-2xl border border-white/10 p-6 hover:border-white/30 transition-colors">
            <h3 class="font-bold text-lg mb-2">Tessere NFC</h3>
            <p class="text-white/60 text-sm">Recensioni, menu e contatti con un tap.</p>
          </a>
          <a href="/grafica-digitale-social-media" class="rounded-2xl border border-white/10 p-6 hover:border-white/30 transition-colors">
            <h3 class="font-bold text-lg mb-2">Grafica & social</h3>
            <p class="text-white/60 text-sm">Identità visiva e contenuti, in collaborazione.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="bg-black py-28 px-8 md:px-16 lg:px-24 text-center border-t border-white/10">
      <h2 class="text-4xl md:text-5xl font-bold leading-[1.05] tracking-tight mb-5 max-w-2xl mx-auto">
        Parti dalla piattaforma operativa.
      </h2>
      <p class="text-base md:text-lg text-white/60 mb-10 max-w-md mx-auto">
        Richiedi una demo e valuta se il flusso si adatta alla tua rete di tecnici.
      </p>
      <a href="/richiedi-demo" class="sl-btn-primary">Richiedi una demo</a>
    </section>

  </div>
</Layout>

<style>
  .sl-btn-primary {
    display:inline-flex;align-items:center;gap:.5rem;
    background:#fff;color:#000;font-weight:600;font-size:.875rem;
    padding:.75rem 1.75rem;border-radius:4px;transition:background .2s;white-space:nowrap;
  }
  .sl-btn-primary:hover{background:#e5e5e5;}
  .sl-btn-secondary {
    display:inline-flex;align-items:center;gap:.5rem;
    background:transparent;color:#fff;font-weight:600;font-size:.875rem;
    padding:.75rem 1.75rem;border-radius:4px;
    border:1.5px solid rgba(255,255,255,.55);
    transition:border-color .2s,background .2s;white-space:nowrap;
  }
  .sl-btn-secondary:hover{border-color:rgba(255,255,255,.9);background:rgba(255,255,255,.08);}
</style>

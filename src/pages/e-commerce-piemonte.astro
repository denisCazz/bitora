---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';
import MediaShowcase from '../components/MediaShowcase.astro';
import FAQ from '../components/FAQ.astro';
import TrustBadges from '../components/TrustBadges.astro';
import ServiceSchema from '../components/schema/Service.astro';
import FAQPageSchema from '../components/schema/FAQPage.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';
---

<Layout
  title="E-commerce Piemonte | Negozi Online Chiavi in Mano | Bitora"
  description="E-commerce professionali per aziende in Piemonte. WooCommerce, Shopify, sviluppo custom. Dalla strategia al lancio con supporto continuo. Preventivo gratuito."
  image="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1600&q=80"
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <VideoHero
      variant="background"
      eyebrow="E-commerce Piemonte"
      title="Vendi online,"
      highlight="senza compromessi."
      description="WooCommerce, Shopify o sviluppo custom. Dalla strategia al lancio: pagamenti, spedizioni, SEO e supporto inclusi."
      primaryCta={{ label: 'Richiedi preventivo', href: '/contattaci?topic=ecommerce' }}
      secondaryCta={{ label: 'Come funziona', href: '#come' }}
      posterSrc="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1600&q=80"
      videoSrc="https://videos.pexels.com/video-files/4994040/4994040-uhd_2732_1440_25fps.mp4"
      videoLabel="E-commerce checkout in azione"
    />

    <section
      id="come"
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Cos'è un e-commerce
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Negozio online che vende davvero.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            Sito che mostra catalogo, accetta pagamenti, gestisce spedizioni, traccia conversioni.
            Aperto 24/7.
          </p>

          <dl class="mt-8 space-y-4">
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Pagamenti sicuri</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Stripe, PayPal, bonifico, Klarna. Conformità PCI.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Spedizioni integrate</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                GLS, BRT, Poste, ritiro in negozio. Tracking automatico.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">SEO + tracking</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Schema product, Google Merchant, GA4, Pixel.
              </dd>
            </div>
          </dl>
        </div>

        <div class="lg:col-span-7">
          <MediaShowcase
            items={[
              {
                src: 'https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=1600&q=80',
                alt: 'Mockup checkout su laptop',
                caption: 'Checkout veloce, mobile-first, conversioni alte.',
              },
              {
                src: 'https://images.unsplash.com/photo-1607082349566-187342175e2f?auto=format&fit=crop&w=1600&q=80',
                alt: 'Catalogo prodotti',
                caption: 'Catalogo ottimizzato: filtri, varianti, foto pro.',
              },
              {
                src: 'https://images.unsplash.com/photo-1556742393-d75f468bfcb0?auto=format&fit=crop&w=1600&q=80',
                alt: 'Dashboard vendite',
                caption: 'Dashboard ordini, magazzino e clienti.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Prima/Dopo rimosso: evitiamo blocchi ridondanti -->

    <section class="py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto">
        <div class="mb-12 grid lg:grid-cols-12 gap-8 items-center">
          <div class="lg:col-span-7">
            <p
              class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
            >
              Risultato
            </p>
            <h2
              class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
            >
              Online + offline, stessa regia.
            </h2>
            <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
              Catalogo, pagamenti, spedizioni e tracking lavorano insieme. Tu vedi ordini e clienti
              in un’unica dashboard.
            </p>
            <ul class="mt-6 grid sm:grid-cols-2 gap-3 text-slate-700 dark:text-slate-300">
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--brand-cta)]"></span> Vendita 24/7
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--brand-cta)]"></span> SEO + Merchant
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--brand-cta)]"></span> Remarketing pronto
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--brand-cta)]"></span> Automazioni ordini
              </li>
            </ul>
          </div>
          <div class="lg:col-span-5">
            <div class="media-frame overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=1600&q=80"
                alt="Checkout e-commerce su laptop"
                class="w-full h-full object-cover aspect-[16/10]"
                loading="lazy"
              />
            </div>
          </div>
        </div>

        <div class="mb-10">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Trust
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Garanzie e metodo
          </h2>
        </div>
        <TrustBadges />
      </div>
    </section>

    <section
      class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            FAQ e-commerce
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
            Risposte chiare su costi, tempi e piattaforme.
          </p>
        </div>
        <div class="lg:col-span-7">
          <FAQ
            items={[
              {
                question: 'Quanto costa un e-commerce?',
                answer:
                  'Dipende da piattaforma, catalogo e integrazioni. Partiamo da audit gratuito e preventivo modulare.',
              },
              {
                question: 'WooCommerce o Shopify?',
                answer:
                  'WooCommerce per controllo + personalizzazioni. Shopify per partenza veloce. Custom per casi B2B/marketplace.',
              },
              {
                question: 'Quanto tempo serve per il lancio?',
                answer:
                  'Tipicamente 3–6 settimane dal brief al go-live, in base a contenuti e prodotti.',
              },
              {
                question: 'Gestite pagamenti e fatture?',
                answer:
                  'Sì: Stripe, PayPal, bonifico. Integrazione fatturazione automatica con gestionali italiani.',
              },
              {
                question: 'Posso vendere in tutta Italia?',
                answer:
                  'Sì. Configuriamo spedizioni nazionali con GLS, BRT, Poste e ritiro in negozio.',
              },
              {
                question: 'Fate SEO per il negozio?',
                answer:
                  'Sì: schema product, sitemap, Merchant Center, contenuti ottimizzati per ricerche prodotto.',
              },
              {
                question: 'Offrite supporto post-lancio?',
                answer:
                  'Sì: monitoraggio, aggiornamenti, ottimizzazioni continue. Niente abbandono al lancio.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto text-center">
        <h2
          class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-950 dark:text-white"
        >
          Pronto a vendere online?
        </h2>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
          Preventivo gratuito. Ti rispondiamo entro 24h.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contattaci?topic=ecommerce" class="btn-primary min-w-[220px] shine-on-hover"
            >Richiedi preventivo</a
          >
          <a
            href="https://wa.me/393514979670?text=Ciao,%20vorrei%20un%20preventivo%20per%20un%20e-commerce."
            class="btn-secondary min-w-[220px]"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<ServiceSchema
  name="Realizzazione E-commerce Piemonte"
  url="https://www.bitora.it/e-commerce-piemonte/"
  serviceType={['E-commerce', 'WooCommerce', 'Shopify', 'Negozi Online']}
  areaServed={[
    'Carmagnola',
    'Carignano',
    'Poirino',
    'Torino',
    'Cuneo',
    'Asti',
    'Alessandria',
    'Piemonte',
    'Italia',
  ]}
/>

<FAQPageSchema
  items={[
    {
      question: 'Quanto costa un e-commerce?',
      answer:
        'Dipende da piattaforma, catalogo e integrazioni. Partiamo da audit gratuito e preventivo modulare.',
    },
    {
      question: 'WooCommerce o Shopify?',
      answer:
        'WooCommerce per controllo + personalizzazioni. Shopify per partenza veloce. Custom per casi B2B/marketplace.',
    },
    {
      question: 'Quanto tempo serve per il lancio?',
      answer: 'Tipicamente 3–6 settimane dal brief al go-live, in base a contenuti e prodotti.',
    },
    {
      question: 'Gestite pagamenti e fatture?',
      answer:
        'Sì: Stripe, PayPal, bonifico. Integrazione fatturazione automatica con gestionali italiani.',
    },
    {
      question: 'Posso vendere in tutta Italia?',
      answer: 'Sì. Configuriamo spedizioni nazionali con GLS, BRT, Poste e ritiro in negozio.',
    },
    {
      question: 'Fate SEO per il negozio?',
      answer:
        'Sì: schema product, sitemap, Merchant Center, contenuti ottimizzati per ricerche prodotto.',
    },
    {
      question: 'Offrite supporto post-lancio?',
      answer:
        'Sì: monitoraggio, aggiornamenti, ottimizzazioni continue. Niente abbandono al lancio.',
    },
  ]}
/>

<BreadcrumbListSchema
  crumbs={[
    { name: 'Home', item: 'https://www.bitora.it/' },
    { name: 'E-commerce', item: 'https://www.bitora.it/e-commerce-piemonte/' },
  ]}
/>

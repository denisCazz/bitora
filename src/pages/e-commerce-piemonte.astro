---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="E-commerce Piemonte | Negozi Online Chiavi in Mano | Bitora"
  description="E-commerce professionali per aziende in Piemonte. WooCommerce, Shopify, sviluppo custom. Dalla strategia al lancio con supporto continuo. Preventivo gratuito."
>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Realizzazione E-commerce Piemonte",
      "provider": { "@type": "LocalBusiness", "name": "Bitora", "address": { "@type": "PostalAddress", "addressLocality": "Carmagnola", "addressRegion": "Piemonte", "addressCountry": "IT" } },
      "areaServed": ["Carmagnola", "Carignano", "Poirino", "Torino", "Piemonte"],
      "serviceType": ["E-commerce", "Negozi Online", "WooCommerce", "Shopify"]
    }
  </script>

  <main class="bg-black text-white overflow-x-hidden selection:bg-primary/20 selection:text-white">
    
    <!-- Hero -->
    <section class="relative py-24 md:py-32 px-6 md:px-12 lg:px-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-black via-black to-black/95"></div>
      <div class="absolute top-1/3 -right-20 w-72 h-72 rounded-full bg-primary/10 blur-[100px] opacity-50"></div>
      
      <div class="relative z-10 max-w-4xl">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">E-commerce</p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
          Il tuo negozio online,<br />
          <span class="text-primary">chiavi in mano.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl leading-relaxed mb-8">
          E-commerce professionali per vendere in tutta Italia. <strong class="text-white">Dalla strategia al lancio</strong>, con pagamenti sicuri, spedizioni integrate e supporto continuo.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contattaci?topic=ecommerce" class="btn-primary group min-w-[200px] flex items-center justify-center gap-2">
            Richiedi preventivo gratuito
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#vantaggi" class="btn-secondary min-w-[200px] flex items-center justify-center gap-2">
            Scopri i vantaggi
          </a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-16 md:py-20 px-6 md:px-12 lg:px-20 border-y border-white/5 bg-white/[0.02]">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {[
            { value: '100%', label: 'Chiavi in mano', bar: 100 },
            { value: '24/7', label: 'Vendita sempre attiva', bar: 100 },
            { value: 'SEO', label: 'Ottimizzato Google', bar: 95 },
            { value: '∞', label: 'Supporto incluso', bar: 100 }
          ].map((stat, i) => (
            <div class="reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <p class="text-3xl md:text-4xl font-bold text-white mb-2">{stat.value}</p>
              <p class="text-sm text-gray-500 uppercase tracking-wider">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Perché E-commerce -->
    <section id="vantaggi" class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Perché vendere online</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">Il commercio digitale cresce. Il tuo negozio no.</h2>

        <div class="grid md:grid-cols-3 gap-8">
          {[
            { icon: '🛒', title: 'Vendita 24/7', desc: 'Il negozio non chiude mai. Clienti acquistano a qualsiasi ora, da qualsiasi luogo.' },
            { icon: '📍', title: 'SEO Locale + Nazionale', desc: 'Visibilità su Google per ricerche locali e nazionali. Più traffico, più vendite.' },
            { icon: '📦', title: 'Gestione Semplificata', desc: 'Pannello intuitivo per prodotti, ordini e clienti. Formazione inclusa.' }
          ].map((item, i) => (
            <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/10 hover:border-primary/40 transition-all reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 text-2xl">{item.icon}</div>
              <h3 class="text-xl font-bold text-white mb-4">{item.title}</h3>
              <p class="text-gray-400 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cosa include -->
    <section class="py-20 md:py-24 px-6 md:px-12 lg:px-20 bg-white/[0.02] border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="reveal-on-scroll">
            <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Cosa include</p>
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">Ogni progetto è unico, come la tua attività.</h2>
            <p class="text-lg text-gray-400 mb-8 leading-relaxed">
              Non vendiamo pacchetti standard. Ogni e-commerce viene progettato sulle tue esigenze: tipo di prodotto, volume di vendite, target.
            </p>
            <ul class="space-y-4">
              {['Analisi mercato e concorrenza', 'Design personalizzato sul brand', 'Catalogo prodotti ottimizzato', 'Pagamenti sicuri (Stripe, PayPal, Bonifico)', 'Spedizioni integrate (GLS, BRT, Poste)', 'Formazione completa sulla gestione'].map(item => (
                <li class="flex items-center gap-4">
                  <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-gray-300">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="reveal-on-scroll" style="transition-delay: 200ms">
            <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/10">
              <h3 class="text-xl font-bold text-white mb-6">Tecnologie</h3>
              <div class="space-y-4">
                {[
                  { name: 'WooCommerce', desc: 'Controllo totale. Ideale per cataloghi medi e personalizzazioni avanzate.', color: 'bg-green-500/20' },
                  { name: 'Shopify', desc: 'Zero pensieri tecnici. Parti velocemente con budget definito.', color: 'bg-purple-500/20' },
                  { name: 'Sviluppo Custom', desc: 'Marketplace, B2B, integrazioni gestionali. Massima flessibilità.', color: 'bg-primary/20' }
                ].map(t => (
                  <div class="p-4 rounded-xl border border-white/10 hover:border-primary/40 transition-all">
                    <h4 class="font-bold text-white mb-1">{t.name}</h4>
                    <p class="text-gray-400 text-sm">{t.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Processo -->
    <section class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Come lavoriamo</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">Dal primo contatto al lancio in 3-6 settimane</h2>

        <div class="grid md:grid-cols-4 gap-8">
          {[
            { step: '01', title: 'Consulenza', desc: 'Analizziamo obiettivi, prodotti e target. Definiamo la strategia.' },
            { step: '02', title: 'Progettazione', desc: 'Design personalizzato, architettura catalogo e flusso d\'acquisto.' },
            { step: '03', title: 'Sviluppo', desc: 'Costruzione, integrazione pagamenti e spedizioni, test.' },
            { step: '04', title: 'Lancio + Supporto', desc: 'Messa online, formazione e assistenza continua.' }
          ].map((item, i) => (
            <div class="text-center reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <span class="text-5xl font-bold text-primary/20">{item.step}</span>
              <h3 class="text-xl font-bold text-white mt-4 mb-2">{item.title}</h3>
              <p class="text-gray-400 text-sm">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Territorio -->
    <section class="py-20 md:py-24 px-6 md:px-12 lg:px-20 bg-white/[0.02] border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm font-medium tracking-widest text-primary uppercase mb-4">Territorio</p>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-8">E-commerce in tutto il Piemonte</h2>
        <div class="flex flex-wrap gap-3">
          {['Carmagnola', 'Carignano', 'Poirino', 'Villastellone', 'Torino', 'Cuneo', 'Asti', 'Alessandria'].map(city => (
            <span class="px-4 py-2 rounded-xl bg-white/[0.05] border border-white/10 text-white text-sm font-medium">{city}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-white/5">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Pronto a vendere online?</h2>
        <p class="text-gray-400 mb-8">Raccontaci il tuo progetto. Preventivo gratuito e senza impegno.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contattaci?topic=ecommerce" class="btn-primary inline-flex items-center justify-center gap-2 min-w-[200px]">Richiedi preventivo</a>
          <a href="https://wa.me/393514979670?text=Ciao,%20vorrei%20un%20preventivo%20per%20un%20e-commerce." class="btn-secondary inline-flex items-center justify-center gap-2 min-w-[200px]">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .reveal-on-scroll { opacity: 0; transform: translateY(30px); transition: all 1s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal-on-scroll.is-visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); } });
  }, { threshold: 0.1 });
  document.addEventListener('DOMContentLoaded', () => document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el)));
</script>

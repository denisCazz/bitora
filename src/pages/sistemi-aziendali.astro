---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';
import MediaShowcase from '../components/MediaShowcase.astro';
import FAQ from '../components/FAQ.astro';
import TrustBadges from '../components/TrustBadges.astro';
import ServiceSchema from '../components/schema/Service.astro';
import FAQPageSchema from '../components/schema/FAQPage.astro';
import HowToSchema from '../components/schema/HowTo.astro';
import BreadcrumbListSchema from '../components/schema/BreadcrumbList.astro';
---

<Layout
  title="Sistemi Aziendali su Misura | Gestionali, CRM, CMMS | Bitora"
  description="Software gestionali, CRM, CMMS e strumenti aziendali su misura. Riduci lavoro manuale, integra processi, aumenta efficienza. Sviluppo italiano."
  image="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1600&q=80"
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <VideoHero
      variant="background"
      eyebrow="Sistemi Aziendali su Misura"
      title="Software gestionali"
      highlight="che lavorano per te."
      description="CRM, gestionali, CMMS e tool custom. Integrati con email, WhatsApp, fogli e API. Riduci lavoro manuale, aumenta efficienza."
      primaryCta={{ label: 'Richiedi consulenza', href: '/contattaci?topic=sistemi' }}
      secondaryCta={{ label: 'Cosa realizziamo', href: '#cosa' }}
      posterSrc="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1600&q=80"
      videoSrc="https://videos.pexels.com/video-files/3209828/3209828-uhd_2560_1440_25fps.mp4"
      videoLabel="Dashboard gestionale aziendale"
    />

    <section
      id="cosa"
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Cos'è un sistema aziendale
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Software che riduce lavoro manuale.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            Centralizza dati, automatizza task ripetitivi, integra strumenti che usi già.
          </p>

          <dl class="mt-8 space-y-4">
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">
                CRM (Customer Relationship Management)
              </dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Lead, clienti, pipeline, follow-up automatizzati.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">Gestionale</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Ordini, magazzino, fatturazione, integrazione contabile.
              </dd>
            </div>
            <div
              class="rounded-2xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-5"
            >
              <dt class="font-bold text-slate-950 dark:text-white">CMMS (Manutenzione)</dt>
              <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                Interventi, ticket, asset, ricambi, firme digitali.
              </dd>
            </div>
          </dl>
        </div>

        <div class="lg:col-span-7">
          <MediaShowcase
            items={[
              {
                src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1600&q=80',
                alt: 'Dashboard CRM e analytics',
                caption: 'Dashboard centralizzata: KPI, pipeline, ticket.',
              },
              {
                src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1600&q=80',
                alt: 'Report e statistiche',
                caption: 'Report automatici e alert intelligenti.',
              },
              {
                src: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=1600&q=80',
                alt: 'Operatore con tablet',
                caption: 'App mobile per operatori sul campo.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Prima/Dopo rimosso: evitiamo blocchi ridondanti -->

    <section class="py-20 md:py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto">
        <p
          class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
        >
          Garanzie
        </p>
        <h2
          class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white mb-12"
        >
          Trust e metodo
        </h2>
        <TrustBadges />
      </div>
    </section>

    <section
      class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            FAQ sistemi aziendali
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
            Risposte chiare su CRM, gestionali, CMMS e integrazioni.
          </p>
        </div>
        <div class="lg:col-span-7">
          <FAQ
            items={[
              {
                question: 'Cos’è un CRM?',
                answer:
                  'Software per gestire clienti, lead, pipeline e follow-up. Centralizza dati e comunicazioni.',
              },
              {
                question: 'Cos’è un CMMS?',
                answer:
                  'Computerized Maintenance Management System: gestione interventi, asset, ricambi, ticket, firme.',
              },
              {
                question: 'Quanto costa un gestionale su misura?',
                answer:
                  'Dipende da moduli e integrazioni. Audit gratuito e roadmap modulare in base a priorità.',
              },
              {
                question: 'Si integra con strumenti esistenti?',
                answer:
                  'Sì: email, WhatsApp, Google Sheets, fatturazione italiana, API REST e webhook.',
              },
              {
                question: 'Tempo medio di sviluppo?',
                answer: 'MVP funzionale 4–8 settimane. Sviluppo iterativo con rilasci frequenti.',
              },
              {
                question: 'Posso accedere da mobile?',
                answer: 'Sì: web app responsive o app dedicata per operatori sul campo.',
              },
              {
                question: 'I dati sono al sicuro?',
                answer:
                  'Sì: hosting EU, backup automatici, controllo accessi, audit log e GDPR by design.',
              },
            ]}
          />
        </div>
      </div>
    </section>
  </main>
</Layout>

<ServiceSchema
  name="Sistemi Aziendali su Misura (CRM, Gestionali, CMMS)"
  url="https://www.bitora.it/sistemi-aziendali/"
  serviceType={['CRM', 'Gestionale', 'CMMS', 'Software su misura', 'Automazione']}
  areaServed={['Carmagnola', 'Torino', 'Piemonte', 'Italia']}
/>

<HowToSchema
  name="Come digitalizziamo processi aziendali"
  description="Metodo Bitora: audit, mappa processi, MVP, rilascio iterativo."
  steps={[
    { name: 'Audit', text: 'Analisi processi esistenti e identificazione colli di bottiglia.' },
    { name: 'Mappa', text: 'Mappa flussi target con priorità e KPI misurabili.' },
    { name: 'MVP', text: 'Sviluppo MVP funzionale in 4–8 settimane con rilascio iterativo.' },
    { name: 'Ottimizza', text: 'Rilasci frequenti, raccolta feedback, miglioramenti continui.' },
  ]}
/>

<FAQPageSchema
  items={[
    {
      question: 'Cos’è un CRM?',
      answer:
        'Software per gestire clienti, lead, pipeline e follow-up. Centralizza dati e comunicazioni.',
    },
    {
      question: 'Cos’è un CMMS?',
      answer:
        'Computerized Maintenance Management System: gestione interventi, asset, ricambi, ticket, firme.',
    },
    {
      question: 'Quanto costa un gestionale su misura?',
      answer:
        'Dipende da moduli e integrazioni. Audit gratuito e roadmap modulare in base a priorità.',
    },
    {
      question: 'Si integra con strumenti esistenti?',
      answer: 'Sì: email, WhatsApp, Google Sheets, fatturazione italiana, API REST e webhook.',
    },
    {
      question: 'Tempo medio di sviluppo?',
      answer: 'MVP funzionale 4–8 settimane. Sviluppo iterativo con rilasci frequenti.',
    },
    {
      question: 'Posso accedere da mobile?',
      answer: 'Sì: web app responsive o app dedicata per operatori sul campo.',
    },
    {
      question: 'I dati sono al sicuro?',
      answer: 'Sì: hosting EU, backup automatici, controllo accessi, audit log e GDPR by design.',
    },
  ]}
/>

<BreadcrumbListSchema
  crumbs={[
    { name: 'Home', item: 'https://www.bitora.it/' },
    { name: 'Sistemi Aziendali', item: 'https://www.bitora.it/sistemi-aziendali/' },
  ]}
/>

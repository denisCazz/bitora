---
import Layout from '../layouts/Layout.astro';
import { icons } from '../components/Icons';

/* ── Grafica Digitale services ── */
const graficaServices = [
  {
    title: 'Brand Identity Completa',
    desc: 'Logo, palette colori, tipografia e linee guida visive per un brand riconoscibile e coerente su ogni canale.',
    features: ['Logo design', 'Palette colori', 'Font system', 'Brand book'],
    icon: 'gallery',
  },
  {
    title: 'Grafiche per Social',
    desc: 'Post, stories, caroselli, copertine e template coordinati con la tua identità visiva. Pronti per Instagram, Facebook e LinkedIn.',
    features: ['Template post', 'Stories & Reels', 'Caroselli', 'Copertine'],
    icon: 'gallery',
  },
  {
    title: 'Materiale Marketing',
    desc: 'Banner, volantini, biglietti da visita, menù e creatività per campagne pubblicitarie online e offline.',
    features: ['Banner ADS', 'Volantini & flyer', 'Biglietti da visita', 'Menù & cataloghi'],
    icon: 'portfolio',
  },
  {
    title: 'Creatività per Campagne',
    desc: 'Visual ad-hoc per Facebook Ads, Google Ads e campagne sponsorizzate: massima resa, minimo costo per click.',
    features: ['Facebook Ads', 'Google Ads', 'Retargeting visual', 'A/B testing creatività'],
    icon: 'trending',
  },
];

/* ── Social Media services ── */
const socialServices = [
  {
    title: 'Piano Editoriale Strategico',
    desc: 'Calendario mensile con contenuti mirati: ogni post ha un obiettivo preciso (awareness, engagement, conversione).',
    icon: 'portfolio',
  },
  {
    title: 'Gestione Profili Social',
    desc: 'Pubblicazione, ottimizzazione bio/profilo, hashtag strategy e programmazione automatizzata su tutti i canali.',
    icon: 'users',
  },
  {
    title: 'Community Management',
    desc: 'Risposte ai commenti, gestione messaggi, moderazione e costruzione di una community attiva e fidelizzata.',
    icon: 'users',
  },
  {
    title: 'Report & Ottimizzazione',
    desc: 'Analisi mensile delle performance, insight azionabili e miglioramento continuo basato sui dati reali.',
    icon: 'trending',
  },
];

/* ── Process ── */
const processSteps = [
  {
    num: '01',
    title: 'Analisi & Strategia',
    desc: 'Studiamo il tuo brand, i competitor locali e il tuo target. Definiamo obiettivi chiari e misurabili.',
    detail: 'Audit brand • Analisi competitor • Definizione KPI',
  },
  {
    num: '02',
    title: 'Identità & Template',
    desc: 'Creiamo la tua identità visiva e i template riutilizzabili: palette, font, stile grafico coerente.',
    detail: 'Brand identity • Template system • Style guide',
  },
  {
    num: '03',
    title: 'Produzione & Pubblicazione',
    desc: 'Produciamo contenuti di qualità e li pubblichiamo con ritmo costante secondo il piano editoriale.',
    detail: 'Content creation • Scheduling • Multi-piattaforma',
  },
  {
    num: '04',
    title: 'Misura & Scala',
    desc: 'Analizziamo i risultati, scaliamo ciò che funziona e miglioriamo ciò che non performa.',
    detail: 'Report mensile • A/B testing • Ottimizzazione ROI',
  },
];

/* ── FAQ ── */
const faqs = [
  {
    q: 'Quanto costa il servizio di grafica digitale?',
    a: 'Ogni progetto è diverso. Offriamo pacchetti a partire da soluzioni base per startup fino a piani completi per aziende strutturate. Contattaci per un preventivo gratuito e personalizzato.',
  },
  {
    q: 'In quanto tempo vedo i primi risultati sui social?',
    a: 'Con una strategia ben impostata, i primi miglioramenti in termini di engagement e visibilità si notano già dal primo mese. La crescita organica costante richiede 3-6 mesi di lavoro continuativo.',
  },
  {
    q: 'Lavorate solo con aziende di Carmagnola e Torino?',
    a: 'Il nostro focus è Carmagnola, Torino e tutto il Piemonte, ma lavoriamo anche con clienti in tutta Italia. La vicinanza territoriale ci permette di offrire un servizio più personalizzato.',
  },
  {
    q: 'Posso avere solo la grafica senza la gestione social?',
    a: 'Assolutamente sì. Offriamo servizi modulari: puoi scegliere solo grafica digitale, solo gestione social, oppure il pacchetto completo con un risparmio significativo.',
  },
  {
    q: 'Che piattaforme social gestite?',
    a: 'Gestiamo Instagram, Facebook, LinkedIn, TikTok e Google Business Profile. Consigliamo le piattaforme più adatte in base al tuo settore e target di riferimento.',
  },
  {
    q: 'Come funziona il processo di approvazione dei contenuti?',
    a: 'Ogni mese ricevi il piano editoriale in anticipo con tutte le grafiche e i copy per approvazione. Puoi richiedere modifiche illimitate prima della pubblicazione.',
  },
];

/* ── Stats ── */
const stats = [
  { value: '150+', label: 'Grafiche create', sub: 'per clienti locali' },
  { value: '40+', label: 'Brand curati', sub: 'identità visive complete' },
  { value: '98%', label: 'Clienti soddisfatti', sub: 'feedback positivi' },
  { value: '3x', label: 'Engagement medio', sub: 'crescita nei primi 90gg' },
];

/* ── Differentiators ── */
const whyUs = [
  {
    title: 'Team giovane, strategie attuali',
    desc: 'Siamo un team giovane e viviamo i social ogni giorno. Conosciamo i trend, gli algoritmi e le strategie che funzionano adesso, non quelle di 5 anni fa. Parliamo la lingua del mercato digitale.',
  },
  {
    title: 'Focus locale, mentalità globale',
    desc: 'Conosciamo il territorio di Carmagnola e Torino. Applichiamo standard internazionali di design al contesto locale.',
  },
  {
    title: 'Grafica + Strategia = Risultati',
    desc: 'Non facciamo solo "belle immagini". Ogni visual è pensato per un obiettivo: generare click, vendite o riconoscibilità.',
  },
  {
    title: 'Tutto incluso, zero sorprese',
    desc: 'Preventivo chiaro, nessun costo nascosto. Tempi rapidi, revisioni illimitate e un team flessibile che si adatta a te.',
  },
];
---

<Layout
  title="Grafica Digitale & Social Media Management Carmagnola Torino | Bitora"
  description="Servizi professionali di grafica digitale e social media management a Carmagnola, Torino e Piemonte. Brand identity, contenuti social, piano editoriale e campagne per far crescere la tua attività. Preventivo gratuito."
>
  <main class="relative bg-white dark:bg-black text-gray-900 dark:text-white">
    <!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
    <section class="relative px-6 pt-24 pb-20 reveal-on-scroll">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-7">
            <div class="flex flex-wrap items-center gap-3">
              <span
                class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white/80 px-4 py-2 text-sm shadow-sm dark:border-white/10 dark:bg-white/5 text-gray-600 dark:text-gray-400"
              >
                <span class="h-2 w-2 rounded-full bg-gray-900 dark:bg-white"></span>
                Carmagnola &bull; Torino &bull; Piemonte
              </span>
              <span
                class="inline-flex items-center gap-2 rounded-full border border-green-300/60 bg-green-50/80 px-4 py-2 text-sm font-semibold text-green-700 shadow-sm dark:border-green-500/20 dark:bg-green-500/10 dark:text-green-400"
              >
                <span class="relative flex h-2 w-2">
                  <span
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                  ></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                </span>
                Disponibilità limitata
              </span>
            </div>

            <h1
              class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] text-gray-900 dark:text-white"
            >
              Grafica professionale e social media
              <span class="block text-gray-500 dark:text-gray-400">
                che portano risultati concreti.
              </span>
            </h1>

            <p class="text-lg md:text-xl leading-relaxed max-w-xl text-gray-600 dark:text-gray-400">
              Creiamo l'identità visiva del tuo brand e gestiamo i tuoi social con metodo: più
              coerenza, più engagement, più clienti. Il tutto con un team locale dedicato.
            </p>

            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href="/contattaci?topic=grafica"
                class="btn-primary inline-flex justify-center items-center gap-2"
              >
                Richiedi preventivo gratuito
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
                >
              </a>
              <a
                href="/contattaci?topic=social"
                class="btn-secondary inline-flex justify-center items-center gap-2"
              >
                Prenota una call gratuita
              </a>
            </div>

            <!-- Trust signals -->
            <div
              class="flex flex-wrap items-center gap-4 pt-2 text-sm text-gray-600 dark:text-gray-400"
            >
              <span class="inline-flex items-center gap-1.5">
                <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"
                  ><path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"></path></svg
                >
                Preventivo gratuito
              </span>
              <span class="inline-flex items-center gap-1.5">
                <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"
                  ><path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"></path></svg
                >
                Nessun vincolo
              </span>
              <span class="inline-flex items-center gap-1.5">
                <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"
                  ><path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"></path></svg
                >
                Risposta entro 24h
              </span>
            </div>
          </div>

          <!-- Visual preview -->
          <div class="relative">
            <div
              class="relative rounded-[2rem] border border-gray-200 bg-gray-50 p-6 shadow-sm dark:border-white/10 dark:bg-white/5"
            >
              <div class="flex items-center justify-between mb-6">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">
                  Anteprima feed coordinato
                </p>
                <span
                  class="text-xs rounded-full border border-gray-200 bg-white px-3 py-1 dark:border-white/10 dark:bg-white/5 text-gray-600 dark:text-gray-400"
                  >IG &bull; FB &bull; LinkedIn</span
                >
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div
                  class="rounded-2xl border border-gray-200 bg-white p-4 dark:border-white/10 dark:bg-white/5"
                >
                  <div
                    class="h-8 w-8 rounded-xl bg-gray-100 dark:bg-white/10 flex items-center justify-center mb-3"
                    aria-hidden="true"
                  >
                    <span class="text-gray-900 dark:text-white font-bold text-sm">A</span>
                  </div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white">Post brand</p>
                  <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Coordinato & on-brand</p>
                </div>

                <div
                  class="rounded-2xl border border-gray-200 bg-white p-4 dark:border-white/10 dark:bg-white/5"
                >
                  <div
                    class="h-8 w-8 rounded-xl bg-gray-100 dark:bg-white/10 flex items-center justify-center mb-3"
                    aria-hidden="true"
                  >
                    <span class="text-gray-900 dark:text-white font-bold text-sm">S</span>
                  </div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white">Stories</p>
                  <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
                    Template riutilizzabili
                  </p>
                </div>

                <div
                  class="rounded-2xl border border-gray-200 bg-white p-4 dark:border-white/10 dark:bg-white/5"
                >
                  <div
                    class="h-8 w-8 rounded-xl bg-gray-100 dark:bg-white/10 flex items-center justify-center mb-3"
                    aria-hidden="true"
                  >
                    <span class="text-gray-900 dark:text-white font-bold text-sm">C</span>
                  </div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white">Campagna</p>
                  <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Ads che convertono</p>
                </div>

                <div
                  class="rounded-2xl border border-gray-200 bg-white p-4 dark:border-white/10 dark:bg-white/5"
                >
                  <div
                    class="h-8 w-8 rounded-xl bg-gray-100 dark:bg-white/10 flex items-center justify-center mb-3"
                    aria-hidden="true"
                  >
                    <span class="text-gray-900 dark:text-white font-bold text-sm">R</span>
                  </div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white">Report</p>
                  <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
                    Dati e insight mensili
                  </p>
                </div>
              </div>

              <div
                class="mt-5 rounded-2xl border border-gray-200 bg-gray-100 dark:bg-white/5 dark:border-white/10 p-4"
              >
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white">
                      Engagement rate medio
                    </p>
                    <p class="text-xs text-gray-600 dark:text-gray-400">
                      Dopo 90 giorni di gestione
                    </p>
                  </div>
                  <span class="text-2xl font-extrabold text-gray-900 dark:text-white">+180%</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════ SOCIAL PROOF STATS ═══════════════════════════════════ -->
    <section class="relative px-6 py-14 reveal-on-scroll">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {
            stats.map(stat => (
              <div class="rounded-3xl border border-gray-200 bg-gray-50 p-6 text-center shadow-sm dark:border-white/10 dark:bg-white/5">
                <div class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white">
                  {stat.value}
                </div>
                <div class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">
                  {stat.label}
                </div>
                <div class="mt-1 text-xs text-gray-600 dark:text-gray-400">{stat.sub}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════ GRAFICA DIGITALE (FOCUS) ═══════════════════════════════════ -->
    <section class="relative px-6 py-20 reveal-on-scroll" id="grafica-digitale">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
          <div>
            <span
              class="inline-flex items-center gap-2 rounded-full border border-gray-300 dark:border-white/20 bg-gray-100 dark:bg-white/10 px-4 py-1.5 text-sm font-semibold text-gray-600 dark:text-gray-300 mb-4"
            >
              Servizio #1
            </span>
            <h2
              class="text-3xl md:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white"
            >
              Grafica Digitale
              <span
                class="block text-xl md:text-2xl font-semibold mt-2 text-gray-600 dark:text-gray-400"
                >Design che comunica, non solo decora</span
              >
            </h2>
            <p class="mt-4 max-w-2xl text-lg leading-relaxed text-gray-600 dark:text-gray-400">
              Ogni elemento grafico che creiamo ha uno scopo preciso: rafforzare il tuo brand,
              catturare l'attenzione e convertire. Dal logo ai post social, dalla brochure alla
              creatività per le ads.
            </p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {
            graficaServices.map(item => (
              <div class="group relative rounded-3xl border border-gray-200 bg-gray-50 p-8 shadow-sm overflow-hidden dark:border-white/10 dark:bg-white/5 hover:shadow-md transition-all duration-300">
                <div
                  class="absolute inset-x-0 top-0 h-1 bg-gray-300 dark:bg-white/20 opacity-60"
                  aria-hidden="true"
                />
                <div class="relative">
                  <div class="flex items-start justify-between gap-4 mb-5">
                    <div>
                      <h3 class="text-xl font-extrabold tracking-tight text-gray-900 dark:text-white">
                        {item.title}
                      </h3>
                      <p class="mt-2 leading-relaxed text-gray-600 dark:text-gray-400">
                        {item.desc}
                      </p>
                    </div>
                    <div
                      class="shrink-0 h-12 w-12 rounded-2xl border border-gray-200 bg-white flex items-center justify-center shadow-sm dark:border-white/10 dark:bg-white/5 text-gray-500 dark:text-gray-400 [&_svg]:h-5 [&_svg]:w-5"
                      aria-hidden="true"
                      set:html={icons[item.icon]}
                    />
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {item.features.map(f => (
                      <span class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium dark:border-white/10 dark:bg-white/5 text-gray-600 dark:text-gray-400">
                        <svg
                          class="w-3 h-3 text-green-500 shrink-0"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"
                          />
                        </svg>
                        {f}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- CTA intermedia grafica -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/contattaci?topic=grafica"
            class="btn-primary inline-flex justify-center items-center gap-2"
          >
            Richiedi un preventivo per la grafica
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
            >
          </a>
          <a href="/lavori" class="btn-secondary inline-flex justify-center items-center gap-2">
            Guarda i nostri lavori
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════ SOCIAL MEDIA MANAGEMENT ═══════════════════════════════════ -->
    <section class="relative px-6 py-20 reveal-on-scroll" id="social-media">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-[1fr,1.1fr] gap-12 items-start">
          <!-- Left: Info -->
          <div>
            <span
              class="inline-flex items-center gap-2 rounded-full border border-gray-300 dark:border-white/20 bg-gray-100 dark:bg-white/10 px-4 py-1.5 text-sm font-semibold text-gray-600 dark:text-gray-300 mb-4"
            >
              Servizio #2
            </span>
            <h2
              class="text-3xl md:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white"
            >
              Social Media Management
              <span
                class="block text-xl md:text-2xl font-semibold mt-2 text-gray-600 dark:text-gray-400"
                >Strategia, contenuti e crescita misurabile</span
              >
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
              Non basta pubblicare. Serve un piano, una strategia e la costanza per costruire una
              presenza social che genera fiducia e clienti. Noi ci occupiamo di tutto.
            </p>

            <!-- Piattaforme -->
            <div class="mt-8">
              <p class="text-sm font-semibold mb-3 text-gray-900 dark:text-white">
                Piattaforme che gestiamo
              </p>
              <div class="flex flex-wrap gap-2">
                {
                  ['Instagram', 'Facebook', 'LinkedIn', 'TikTok', 'Google Business'].map(p => (
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium dark:border-white/10 dark:bg-white/5 text-gray-900 dark:text-white">
                      {p}
                    </span>
                  ))
                }
              </div>
            </div>

            <div class="mt-8">
              <a
                href="/contattaci?topic=social"
                class="btn-primary inline-flex justify-center items-center gap-2"
              >
                Affidaci i tuoi social
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
                >
              </a>
            </div>
          </div>

          <!-- Right: Service cards -->
          <div class="space-y-4">
            {
              socialServices.map((item, idx) => (
                <div class="group relative rounded-3xl border border-gray-200 bg-gray-50 p-7 shadow-sm overflow-hidden dark:border-white/10 dark:bg-white/5 hover:shadow-md transition-all duration-300">
                  <div
                    class="absolute inset-x-0 top-0 h-0.5 bg-gray-300 dark:bg-white/20 opacity-40"
                    aria-hidden="true"
                  />
                  <div class="flex items-start gap-5">
                    <div
                      class="shrink-0 h-11 w-11 rounded-2xl border border-gray-200 bg-white flex items-center justify-center shadow-sm dark:border-white/10 dark:bg-white/5 text-gray-500 dark:text-gray-400 [&_svg]:h-5 [&_svg]:w-5"
                      aria-hidden="true"
                      set:html={icons[item.icon]}
                    />
                    <div>
                      <h3 class="text-lg font-extrabold tracking-tight text-gray-900 dark:text-white">
                        {item.title}
                      </h3>
                      <p class="mt-2 leading-relaxed text-sm text-gray-600 dark:text-gray-400">
                        {item.desc}
                      </p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════ PERCHÉ SCEGLIERCI ═══════════════════════════════════ -->
    <section class="relative px-6 py-20 reveal-on-scroll">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2
            class="text-3xl md:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white"
          >
            Perché scegliere Bitora
          </h2>

---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { testimonials } from '../data/testimonials';
import ClientLogos from '../components/ClientLogos.astro';
---

<Layout
  title="Bitora | Sistemi Digitali su Misura per Aziende e PMI | Piemonte"
  description="Sistemi digitali su misura per la tua azienda. Gestionali, CRM, CMMS, siti web ed e-commerce. Ti seguiamo dall'inizio alla fine. Sede in Piemonte, serviamo tutta Italia."
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <!-- Hero - Pulito e professionale -->
    <section
      class="relative min-h-[90vh] flex flex-col justify-center px-6 md:px-12 lg:px-20 overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-gradient-to-b from-gray-50 via-white to-white dark:from-black dark:via-black dark:to-black/95"
      >
      </div>
      <div class="absolute inset-0 opacity-30">
        <div
          class="absolute top-1/4 -left-32 w-96 h-96 rounded-full bg-gray-200 dark:bg-white/10 blur-[120px]"
        >
        </div>
        <div
          class="absolute bottom-1/4 -right-32 w-80 h-80 rounded-full bg-gray-100 dark:bg-white/5 blur-[100px]"
        >
        </div>
      </div>

      <div class="relative z-10 max-w-4xl">
        <p
          class="text-sm font-medium tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-6"
        >
          Sede in Piemonte · Serviamo tutta Italia
        </p>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] mb-6">
          Sistemi digitali<br />
          <span class="text-gray-900 dark:text-white">su misura per la tua azienda.</span>
        </h1>
        <p
          class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed mb-10"
        >
          Gestionali, CRM, CMMS, siti web ed e-commerce. Ti seguiamo dall'analisi al deploy.
          Sviluppo su misura per PMI e aziende.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contattaci"
            class="btn-primary group min-w-[200px] flex items-center justify-center gap-2"
          >
            Richiedi consulenza
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
          <a
            href="/soluzioni"
            class="btn-secondary min-w-[200px] flex items-center justify-center gap-2"
          >
            Scopri le soluzioni
          </a>
        </div>
      </div>
    </section>

    <!-- Client Logos -->
    <section
      class="border-y border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02] py-12"
    >
      <ClientLogos />
    </section>

    <!-- Stats con barre animate -->
    <section
      class="py-16 md:py-20 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          {
            [
              { value: '50+', label: 'Progetti realizzati', bar: 95 },
              { value: '100%', label: 'Clienti soddisfatti', bar: 100 },
              { value: '24h', label: 'Tempo di risposta', bar: 88 },
              { value: 'Italia', label: 'Copertura territoriale', bar: 100 },
            ].map((stat, i) => (
              <div class="text-center reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
                <p class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">
                  {stat.value}
                </p>
                <p class="text-sm text-gray-500 uppercase tracking-wider mb-4">{stat.label}</p>
                <div class="h-1.5 bg-gray-200 dark:bg-white/10 rounded-full overflow-hidden max-w-[120px] mx-auto">
                  <div
                    class="bar-fill h-full bg-gray-900 dark:bg-white rounded-full transition-all duration-1000 ease-out"
                    data-width={stat.bar}
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- E-commerce e Tessere NFC - In evidenza -->
    <section
      class="py-20 md:py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <div class="mb-12">
          <p
            class="text-sm font-medium tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-3"
          >
            Puntiamo su
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            E-commerce e Tessere NFC
          </h2>
          <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl">
            Due servizi in forte crescita. Li portiamo avanti con passione.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <a
            href="/e-commerce-piemonte"
            class="group p-8 md:p-10 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border-2 border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 flex flex-col justify-between min-h-[280px] reveal-on-scroll"
          >
            <div>
              <span class="text-4xl mb-4 block">🛒</span>
              <h3
                class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
              >
                E-commerce
              </h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                Negozi online chiavi in mano per vendere in tutta Italia. WooCommerce, Shopify,
                sviluppo custom. Pagamenti, spedizioni, supporto incluso.
              </p>
            </div>
            <span
              class="mt-6 inline-flex items-center gap-2 text-gray-900 dark:text-white font-medium group-hover:gap-3 transition-all"
            >
              Scopri l'e-commerce <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
              >
            </span>
          </a>

          <a
            href="/nfc-ecosystem"
            class="group p-8 md:p-10 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border-2 border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 flex flex-col justify-between min-h-[280px] reveal-on-scroll"
            style="transition-delay: 100ms"
          >
            <div>
              <span class="text-4xl mb-4 block">💳</span>
              <h3
                class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
              >
                Tessere NFC
              </h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                Biglietti da visita intelligenti. Un tap per recensioni Google, contatti, menu
                digitali. Pellicola intercambiabile, aggiornamenti illimitati.
              </p>
            </div>
            <span
              class="mt-6 inline-flex items-center gap-2 text-gray-900 dark:text-white font-medium group-hover:gap-3 transition-all"
            >
              Scopri le tessere NFC <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
              >
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Soluzioni - Griglia pulita -->
    <section id="servizi" class="py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16">
          <p
            class="text-sm font-medium tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-3"
          >
            Le nostre soluzioni
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Cosa realizziamo
          </h2>
          <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl">
            Sistemi digitali su misura. Dall'analisi al deploy.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <a
            href="/sistemi-aziendali"
            class="group p-8 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 lg:col-span-2 lg:row-span-2 flex flex-col justify-between min-h-[280px] reveal-on-scroll"
          >
            <div>
              <span class="text-3xl mb-4 block">⚙️</span>
              <h3
                class="text-2xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
              >
                Sistemi Aziendali su Misura
              </h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                Gestionali, CRM, CMMS e software custom. Sviluppati sulle tue esigenze. Ti seguiamo
                dall'analisi al deploy.
              </p>
            </div>
            <span
              class="mt-6 inline-flex items-center gap-2 text-gray-900 dark:text-white font-medium group-hover:gap-3 transition-all"
            >
              Scopri di più <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
              >
            </span>
          </a>

          <a
            href="/siti-web-professionali"
            class="group p-6 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 reveal-on-scroll"
            style="transition-delay: 100ms"
          >
            <span class="text-2xl mb-3 block">🌐</span>
            <h3
              class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
            >
              Siti Web
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">
              Siti professionali, veloci e ottimizzati.
            </p>
          </a>

          <a
            href="/bitora-crm"
            class="group p-6 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 reveal-on-scroll"
            style="transition-delay: 150ms"
          >
            <span class="text-2xl mb-3 block">📊</span>
            <h3
              class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
            >
              Gestionali & CRM
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">
              Clienti, lead, pipeline sotto controllo.
            </p>
          </a>

          <a
            href="/cmms"
            class="group p-6 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 reveal-on-scroll"
            style="transition-delay: 200ms"
          >
            <span class="text-2xl mb-3 block">🔧</span>
            <h3
              class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
            >
              CMMS
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">
              Software gestione manutenzione per tecnici.
            </p>
          </a>

          <a
            href="/grafica-digitale-social-media"
            class="group p-6 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 reveal-on-scroll"
            style="transition-delay: 250ms"
          >
            <span class="text-2xl mb-3 block">🎨</span>
            <h3
              class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
            >
              Grafica & Social
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">
              Brand identity e contenuti social.
            </p>
          </a>

          <a
            href="/e-commerce-piemonte"
            class="group p-6 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 reveal-on-scroll"
            style="transition-delay: 300ms"
          >
            <span class="text-2xl mb-3 block">🛒</span>
            <h3
              class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
            >
              E-commerce
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">
              Negozi online per vendere in tutta Italia.
            </p>
          </a>

          <a
            href="/nfc-ecosystem"
            class="group p-6 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 hover:border-gray-400 dark:hover:border-white/40 transition-all duration-300 reveal-on-scroll"
            style="transition-delay: 350ms"
          >
            <span class="text-2xl mb-3 block">💳</span>
            <h3
              class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors"
            >
              Tessere NFC
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">
              Biglietti da visita intelligenti.
            </p>
          </a>
        </div>

        <div class="mt-12 text-center">
          <a href="/soluzioni" class="btn-secondary inline-flex items-center gap-2">
            Vedi tutte le soluzioni
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
        </div>
      </div>
    </section>

    <!-- Perché Bitora - Due colonne -->
    <section
      class="py-24 px-6 md:px-12 lg:px-20 bg-gray-50 dark:bg-white/[0.02] border-y border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <p
              class="text-sm font-medium tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-4"
            >
              Perché scegliere Bitora
            </p>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-10">
              Ti seguiamo<br />dall'inizio alla fine.
            </h2>

            <div class="space-y-6">
              {
                [
                  {
                    title: 'Consulenza in 24h',
                    desc: 'Risposta rapida e analisi delle tue esigenze.',
                  },
                  {
                    title: 'Soluzioni su misura',
                    desc: 'Nessun pacchetto preconfezionato. Solo ciò che serve.',
                  },
                  {
                    title: 'Sede in Piemonte',
                    desc: 'Siamo a Carmagnola. Serviamo clienti in tutta Italia.',
                  },
                  { title: 'Risultati misurabili', desc: 'KPI, report e ottimizzazione continua.' },
                ].map(item => (
                  <div class="flex gap-4 reveal-on-scroll">
                    <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-gray-100 dark:bg-white/10 border border-gray-200 dark:border-white/20 flex items-center justify-center">
                      <svg
                        class="w-5 h-5 text-gray-900 dark:text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">
                        {item.title}
                      </h3>
                      <p class="text-gray-600 dark:text-gray-400 text-sm">{item.desc}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="relative reveal-on-scroll" style="transition-delay: 200ms">
            <div
              class="p-8 md:p-10 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10"
            >
              <div class="flex items-center gap-3 mb-6">
                <div class="flex -space-x-2">
                  <img
                    src="/mistral.jpg"
                    alt=""
                    class="w-10 h-10 rounded-full border-2 border-white dark:border-black object-cover"
                  />
                  <img
                    src="/sartoria_kristina.png"
                    alt=""
                    class="w-10 h-10 rounded-full border-2 border-white dark:border-black object-cover"
                  />
                  <img
                    src="/bitora.jpg"
                    alt=""
                    class="w-10 h-10 rounded-full border-2 border-white dark:border-black object-cover"
                  />
                </div>
                <div>
                  <div class="flex gap-0.5">
                    {
                      [1, 2, 3, 4, 5].map(() => (
                        <svg
                          class="w-4 h-4 text-yellow-400"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))
                    }
                  </div>
                  <p class="text-xs text-gray-500">+50 clienti soddisfatti</p>
                </div>
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
                Richiedi una consulenza
              </h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm mb-6">
                Ti rispondiamo entro 24 ore con una proposta su misura.
              </p>
              <a
                href="/contattaci"
                class="btn-primary w-full flex items-center justify-center gap-2"
              >
                Richiedi consulenza gratuita
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                >
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-24 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto">
        <div class="mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">
            Cosa dicono i nostri clienti
          </h2>
          <p class="text-gray-600 dark:text-gray-400">Aziende che hanno scelto Bitora</p>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          {
            testimonials.slice(0, 4).map((t, i) => (
              <div
                class="p-8 rounded-2xl bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 reveal-on-scroll"
                style={`transition-delay: ${i * 100}ms`}
              >
                <div class="flex items-center gap-4 mb-4">
                  <img
                    src={t.image}
                    alt={t.company}
                    class="h-12 w-12 rounded-full object-cover bg-gray-100 dark:bg-white/10"
                    loading="lazy"
                  />
                  <div>
                    <p class="text-gray-900 dark:text-white font-medium">{t.company}</p>
                    <p class="text-xs text-gray-500 uppercase tracking-wider">
                      {t.role ?? 'Partner'}
                    </p>
                  </div>
                </div>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed">"{t.quote}"</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA finale -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-t border-gray-200 dark:border-white/5">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          Pronto a digitalizzare i tuoi processi?
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-10">
          Consulenza gratuita. Raccontaci le tue esigenze.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contattaci"
            class="btn-primary group min-w-[200px] flex items-center justify-center gap-2"
          >
            Richiedi consulenza
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
          <a
            href="https://wa.me/393514979670?text=Ciao%2C%20vorrei%20informazioni%20sui%20vostri%20servizi.%20Ho%20visitato%20bitora.it"
            class="btn-secondary min-w-[200px] flex items-center justify-center gap-2"
          >

---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { testimonials } from '../data/testimonials';
import { caseStudies } from '../data/caseStudies';
import ClientLogos from '../components/ClientLogos.astro';
import VideoHero from '../components/VideoHero.astro';
import StatCounter from '../components/StatCounter.astro';
import TrustBadges from '../components/TrustBadges.astro';
import FAQ from '../components/FAQ.astro';
import FAQPageSchema from '../components/schema/FAQPage.astro';
import ReviewsSchema from '../components/schema/Reviews.astro';

const featured = caseStudies.filter(c => c.featured).slice(0, 3);
---

<Layout
  title="Bitora | Sistemi Digitali su Misura per Aziende e PMI | Piemonte"
  description="Sistemi digitali su misura: CRM, gestionali, CMMS, siti web ed e-commerce. Progettiamo, sviluppiamo, ottimizziamo. Sede in Piemonte, serviamo tutta Italia."
  image="/social-media-hero.svg"
>
  <main class="bg-white dark:bg-black text-gray-900 dark:text-white overflow-x-hidden">
    <VideoHero
      variant="background"
      eyebrow="Sede in Piemonte · Serviamo tutta Italia"
      title="Sistemi digitali"
      highlight="che convertono."
      description="CRM, gestionali, CMMS, siti web ed e-commerce. Dal concept al deploy, con metodo e risultati misurabili."
      primaryCta={{ label: 'Richiedi consulenza', href: '/contattaci' }}
      secondaryCta={{ label: 'Vedi i progetti', href: '/lavori' }}
      posterSrc="/social-media-hero.svg"
      videoSrc="https://videos.pexels.com/video-files/3129671/3129671-uhd_2560_1440_30fps.mp4"
      videoLabel="Bitora al lavoro su progetti digitali"
    />

    <!-- Logos clienti -->
    <section
      class="border-y border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02] py-10"
    >
      <ClientLogos />
    </section>

    <!-- Stats -->
    <section
      class="py-16 md:py-20 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <StatCounter
          items={[
            { label: 'Progetti realizzati', value: '50+', number: 50, suffix: '+' },
            { label: 'Clienti soddisfatti', value: '100%', number: 100, suffix: '%' },
            { label: 'Tempo di risposta', value: '24h', number: 24, suffix: 'h' },
            { label: 'Copertura', value: 'Italia' },
          ]}
        />
      </div>
    </section>

    <!-- Soluzioni: 4 servizi con foto -->
    <section
      id="servizi"
      class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto">
        <p
          class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
        >
          Soluzioni
        </p>
        <h2
          class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white max-w-3xl"
        >
          Tutto ciò che serve per vendere e gestire online.
        </h2>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-2xl">
          Quattro pilastri. Uno stack coerente. Risultati misurabili.
        </p>

        <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-12 gap-6">
          {
            [
              {
                href: '/e-commerce-piemonte',
                title: 'E-commerce',
                desc: 'WooCommerce, Shopify o custom. Checkout veloce, tracking, SEO e supporto.',
                img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1600&q=80',
                span: 'lg:col-span-7',
                cta: 'Scopri e-commerce',
              },
              {
                href: '/nfc-ecosystem',
                title: 'Tessere NFC',
                desc: 'Un tap: recensioni Google, contatti, menu. Programmazione inclusa.',
                img: '/nfc.png',
                span: 'lg:col-span-5',
                cta: 'Scopri NFC',
              },
              {
                href: '/siti-web-professionali',
                title: 'Siti web professionali',
                desc: "Veloci, accessibili, indicizzati. Conversione prima dell'estetica.",
                img: 'https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?auto=format&fit=crop&w=1600&q=80',
                span: 'lg:col-span-5',
                cta: 'Scopri siti web',
              },
              {
                href: '/sistemi-aziendali',
                title: 'Sistemi aziendali',
                desc: 'CRM, CMMS, gestionali. Automatizziamo il lavoro manuale.',
                img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1600&q=80',
                span: 'lg:col-span-7',
                cta: 'Scopri sistemi',
              },
            ].map((s, i) => (
              <a
                href={s.href}
                class={`group block rounded-3xl overflow-hidden border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel hover-lift reveal-on-scroll ${s.span}`}
                style={`transition-delay:${i * 80}ms`}
              >
                <div class="relative media-frame">
                  <img
                    src={s.img}
                    alt={s.title}
                    class="w-full h-full object-cover aspect-[16/10] group-hover:scale-[1.04] transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent" />
                  <div class="absolute bottom-5 left-5 right-5">
                    <div class="hero-panel rounded-2xl px-5 py-4">
                      <p class="text-white font-bold text-xl">{s.title}</p>
                      <p class="text-white/85 text-sm mt-1">{s.desc}</p>
                    </div>
                  </div>
                </div>
                <div class="px-6 py-5 inline-flex items-center gap-2 font-semibold text-[color:var(--brand-cta)]">
                  {s.cta}
                  <svg
                    class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Metodo: storytelling sticky + parallax -->
    <section
      class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Metodo
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Meno monotonia.<br />Più ritmo.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            Alterniamo testo, immagini e micro-effetti per tenere l'attenzione alta. Sempre leggeri,
            sempre misurati.
          </p>

          <div class="mt-10 media-frame relative overflow-hidden">
            <img
              src="/bitora.jpg"
              alt="Workshop e pianificazione progetto digitale"
              class="w-full h-full object-cover aspect-video"
              loading="lazy"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-transparent"
            >
            </div>
            <div class="absolute bottom-5 left-5 right-5">
              <div class="hero-panel rounded-2xl px-5 py-4">
                <p class="text-white font-semibold">Roadmap + KPI</p>
                <p class="text-white/85 text-sm mt-1">
                  Più lead. Più vendite. Meno lavoro manuale. Misurabile.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 space-y-6">
          {
            [
              {
                n: '01',
                title: 'Analisi & Strategia',
                desc: 'Obiettivi, target, keyword, funnel. Definiamo cosa misurare e cosa tagliare.',
              },
              {
                n: '02',
                title: 'UI/UX & Copy',
                desc: 'Struttura pagina, CTA, trust. Prototipo rapido e iterazioni veloci.',
              },
              {
                n: '03',
                title: 'Sviluppo & Performance',
                desc: 'Mobile-first, LCP/CLS controllati. SEO tecnico e tracking.',
              },
              {
                n: '04',
                title: 'Deploy & Ottimizzazione',
                desc: 'Monitoraggio, miglioramenti continui, supporto post-lancio.',
              },
            ].map((s, i) => (
              <div
                class="rounded-3xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-7 hover-lift reveal-on-scroll"
                style={`transition-delay:${i * 90}ms`}
              >
                <div class="flex items-start justify-between gap-6">
                  <div>
                    <p class="text-xs font-bold tracking-widest text-[color:var(--brand-cta)]">
                      {s.n}
                    </p>
                    <h3 class="mt-2 text-xl font-extrabold tracking-tight text-slate-950 dark:text-white">
                      {s.title}
                    </h3>
                    <p class="mt-3 text-slate-600 dark:text-slate-300 leading-relaxed">{s.desc}</p>
                  </div>
                  <div class="w-12 h-12 rounded-2xl bg-[color:var(--brand-cta)]/10 text-[color:var(--brand-cta)] flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.8"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Trust + perché Bitora -->
    <section class="py-20 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Perché Bitora
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Sviluppo su misura,<br />con numeri chiari.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
            Niente pacchetti preconfezionati. Costruiamo prodotti digitali che semplificano
            processi, portano lead e aumentano vendite.
          </p>
        </div>
        <div class="lg:col-span-7">
          <TrustBadges />
        </div>
      </div>
    </section>

    <!-- Progetti in evidenza -->
    <section
      class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]"
    >
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between gap-6 mb-12 flex-wrap">
          <div>
            <p
              class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
            >
              Case study
            </p>
            <h2
              class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
            >
              Progetti reali.<br />Risultati misurabili.
            </h2>
          </div>
          <a href="/lavori" class="link-brand inline-flex items-center gap-2 font-semibold">
            Tutti i progetti
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {
            featured.map((p, i) => (
              <a
                href={`/progetti/${p.slug}`}
                class="group block rounded-3xl overflow-hidden border border-gray-200 dark:border-white/10 bg-white dark:bg-white/[0.03] hover-lift reveal-on-scroll"
                style={`transition-delay:${i * 80}ms`}
              >
                <div class="relative">
                  <img
                    src={p.imageUrl}
                    alt={p.title}
                    class="w-full h-full object-cover aspect-[4/3] group-hover:scale-[1.04] transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
                </div>
                <div class="p-5">
                  <p class="text-xs text-slate-500 uppercase tracking-wider">
                    {p.category} · {p.location}
                  </p>
                  <h3 class="mt-1 text-lg font-extrabold tracking-tight text-slate-950 dark:text-white group-hover:text-[color:var(--brand-cta)] transition-colors">
                    {p.title}
                  </h3>
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {p.metricsPreview.slice(0, 2).map(m => (
                      <span class="text-[11px] text-slate-600 dark:text-slate-300 border border-gray-200 dark:border-white/10 px-2 py-0.5 rounded-full">
                        {m}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-24 px-6 md:px-12 lg:px-20 border-b border-gray-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="mb-12">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            Recensioni
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Cosa dicono i clienti.
          </h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {
            testimonials.slice(0, 6).map((t, i) => (
              <div
                class="rounded-3xl border border-gray-200 dark:border-white/10 bg-white/70 dark:bg-white/[0.03] glass-panel p-7 hover-lift reveal-on-scroll"
                style={`transition-delay:${i * 80}ms`}
              >
                <div class="flex items-center gap-4">
                  <img
                    src={t.image}
                    alt={t.company}
                    class="h-12 w-12 rounded-full object-cover bg-gray-100 dark:bg-white/10"
                    loading="lazy"
                  />
                  <div>
                    <p class="text-slate-950 dark:text-white font-semibold">{t.company}</p>
                    <p class="text-xs text-slate-500 uppercase tracking-wider">
                      {t.role ?? 'Partner'}
                    </p>
                  </div>
                  <div class="ml-auto text-[color:var(--brand-cta)] text-sm font-bold tracking-widest">
                    {'★'.repeat(t.rating ?? 5)}
                  </div>
                </div>
                <p class="mt-4 text-slate-700 dark:text-slate-300 leading-relaxed">“{t.quote}”</p>
                {t.results ? (
                  <p class="mt-4 text-sm font-semibold text-[color:var(--brand-cta)]">
                    {t.results}
                  </p>
                ) : null}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section
      class="py-24 px-6 md:px-12 lg:px-20 bg-gray-50 dark:bg-white/[0.02] border-b border-gray-200 dark:border-white/5"
    >
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <p
            class="text-sm font-semibold tracking-widest uppercase text-slate-500 dark:text-slate-400 mb-3"
          >
            FAQ
          </p>
          <h2
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-950 dark:text-white"
          >
            Domande frequenti.
          </h2>
          <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
            Risposte rapide per aiutarti a decidere.
          </p>
        </div>
        <div class="lg:col-span-7">
          <FAQ
            items={[
              {
                question: 'Quanto costa un sito web professionale?',
                answer:
                  'Dipende da pagine, contenuti e integrazioni. Partiamo da un audit e ti diamo un preventivo chiaro e modulare.',
              },
              {
                question: 'In quanto tempo consegnate?',
                answer:
                  'Per una landing efficace 7–14 giorni. Per un sito completo 2–6 settimane, in base a contenuti e revisioni.',
              },
              {
                question: 'Fate SEO e ottimizzazione per Google (locale)?',
                answer:
                  'Sì: struttura H1/H2, performance, schema, sitemap e contenuti orientati a ricerche locali (Piemonte/Torino).',
              },
              {
                question: 'Le tessere NFC richiedono abbonamento?',
                answer:
                  'No: programmazione inclusa e aggiornamenti illimitati. Nessun canone mensile.',
              },
              {
                question: 'Posso collegare NFC a recensioni Google e contatti?',
                answer:
                  'Sì: un tap apre recensioni Google, WhatsApp, menu digitale, sito e link personalizzati.',
              },
              {
                question: 'E-commerce: WooCommerce o Shopify?',
                answer:
                  'Dipende da catalogo, gestione e budget. Ti consigliamo la piattaforma più adatta e ti seguiamo fino al lancio.',
              },
              {
                question: 'Gestionali/CRM: si integra con i miei strumenti?',
                answer:
                  'Sì: integriamo email, WhatsApp, fogli, API e processi interni. Riduciamo lavoro manuale.',
              },
              {
                question: 'Offrite supporto dopo il lancio?',
                answer:
                  'Sì: monitoraggio, ottimizzazioni e interventi rapidi. Il sito non finisce con la pubblicazione.',
              },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- CTA finale rimossa: evitiamo duplicati -->
  </main>
</Layout>

<FAQPageSchema
  items={[
    {
      question: 'Quanto costa un sito web professionale?',
      answer:
        'Dipende da pagine, contenuti e integrazioni. Partiamo da un audit e ti diamo un preventivo chiaro e modulare.',
    },
    {
      question: 'In quanto tempo consegnate?',
      answer:
        'Per una landing efficace 7–14 giorni. Per un sito completo 2–6 settimane, in base a contenuti e revisioni.',
    },
    {
      question: 'Fate SEO e ottimizzazione per Google (locale)?',
      answer:
        'Sì: struttura H1/H2, performance, schema, sitemap e contenuti orientati a ricerche locali (Piemonte/Torino).',
    },
    {
      question: 'Le tessere NFC richiedono abbonamento?',
      answer: 'No: programmazione inclusa e aggiornamenti illimitati. Nessun canone mensile.',
    },
    {
      question: 'Posso collegare NFC a recensioni Google e contatti?',
      answer:
        'Sì: un tap apre recensioni Google, WhatsApp, menu digitale, sito e link personalizzati.',
    },
    {
      question: 'E-commerce: WooCommerce o Shopify?',
      answer:
        'Dipende da catalogo, gestione e budget. Ti consigliamo la piattaforma più adatta e ti seguiamo fino al lancio.',
    },
    {

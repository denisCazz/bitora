---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Bitora | Siti Web e Servizi Digitali su Misura | Piemonte"
  description="Siti web, e-commerce e servizi digitali su misura per la tua azienda. Gestionali, CRM, CMMS e tessere NFC. Ti seguiamo dall'inizio alla fine. Sede a Carmagnola, Piemonte."
>
  <main class="bg-black text-white overflow-x-hidden">

    <!-- HERO -->
    <section class="relative h-screen min-h-[640px] flex flex-col justify-end">
      <div class="absolute inset-0">
        <img
          src="/world-tech.jpg"
          alt="Sistemi digitali su misura per aziende"
          class="w-full h-full object-cover"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-black/10"></div>
      </div>
      <div class="relative z-10 px-8 md:px-16 lg:px-24 pb-20 md:pb-28 hero-text">
        <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-4">
          Sede in Piemonte · Serviamo tutta Italia
        </p>
        <h1 class="text-5xl md:text-6xl lg:text-[5.5rem] font-bold leading-[1.04] tracking-tight mb-5 max-w-3xl">
          Sistemi digitali<br />su misura.
        </h1>
        <p class="text-base md:text-lg text-white/70 mb-9 max-w-lg leading-relaxed">
          Gestionali, siti web, e-commerce e tessere NFC.<br class="hidden md:block" />
          Ti seguiamo dall'analisi al deploy.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/contattaci" class="sl-btn-primary">Richiedi consulenza</a>
          <a href="/servizi" class="sl-btn-secondary">Scopri i servizi</a>
        </div>
      </div>
    </section>

    <!-- SITI WEB & E-COMMERCE -->
    <section class="relative min-h-screen flex flex-col md:flex-row overflow-hidden">
      <!-- mobile: immagine come sfondo a bassa opacità -->
      <div class="absolute inset-0 md:hidden">
        <img src="/programming.jpg" alt="Sviluppo siti web su misura per aziende" class="w-full h-full object-cover opacity-15" loading="lazy" decoding="async" />
      </div>
      <!-- pannello sinistro: testo su nero pieno -->
      <div class="relative z-10 flex flex-col justify-center bg-black md:w-1/2 px-8 md:px-14 lg:px-20 py-32 md:py-0 min-h-screen" data-reveal-left>
        <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-6">Siti Web &amp; E-commerce</p>
        <h2 class="text-5xl lg:text-7xl font-bold leading-[1.02] tracking-tight mb-6">
          Il tuo sito.<br />La tua<br />vetrina.&nbsp;→
        </h2>
        <p class="text-base md:text-lg text-white/70 mb-10 max-w-sm leading-relaxed">
          Veloci, SEO-ottimizzati e costruiti per convertire. Sviluppati su misura, codice proprietario.
        </p>
        <a href="/servizi" class="sl-btn-secondary self-start">Scopri i servizi</a>
      </div>
      <!-- pannello destro: immagine (solo desktop) -->
      <div class="hidden md:block md:w-1/2 relative overflow-hidden" data-reveal-right>
        <img
          src="/programming.jpg"
          alt="Siti web professionali ed e-commerce"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-y-0 left-0 w-28 bg-gradient-to-r from-black to-transparent pointer-events-none"></div>
        <div class="absolute bottom-0 inset-x-0 h-52 bg-gradient-to-t from-black to-transparent pointer-events-none"></div>
      </div>
    </section>

    <!-- TESSERE NFC -->
    <section class="bg-black py-24 md:py-36">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24">
        <div class="grid md:grid-cols-2 gap-12 lg:gap-24 items-center">
          <div data-reveal-left>
            <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-6">Tessere NFC</p>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight mb-6">
              Un tap.<br />Tutto connesso.
            </h2>
            <p class="text-base md:text-lg text-white/70 mb-8 leading-relaxed">
              Biglietti da visita intelligenti. Recensioni Google, menu digitali, contatti. Un solo tocco.
            </p>
            <div class="flex flex-wrap gap-2 mb-10">
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Biglietti da visita</span>
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Menu digitali</span>
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Recensioni Google</span>
              <span class="px-4 py-1.5 rounded-full border border-white/20 text-sm text-white/60">Prog. illimitata</span>
            </div>
            <a href="/servizi#nfc" class="sl-btn-secondary">Scopri le tessere NFC</a>
          </div>
          <div class="relative rounded-2xl overflow-hidden aspect-[4/3] border border-white/10" data-reveal-right>
            <img
              src="/nfc.jpg"
              alt="Tessere NFC intelligenti in uso"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- SISTEMI AZIENDALI -->
    <section class="relative min-h-screen flex items-center justify-center py-24">
      <div class="absolute inset-0">
        <img
          src="/customers.jpg"
          alt="Gestionali CRM e sistemi aziendali su misura"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-black/60"></div>
        <div class="absolute top-0 inset-x-0 h-40 bg-gradient-to-b from-black to-transparent pointer-events-none"></div>
        <div class="absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-black to-transparent pointer-events-none"></div>
      </div>
      <div class="relative z-10 w-full max-w-2xl mx-6 md:mx-auto text-center backdrop-blur-xl bg-white/[0.07] border border-white/15 rounded-3xl px-8 md:px-16 py-14" data-reveal>
        <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-6">Sistemi Aziendali</p>
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.02] tracking-tight mb-6">
          Automatizza.<br />Controlla.<br />Scala.
        </h2>
        <p class="text-base md:text-lg text-white/70 mb-10 max-w-md mx-auto leading-relaxed">
          Gestionali, CRM, CMMS e software custom. Dall'analisi dei processi al deploy in produzione.
        </p>
        <a href="/servizi#sistemi" class="sl-btn-secondary">Scopri i sistemi</a>
      </div>
    </section>

    <!-- AI -->
    <section class="relative bg-black py-32 md:py-44 overflow-hidden text-center">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-indigo-600/15 blur-[120px]"></div>
      </div>
      <div class="relative z-10 px-8 max-w-3xl mx-auto" data-reveal>
        <p class="text-xs font-semibold tracking-[0.25em] text-indigo-400/70 uppercase mb-6">Intelligenza Artificiale</p>
        <h2 class="text-5xl md:text-6xl lg:text-[5rem] font-bold leading-[1.04] tracking-tight mb-6">
          Il tuo assistente AI.<br />Già operativo.
        </h2>
        <p class="text-base md:text-lg text-white/65 mb-12 max-w-md mx-auto leading-relaxed">
          Automazioni, chatbot e strumenti AI integrati nei tuoi processi. Su misura, non soluzioni preconfezionate.
        </p>
        <a href="https://ai.bitora.it/" class="sl-btn-primary" target="_blank" rel="noopener">Scopri Bitora AI →</a>
      </div>
    </section>

    <!-- PIEMONTE -->
    <section class="relative h-[90vh] min-h-[580px] flex flex-col items-center justify-center text-center">
      <div class="absolute inset-0">
        <img
          src="/italy.jpg"
          alt="Da Carmagnola a tutta Italia"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-black/55"></div>
        <div class="absolute top-0 inset-x-0 h-40 bg-gradient-to-b from-black to-transparent pointer-events-none"></div>
        <div class="absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-black to-transparent pointer-events-none"></div>
      </div>
      <div class="relative z-10 px-8 max-w-3xl" data-reveal>
        <p class="text-xs font-semibold tracking-[0.25em] text-white/50 uppercase mb-8">Radicati in Piemonte</p>
        <h2 class="text-5xl md:text-6xl lg:text-[5rem] font-bold leading-[1.04] tracking-tight mb-6">
          Da Carmagnola<br />a tutta Italia.
        </h2>
        <p class="text-base md:text-lg text-white/70 mb-10 max-w-md mx-auto leading-relaxed">
          Sede a Carmagnola, Provincia di Torino. Serviamo PMI e aziende in tutta Italia.
        </p>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/45">
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-white/35 inline-block"></span>Carmagnola</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-white/35 inline-block"></span>Torino</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-white/35 inline-block"></span>Piemonte</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-white/35 inline-block"></span>Tutta Italia</span>
        </div>
      </div>
    </section>

    <!-- CTA FINALE -->
    <section class="bg-black py-28 px-8 md:px-16 lg:px-24 text-center">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight mb-5 max-w-2xl mx-auto" data-reveal>
        Pronto a digitalizzare<br />la tua azienda?
      </h2>
      <p class="text-base md:text-lg text-white/60 mb-10 max-w-md mx-auto" data-reveal data-delay="2">
        Consulenza gratuita. Ti rispondiamo entro 24 ore.
      </p>
      <div class="flex flex-wrap gap-4 justify-center" data-reveal data-delay="3">
        <a href="/contattaci" class="sl-btn-primary">Richiedi consulenza</a>
        <a href="https://wa.me/393514979670?text=Ciao%2C%20vorrei%20informazioni%20sui%20vostri%20servizi.%20Ho%20visitato%20bitora.it" class="sl-btn-secondary">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </section>

  <script>

    // ── Scroll reveal ─────────────────────────────────────────
    const _revEls = document.querySelectorAll('[data-reveal],[data-reveal-left],[data-reveal-right]');
    const _revObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); _revObs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    _revEls.forEach(el => _revObs.observe(el));
  </script>
  </main>
</Layout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Bitora",
  image: "https://www.bitora.it/bitora.jpg",
  url: "https://www.bitora.it",
  areaServed: ["Carmagnola","Torino","Piemonte","Italia"],
})} />

<style>
  /* ── Hero entrance ── */
  .hero-text > * { opacity:0; animation: heroUp 1s cubic-bezier(0.16,1,0.3,1) forwards; }
  .hero-text > *:nth-child(1) { animation-delay:.15s; }
  .hero-text > *:nth-child(2) { animation-delay:.32s; }
  .hero-text > *:nth-child(3) { animation-delay:.48s; }
  .hero-text > *:nth-child(4) { animation-delay:.64s; }
  @keyframes heroUp {
    from { opacity:0; transform:translateY(36px); }
    to   { opacity:1; transform:translateY(0); }
  }
  /* ── Scroll reveal ── */
  [data-reveal] {
    opacity:0; transform:translateY(52px);
    transition: opacity .85s cubic-bezier(0.16,1,0.3,1), transform .85s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal-left] {
    opacity:0; transform:translateX(-52px);
    transition: opacity .85s cubic-bezier(0.16,1,0.3,1), transform .85s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal-right] {
    opacity:0; transform:translateX(52px);
    transition: opacity .85s cubic-bezier(0.16,1,0.3,1), transform .85s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].is-visible,
  [data-reveal-left].is-visible,
  [data-reveal-right].is-visible { opacity:1; transform:translate(0,0); }
  [data-delay="2"] { transition-delay:.22s; }
  [data-delay="3"] { transition-delay:.4s; }
  /* ── Parallax ── */
  .parallax-img { will-change:transform; }
  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal],[data-reveal-left],[data-reveal-right],.hero-text > * {
      opacity:1!important; transform:none!important; animation:none!important; transition:none!important;
    }
  }
  .sl-btn-primary {
    display:inline-flex;align-items:center;gap:.5rem;
    background:#fff;color:#000;font-weight:600;font-size:.875rem;
    padding:.75rem 1.75rem;border-radius:4px;transition:background .2s;white-space:nowrap;
  }
  .sl-btn-primary:hover{background:#e5e5e5;}
  .sl-btn-secondary {
    display:inline-flex;align-items:center;gap:.5rem;
    background:transparent;color:#fff;font-weight:600;font-size:.875rem;
    padding:.75rem 1.75rem;border-radius:4px;
    border:1.5px solid rgba(255,255,255,.55);
    transition:border-color .2s,background .2s;white-space:nowrap;
  }
  .sl-btn-secondary:hover{border-color:rgba(255,255,255,.9);background:rgba(255,255,255,.08);}
</style>
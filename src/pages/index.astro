      answer:
        'Sì: integriamo email, WhatsApp, fogli, API e processi interni. L’obiettivo è ridurre lavoro manuale.',
    },
    {
      question: 'Offrite supporto dopo il lancio?',
      answer:
        'Sì: monitoraggio, ottimizzazioni e interventi rapidi. Il sito non finisce con la pubblicazione.',
    },
  ]}
/>

<ReviewsSchema
  itemName="Bitora"
  ratingValue={5}
  reviewCount={50}
  reviews={testimonials
    .slice(0, 5)
    .map(t => ({ author: t.author, body: t.quote, rating: t.rating }))}
/>

<script>
  const prefersReduced = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
  if (!prefersReduced) {
    const els = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
    const onScroll = () => {
      const y = window.scrollY || 0;
      els.forEach(el => {
        const r = el.getBoundingClientRect();
        if (r.bottom < 0 || r.top > window.innerHeight) return;
        el.style.transform = `translateY(${(y * 0.06).toFixed(1)}px) scale(1.04)`;
      });
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
